{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Player App (Next.js)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["next", "dev", "--webpack"],
      "port": 3000,
      "cwd": "apps/Phoenix-Sportsbook-Combined/talon-backoffice/packages/app",
      "env": {
        "NEXT_PUBLIC_API_URL": "http://localhost:18080",
        "NEXT_PUBLIC_AUTH_URL": "http://localhost:18081",
        "NEXT_PUBLIC_WS_URL": "ws://localhost:18080/ws"
      }
    },
    {
      "name": "Go Gateway",
      "runtimeExecutable": "go",
      "runtimeArgs": ["run", "./cmd/gateway"],
      "port": 18080,
      "cwd": "apps/Phoenix-Sportsbook-Combined/go-platform/services/gateway",
      "env": {
        "GATEWAY_PORT": "18080",
        "LOG_LEVEL": "debug"
      }
    },
    {
      "name": "Go Auth Service",
      "runtimeExecutable": "go",
      "runtimeArgs": ["run", "./cmd/auth"],
      "port": 18081,
      "cwd": "apps/Phoenix-Sportsbook-Combined/go-platform/services/auth",
      "env": {
        "AUTH_PORT": "18081",
        "LOG_LEVEL": "debug",
        "AUTH_COOKIE_SECURE": "false"
      }
    },
    {
      "name": "Back-Office App (Next.js)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3001,
      "cwd": "apps/Phoenix-Sportsbook-Combined/talon-backoffice/packages/office",
      "env": {
        "NEXT_PUBLIC_API_URL": "http://localhost:18080",
        "NEXT_PUBLIC_AUTH_URL": "http://localhost:18081"
      }
    },
    {
      "name": "PostgreSQL (Docker)",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up", "postgres"],
      "port": 5432,
      "cwd": "apps/Phoenix-Sportsbook-Combined"
    },
    {
      "name": "Redis (Docker)",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up", "redis"],
      "port": 6379,
      "cwd": "apps/Phoenix-Sportsbook-Combined"
    }
  ]
}
