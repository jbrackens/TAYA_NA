{
  "compilerOptions": {
    "outDir": "dist",
    "module": "commonjs",
    "target": "es5",
    "declaration": true,
    "sourceMap": true,
    "noEmitOnError": true,
    "types": ["react", "jest", "node"],
    "lib": ["es2018", "dom"],
    "esModuleInterop": true,
    "jsx": "preserve",
    "moduleResolution": "node",
    "strict": true,
    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "noUnusedParameters": true,
    "removeComments": false,
    "preserveConstEnums": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": "./"
  },
  "exclude": ["node_modules", "dist", "src/__mocks__/*", "src/**/*.test.tsx", "src/**/*.test.ts"],
  "include": ["src/**/*.ts"]
}
