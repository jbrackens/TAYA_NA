# Dedicated runtime profile for MS-008 cross-sport launch-readiness enforcement.

# Stack orchestration controls.
RUNTIME_GATE_AUTOSTART_STACK=1
RUNTIME_GATE_AUTO_STOP_STACK=1
RUNTIME_GATE_BOOTSTRAP=0
RUNTIME_GATE_PICK_FREE_PORTS=0
RUNTIME_GATE_WAIT_TIMEOUT_SECONDS=300

# Runtime versions/ports.
JAVA_PROFILE_VERSION=21
TALON_PORT=3000
SPORTSBOOK_PORT=3002
GO_GATEWAY_PORT=18080

# Runtime gate strictness.
MULTI_SPORT_ITERATIONS=5
MULTI_SPORT_SPORTS_CSV=mlb,nfl,nba,ufc,ncaa_baseball
MULTI_SPORT_CHECK_ESPORTS_COMPAT=1
