{
  "name": "@phoenix-ui/app",
  "version": "0.34.1-build.4",
  "description": "Next.js React App - The Phoenix UI",
  "scripts": {
    "bootstrap:locales": "node ./scripts/translations/generate.js",
    "run-local:dev": "yarn watch & next dev",
    "build": "yarn bootstrap:locales && next build",
    "build:local": "env-cmd -f .env.local yarn build",
    "build:dev": "env-cmd -f .env.development yarn build",
    "build:stage": "env-cmd -f .env.staging yarn build",
    "build:prod": "env-cmd -f .env.production yarn build",
    "build:start": "yarn build && yarn start",
    "build:export": "yarn build && next export",
    "build:export:local": "env-cmd -f .env.local yarn build:export",
    "build:export:dev": "env-cmd -f .env.development yarn build:export",
    "build:export:stage": "env-cmd -f .env.staging yarn build:export",
    "build:export:prod": "env-cmd -f .env.production yarn build:export",
    "start": "next start",
    "start:dev": "env-cmd -f .env.development next start",
    "start:stage": "env-cmd -f .env.staging next start",
    "export": "yarn build && next export",
    "test": "jest --logHeapUsage --maxWorkers=50% --config ./jest.config.js",
    "test:coverage": "jest --coverage --logHeapUsage --maxWorkers=50% --config ./jest.config.js",
    "watch": "node ./scripts/translations/watch.js"
  },
  "dependencies": {
    "@phoenix-ui/utils": "0.23.1-build.1",
    "@types/react-infinite-scroller": "^1.2.1",
    "antd": "4.16.12",
    "formik": "^2.2.9",
    "jsonwebtoken": "^8.5.1",
    "libphonenumber-js": "^1.9.20",
    "i18next": "^23.7.0",
    "next": "13.5.7",
    "next-i18next": "^14.0.3",
    "react-code-input": "^3.10.1",
    "react-i18next": "^13.5.0",
    "react-gtm-module": "^2.0.11",
    "react-infinite-scroller": "^1.2.4",
    "react-redux": "^7.1.3",
    "react-use-websocket": "2.1.1",
    "styled-components": "^5.0.0",
    "uuid": "^8.3.1",
    "yup": "^0.32.11"
  },
  "devDependencies": {
    "@reduxjs/toolkit": "^1.1.0",
    "@types/jest": "24.0.23",
    "@types/jsonwebtoken": "^7.2.7",
    "@types/node": "^14.6.4",
    "@types/react": "18.2.0",
    "@types/react-dom": "18.2.0",
    "@types/react-redux": "^7.1.9",
    "@types/styled-components": "5.1.3",
    "@types/uuid": "^8.3.0",
    "dom-accessibility-api": "^0.5.2",
    "i18next-hmr": "^1.6.0",
    "react-test-renderer": "18.2.0",
    "typescript": "5.3.3"
  },
  "serial-number": 188
}
