{
  "presets": ["next/babel"],
  "plugins": [
    [
      "styled-components", 
      { 
        "ssr": true, 
        "preprocess": false 
    }],
    [
      "module-resolver",
      {
        "extensions": [".js", ".jsx", ".ts", ".tsx"],
        "alias": {
          "i18n": "./i18n.js",
        }
      }
    ]
  ]
}