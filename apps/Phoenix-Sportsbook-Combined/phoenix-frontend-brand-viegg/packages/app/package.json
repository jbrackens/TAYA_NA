{
  "name": "@phoenix-ui/app-darkstormlabs",
  "version": "0.76.0",
  "description": "Phoenix UI - vie.gg",
  "scripts": {
    "bootstrap:locales": "node ./scripts/translations/generate.js",
    "run-local:dev": "NODE_OPTIONS=--openssl-legacy-provider yarn watch & NODE_OPTIONS=--openssl-legacy-provider next",
    "build": "NODE_OPTIONS=--openssl-legacy-provider yarn bootstrap:locales && NODE_OPTIONS=--openssl-legacy-provider next build",
    "build:local": "env-cmd -f .env.local yarn build",
    "build:dev": "env-cmd -f .env.development yarn build",
    "build:stage": "env-cmd -f .env.staging yarn build",
    "build:prod": "env-cmd -f .env.production yarn build",
    "build:start": "yarn build && yarn start",
    "build:export": "yarn build && next export",
    "build:export:local": "env-cmd -f .env.local yarn build:export",
    "build:export:dev": "env-cmd -f .env.development yarn build:export",
    "build:export:stage": "env-cmd -f .env.staging yarn build:export",
    "build:export:prod": "env-cmd -f .env.production yarn build:export",
    "start": "next start",
    "start:dev": "env-cmd -f .env.development next start",
    "start:stage": "env-cmd -f .env.staging next start",
    "export": "yarn build && next export",
    "test": "jest --coverage --passWithNoTests --config ./jest.config.js",
    "watch": "node ./scripts/translations/watch.js"
  },
  "dependencies": {
    "@phoenix-ui/app": "0.34.1-build.4",
    "@phoenix-ui/utils": "0.23.1-build.1",
    "antd": "4.16.12",
    "jsonwebtoken": "^8.5.1",
    "next": "11.1.3",
    "next-compose-plugins": "^2.2.0",
    "next-i18next": "^6.0.2",
    "next-transpile-modules": "^8.0.0",
    "react": "17.0.2",
    "react-dom": "17.0.2",
    "react-fetch-hook": "^1.8.3",
    "react-gtm-module": "^2.0.11",
    "react-redux": "^7.1.3",
    "react-use-websocket": "2.1.1",
    "styled-components": "^5.0.0",
    "uuid": "^8.3.2"
  },
  "devDependencies": {
    "@reduxjs/toolkit": "^1.1.0",
    "@testing-library/jest-dom": "^5.11.4",
    "@testing-library/react": "^11.0.2",
    "@testing-library/react-hooks": "^3.4.1",
    "@testing-library/user-event": "^7.1.2",
    "@types/jest": "24.0.23",
    "@types/jsonwebtoken": "^7.2.7",
    "@types/lodash": "4.14.161",
    "@types/node": "^14.6.4",
    "@types/react": "17.0.2",
    "@types/react-dom": "17.0.2",
    "@types/react-redux": "^7.1.9",
    "@types/styled-components": "^5.1.3",
    "@types/uuid": "^8.3.0",
    "babel-plugin-module-resolver": "^4.0.0",
    "babel-plugin-styled-components": "^1.11.1",
    "dom-accessibility-api": "^0.5.2",
    "i18next-hmr": "^1.6.0",
    "react-test-renderer": "^16.13.1",
    "typescript": "4.3.2"
  },
  "serial-number": 124
}
