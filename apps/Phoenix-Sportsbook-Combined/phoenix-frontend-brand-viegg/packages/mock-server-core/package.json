{
  "name": "@phoenix-ui/mock-server",
  "version": "0.13.0",
  "description": "An Express server delivers mocked API to the Phoenix UI",
  "main": "dist/index.js",
  "esnext": "dist/index.js",
  "files": [
    "dist/**/*"
  ],
  "directories": {
    "src": "src",
    "test": "__tests__"
  },
  "scripts": {
    "run-local:dev": "nodemon --watch 'src/**/*.ts' --exec ts-node src/index.ts",
    "dist": "tsc"
  },
  "dependencies": {
    "body-parser": "^1.19.0",
    "cors": "^2.8.5",
    "express": "^4.17.1",
    "jsonwebtoken": "^8.5.1",
    "nodemon": "^2.0.4",
    "qs": "^6.9.4",
    "ws": "^7.3.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.7",
    "@types/express": "^4.17.8",
    "@types/jsonwebtoken": "^7.2.7",
    "@types/node": "^14.6.4",
    "@types/ws": "^7.2.7",
    "ts-node": "9.0.0",
    "typescript": "4.3.2"
  }
}
