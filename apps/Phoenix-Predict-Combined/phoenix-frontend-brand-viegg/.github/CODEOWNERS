# Note that the rules in CODEOWNERS are NOT additive -
# for any given file, only the latest matching rule (and not all matching rules) applies.

# Lowest priority rule - let's assign YAML files to our designated YAML engineer unless there's a better match for the specific location!

*.yaml                       @PawelLipski
*.yml                        @PawelLipski


# Lower priority rules - for entire directories and wide file globs

/ci/                      @PawelLipski
/deploy/                  @PawelLipski @eesik
/docker/                  @PawelLipski
/.github/                 @PawelLipski
/k8s-operations/          @PawelLipski
*.md                      @PawelLipski
*.sh                      @PawelLipski

# Highest priority rules - for specific files, without globs or with a narrow glob

CHANGELOG.md              # exclude @PawelLipski
.dockerignore             @PawelLipski
.gitignore                @PawelLipski
Jenkinsfile*              @PawelLipski
