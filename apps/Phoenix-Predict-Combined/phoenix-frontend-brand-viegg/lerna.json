{
  "version": "independent",
  "npmClient": "yarn",
  "useWorkspaces": true,
  "ignoreChanges": [
    "**/*.spec.{ts,tsx}",
    "**/*.spec.{js,jsx}",
    "**/*.test.{ts,tsx}",
    "**/*.test.{js,jsx}",
    "**/*.md"
  ],
  "packages": ["packages/*"],
  "command": {
    "publish": {
      "allowBranch": ["master", "develop"],
      "conventionalCommits": true,
      "message": "chore(release): publish",
      "registry": "https://registry.npmjs.org/",
      "exact": true,
      "push": true,
      "verifyAccess": false,
      "yes": true,
      "logLevel": "verbose"
    }
  }
}
