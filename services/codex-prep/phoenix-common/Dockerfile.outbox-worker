FROM golang:1.24-bookworm AS builder

WORKDIR /app
RUN apt-get update && apt-get install -y --no-install-recommends git build-essential pkg-config librdkafka-dev && rm -rf /var/lib/apt/lists/*
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=1 GOOS=linux go build -o /out/phoenix-outbox-worker ./cmd/outbox-worker

FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates librdkafka1 && rm -rf /var/lib/apt/lists/* \
  && useradd --system --create-home --home-dir /app --shell /usr/sbin/nologin phoenix
USER phoenix
WORKDIR /app
COPY --from=builder /out/phoenix-outbox-worker /usr/local/bin/phoenix-outbox-worker
ENTRYPOINT ["/usr/local/bin/phoenix-outbox-worker"]
