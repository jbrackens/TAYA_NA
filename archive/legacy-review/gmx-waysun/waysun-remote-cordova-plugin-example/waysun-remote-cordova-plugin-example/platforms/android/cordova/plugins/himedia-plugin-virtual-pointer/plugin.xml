<?xml version='1.0' encoding='utf-8'?>
<plugin id="himedia-plugin-virtual-pointer" version="0.1.4" xmlns="http://apache.org/cordova/ns/plugins/1.0" xmlns:android="http://schemas.android.com/apk/res/android">

<name>HimediaVirtualPointer</name>

<js-module name="HimediaVirtualPointer" src="www/HimediaVirtualPointer.js">
    <runs />
</js-module>

<asset src="img/cursor.png" target="cursor.png" />

<platform name="android">
    <config-file parent="/*" target="res/xml/config.xml">
        <feature name="HimediaVirtualPointer">
            <param name="android-package" value="himedia-plugin-virtual-pointer.HimediaVirtualPointer" />
        </feature>
    </config-file>

    <config-file parent="/*" target="AndroidManifest.xml"></config-file>
    <source-file src="src/android/HimediaVirtualPointer.java" target-dir="src/himedia-plugin-virtual-pointer/HimediaVirtualPointer" />
</platform>
</plugin>