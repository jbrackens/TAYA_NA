# File contains all values are needed by this scripts only

CFG_REPLICAS=${FORCE_CFG_REPLICAS:-2}
CFG_MAX_REPLICAS=${FORCE_CFG_MAX_REPLICAS:-${CFG_REPLICAS}}

# because I want to have rapid deployment
CFG_STRATEGY_MAX_SURGE=${FORCE_CFG_STRATEGY_MAX_SURGE:-0}
CFG_STRATEGY_MAX_UNAVAILABLE=${FORCE_CFG_STRATEGY_MAX_UNAVAILABLE:-1}

CFG_DEPLOY_TAG=${FORCE_CFG_DEPLOY_TAG:-0.0.27}
CFG_DEPLOY_DB_TAG=${FORCE_CFG_DEPLOY_DB_TAG:-db-migration-${CFG_DEPLOY_TAG}}

CFG_RESOURCE_LIMIT_CPU=${FORCE_CFG_RESOURCE_LIMIT_CPU:-1000m}
CFG_RESOURCE_LIMIT_MEMORY=${FORCE_CFG_RESOURCE_LIMIT_MEMORY:-768Mi}
CFG_RESOURCE_REQUESTS_CPU=${FORCE_CFG_RESOURCE_REQUESTS_CPU:-500m}
CFG_RESOURCE_REQUESTS_MEMORY=${FORCE_CFG_RESOURCE_REQUESTS_MEMORY:-768Mi}

_T="bitwarden|db:tencent:manual-dev:::manual-rds-all-schema:frankfurt-1,frankfurt|"
CFG_WALLET_DB_ADDRESS=${FORCE_CFG_WALLET_DB_ADDRESS:-${_T}hostname}
CFG_WALLET_DB_PORT=${FORCE_CFG_WALLET_DB_PORT:-${_T}port}
CFG_WALLET_DB_NAME=${FORCE_CFG_WALLET_DB_NAME:-'raw|wallet'}
CFG_WALLET_DB_USERNAME=${FORCE_CFG_WALLET_DB_USERNAME:-${_T}username}
CFG_WALLET_DB_PASSWORD=${FORCE_CFG_WALLET_DB_PASSWORD:-${_T}password}

CFG_WALLET_TRANSACTION_READ_DB_ADDRESS=${FORCE_CFG_WALLET_TRANSACTION_READ_DB_ADDRESS:-${_T}hostname-read-replica}
CFG_WALLET_TRANSACTION_READ_DB_PORT=${FORCE_CFG_WALLET_TRANSACTION_READ_DB_PORT:-${_T}port}
CFG_WALLET_TRANSACTION_READ_DB_NAME=${FORCE_CFG_WALLET_TRANSACTION_READ_DB_NAME:-'raw|wallet'}
CFG_WALLET_TRANSACTION_READ_DB_USERNAME=${FORCE_CFG_WALLET_TRANSACTION_READ_DB_USERNAME:-${_T}username}
CFG_WALLET_TRANSACTION_READ_DB_PASSWORD=${FORCE_CFG_WALLET_TRANSACTION_READ_DB_PASSWORD:-${_T}password}

CFG_WALLET_LIQUIBASE_DB_USERNAME=${FORCE_CFG_WALLET_LIQUIBASE_DB_USERNAME:-${_T}username}
CFG_WALLET_LIQUIBASE_DB_PASSWORD=${FORCE_CFG_WALLET_LIQUIBASE_DB_PASSWORD:-${_T}password}

CFG_WALLET_PLAY_SECRET_KEY=${FORCE_CFG_WALLET_PLAY_SECRET_KEY:-'bitwarden|env_var:stella:manual-dev:::microservices:wallet|PLAY_SECRET_KEY'}



CFG_WALLET_TRANSACTION_READ_DB_NUM_THREADS=${FORCE_CFG_WALLET_TRANSACTION_READ_DB_NUM_THREADS:-"5"}
CFG_WALLET_TRANSACTION_READ_DB_MAX_CONNECTIONS=${FORCE_CFG_WALLET_TRANSACTION_READ_DB_MAX_CONNECTIONS:-"5"}
CFG_WALLET_TRANSACTION_READ_DB_MIN_CONNECTIONS=${FORCE_CFG_WALLET_TRANSACTION_READ_DB_MIN_CONNECTIONS:-"5"}

