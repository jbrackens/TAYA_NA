apiVersion: v1
kind: Service
metadata:
  name: wallet
  namespace: ${CFG_K8S_NAMESPACE}
  annotations:
    eeg-ingress/enabled: "true"
    eeg-ingress/path: "/wallet"
    eeg-ingress/service-name: "wallet"
    eeg-ingress/service-port: "8080"
spec:
  externalTrafficPolicy: Cluster
  ports:
  - name: 8080-8080-tcp
    port: 8080
    protocol: TCP
    targetPort: 8080
  selector:
    app: wallet
    k8s-app: wallet
    qcloud-app: wallet
  sessionAffinity: None
  type: NodePort
