apiVersion: v1
kind: ConfigMap
metadata:
  name: wallet
  namespace: ${CFG_K8S_NAMESPACE}
data:
  AKKA_CLUSTER_BOOTSTRAP_SERVICE_NAME: "wallet"
  JAVA_OPTS: "-Dconfig.resource=application-k8s.conf"
  WALLET_AKKA_LOG_LEVEL: "${CFG_WALLET_AKKA_LOG_LEVEL}"
  WALLET_ENTITY_ASK_TIMEOUT: "${CFG_WALLET_ENTITY_ASK_TIMEOUT}"
  WALLET_ENTITY_PERSISTENCE_FAILURE_RESTART_MAX_BACKOFF: "${CFG_WALLET_ENTITY_PERSISTENCE_FAILURE_RESTART_MAX_BACKOFF}"
  WALLET_ENTITY_PERSISTENCE_FAILURE_RESTART_MIN_BACKOFF: "${CFG_WALLET_ENTITY_PERSISTENCE_FAILURE_RESTART_MIN_BACKOFF}"
  WALLET_ENTITY_PERSISTENCE_FAILURE_RESTART_RANDOM_FACTOR: "${CFG_WALLET_ENTITY_PERSISTENCE_FAILURE_RESTART_RANDOM_FACTOR}"
  WALLET_ENTITY_SNAPSHOT_KEEP_N_SNAPSHOTS: "${CFG_WALLET_ENTITY_SNAPSHOT_KEEP_N_SNAPSHOTS}"
  WALLET_ENTITY_SNAPSHOT_NUMBER_OF_EVENTS: "${CFG_WALLET_ENTITY_SNAPSHOT_NUMBER_OF_EVENTS}"
  WALLET_ENTITY_TRANSACTION_PROJECTION_NAME: wallet_transactions
  WALLET_ENTITY_TRANSACTION_PROJECTION_PARALLELISM_LEVEL: "${CFG_WALLET_ENTITY_TRANSACTION_PROJECTION_PARALLELISM_LEVEL}"
  WALLET_ENTITY_TRANSACTION_PROJECTION_SHARDS: "${CFG_WALLET_ENTITY_TRANSACTION_PROJECTION_SHARDS}"
  WALLET_HOST: "0.0.0.0"
  WALLET_PORT: "8080"
  WALLET_START_AKKA_MANAGEMENT_AND_CLUSTER_BOOTSTRAP: "true"
  WALLET_TRANSACTION_READ_DB_NUM_THREADS: "${CFG_WALLET_TRANSACTION_READ_DB_NUM_THREADS}"
  WALLET_TRANSACTION_READ_DB_MAX_CONNECTIONS: "${CFG_WALLET_TRANSACTION_READ_DB_MAX_CONNECTIONS}"
  WALLET_TRANSACTION_READ_DB_MIN_CONNECTIONS: "${CFG_WALLET_TRANSACTION_READ_DB_MIN_CONNECTIONS}"
