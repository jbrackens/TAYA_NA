CFG_USER_CONTEXT_LIQUIBASE_DB_PASSWORD=${FORCE_CFG_USER_CONTEXT_LIQUIBASE_DB_PASSWORD:-${_T}password}


CFG_WALLET_TRANSACTION_READ_DB_ADDRESS=${FORCE_CFG_WALLET_TRANSACTION_READ_DB_ADDRESS:-${_T}hostname}
CFG_WALLET_TRANSACTION_READ_DB_PORT=${FORCE_CFG_WALLET_TRANSACTION_READ_DB_PORT:-${_T}port}
CFG_WALLET_TRANSACTION_READ_DB_NAME=${FORCE_CFG_WALLET_TRANSACTION_READ_DB_NAME:-'raw|wallet'}
CFG_WALLET_TRANSACTION_READ_DB_USERNAME=${FORCE_CFG_WALLET_TRANSACTION_READ_DB_USERNAME:-${_T}username}
CFG_WALLET_TRANSACTION_READ_DB_PASSWORD=${FORCE_CFG_WALLET_TRANSACTION_READ_DB_PASSWORD:-${_T}password}



CFG_USER_CONTEXT_PLAY_SECRET_KEY=${FORCE_CFG_USER_CONTEXT_PLAY_SECRET_KEY:-'bitwarden|env_var:stella:terra-dev:::microservices:wallet|PLAY_SECRET_KEY'}



