# File contains all values are needed by this scripts only

CFG_REPLICAS=${FORCE_CFG_REPLICAS:-2}

# because I want to have rapid deployment
CFG_STRATEGY_MAX_SURGE=${FORCE_CFG_STRATEGY_MAX_SURGE:-0}
CFG_STRATEGY_MAX_UNAVAILABLE=${FORCE_CFG_STRATEGY_MAX_UNAVAILABLE:-1}

CFG_DEPLOY_TAG=${FORCE_CFG_DEPLOY_TAG:-0.0.15}
CFG_DEPLOY_DB_TAG=${FORCE_CFG_DEPLOY_DB_TAG:-db-migration-${CFG_DEPLOY_TAG}}

CFG_RESOURCE_LIMIT_CPU=${FORCE_CFG_RESOURCE_LIMIT_CPU:-1024m}
CFG_RESOURCE_LIMIT_MEMORY=${FORCE_CFG_RESOURCE_LIMIT_MEMORY:-1024Mi}
CFG_RESOURCE_REQUESTS_CPU=${FORCE_CFG_RESOURCE_REQUESTS_CPU:-1024m}
CFG_RESOURCE_REQUESTS_MEMORY=${FORCE_CFG_RESOURCE_REQUESTS_MEMORY:-1024Mi}

_T="bitwarden|db:tencent:terra-dev:::terra-rds-all-schema:frankfurt-2,frankfurt|"
CFG_USER_CONTEXT_DB_ADDRESS=${FORCE_CFG_USER_CONTEXT_DB_ADDRESS:-${_T}hostname}
CFG_USER_CONTEXT_DB_PORT=${FORCE_CFG_USER_CONTEXT_DB_PORT:-${_T}port}
CFG_USER_CONTEXT_DB_NAME=${FORCE_CFG_USER_CONTEXT_DB_NAME:-'raw|wallet'}
CFG_USER_CONTEXT_DB_USERNAME=${FORCE_CFG_USER_CONTEXT_DB_USERNAME:-${_T}username}
CFG_USER_CONTEXT_DB_PASSWORD=${FORCE_CFG_USER_CONTEXT_DB_PASSWORD:-${_T}password}
