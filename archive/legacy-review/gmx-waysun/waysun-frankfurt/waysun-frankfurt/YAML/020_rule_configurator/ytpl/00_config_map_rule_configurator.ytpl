apiVersion: v1
kind: ConfigMap
metadata:
  name: rule-configurator
  namespace: ${CFG_K8S_NAMESPACE}
data:
  RULE_CONFIGURATOR_ACHIEVEMENT_KAFKA_CLIENT_ID: ${CFG_RULE_CONFIGURATOR_ACHIEVEMENT_KAFKA_CLIENT_ID}
  RULE_CONFIGURATOR_AGGREGATION_KAFKA_CLIENT_ID: ${CFG_RULE_CONFIGURATOR_AGGREGATION_KAFKA_CLIENT_ID}
  RULE_CONFIGURATOR_EVENT_KAFKA_CLIENT_ID: ${CFG_RULE_CONFIGURATOR_EVENT_KAFKA_CLIENT_ID}
  RULE_CONFIGURATOR_HOST: 0.0.0.0
  RULE_CONFIGURATOR_KAFKA_MAX_REQUESTS_PER_CONNECTION: "1"
  RULE_CONFIGURATOR_PORT: "8080"
