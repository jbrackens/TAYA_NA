  namespace: ${CFG_K8S_NAMESPACE}
data:
  RULE_CONFIGURATOR_LIQUIBASE_DB_USERNAME: ${RULE_CONFIGURATOR_LIQUIBASE_DB_USERNAME}
  RULE_CONFIGURATOR_LIQUIBASE_DB_PASSWORD: ${RULE_CONFIGURATOR_LIQUIBASE_DB_PASSWORD}
