apiVersion: v1
kind: ConfigMap
metadata:
  name: event-ingestor
  namespace: ${CFG_K8S_NAMESPACE}
data:
  EVENT_INGESTOR_EVENT_PUBLICATION_MODE: "publishDirectlyToKafka"
  EVENT_INGESTOR_HOST: "0.0.0.0"
  EVENT_INGESTOR_KAFKA_CLIENT_ID: "event-ingestor"
  EVENT_INGESTOR_KAFKA_GROUP_ID: "event-ingestor"
  EVENT_INGESTOR_KAFKA_MAX_REQUESTS_PER_CONNECTION: "5"
  EVENT_INGESTOR_KAFKA_POLL_TIMEOUT: "1 second"
  EVENT_INGESTOR_KAFKA_PUBLICATION_TIME_LIMIT: "1 second"
  EVENT_INGESTOR_PORT: "8080"

