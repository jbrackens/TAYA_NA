# File contains all values are needed by this scripts only
CFG_REPLICAS=${FORCE_CFG_REPLICAS:-1}
CFG_MAX_REPLICAS=${FORCE_CFG_MAX_REPLICAS:-${CFG_REPLICAS}}

# because I want to have rapid deployment
CFG_STRATEGY_MAX_SURGE=${FORCE_CFG_STRATEGY_MAX_SURGE:-0}
CFG_STRATEGY_MAX_UNAVAILABLE=${FORCE_CFG_STRATEGY_MAX_UNAVAILABLE:-1}

CFG_DEPLOY_TAG=${FORCE_CFG_DEPLOY_TAG:-0.0.28}
CFG_DEPLOY_DB_TAG=${FORCE_CFG_DEPLOY_DB_TAG:-db-migration-${CFG_DEPLOY_TAG}}

CFG_RESOURCE_LIMIT_CPU=${FORCE_CFG_RESOURCE_LIMIT_CPU:-1000m}
CFG_RESOURCE_LIMIT_MEMORY=${FORCE_CFG_RESOURCE_LIMIT_MEMORY:-768Mi}
CFG_RESOURCE_REQUESTS_CPU=${FORCE_CFG_RESOURCE_REQUESTS_CPU:-250m}
CFG_RESOURCE_REQUESTS_MEMORY=${FORCE_CFG_RESOURCE_REQUESTS_MEMORY:-768Mi}

CFG_ACHIEVEMENT_ACHIEVEMENT_EVENTS_CACHE_TIMEOUT="${FORCE_CFG_ACHIEVEMENT_ACHIEVEMENT_EVENTS_CACHE_TIMEOUT:-10 seconds}"
CFG_ACHIEVEMENT_WINDOWS_CACHE_TIMEOUT="${FORCE_CFG_ACHIEVEMENT_WINDOWS_CACHE_TIMEOUT:-10 seconds}"

_T="bitwarden|db:tencent:manual-dev:::manual-rds-all-schema:frankfurt-1,frankfurt|"
CFG_ACHIEVEMENT_DB_ADDRESS=${FORCE_CFG_ACHIEVEMENT_DB_ADDRESS:-${_T}hostname}
CFG_ACHIEVEMENT_DB_PORT=${FORCE_CFG_ACHIEVEMENT_DB_PORT:-${_T}port}
CFG_ACHIEVEMENT_DB_NAME=${FORCE_CFG_ACHIEVEMENT_DB_NAME:-raw|achievement}
CFG_ACHIEVEMENT_DB_USERNAME=${FORCE_CFG_ACHIEVEMENT_DB_USERNAME:-${_T}username}
CFG_ACHIEVEMENT_DB_PASSWORD=${FORCE_CFG_ACHIEVEMENT_DB_PASSWORD:-${_T}password}
CFG_ACHIEVEMENT_LIQUIBASE_DB_USERNAME=${FORCE_CFG_ACHIEVEMENT_LIQUIBASE_DB_USERNAME:-${_T}username}
CFG_ACHIEVEMENT_LIQUIBASE_DB_PASSWORD=${FORCE_CFG_ACHIEVEMENT_LIQUIBASE_DB_PASSWORD:-${_T}password}

CFG_ACHIEVEMENT_PLAY_SECRET_KEY=${FORCE_CFG_ACHIEVEMENT_PLAY_SECRET_KEY:-'bitwarden|env_var:stella:manual-dev:::microservices:achievement|PLAY_SECRET_KEY'}
_T='bitwarden|redis:tencent:manual-dev:::manual-redis:frankfurt-1,frankfurt|'
CFG_ACHIEVEMENT_REDIS_DATABASE_NUMBER=${FORCE_CFG_ACHIEVEMENT_REDIS_DATABASE_NUMBER:-raw|3}
CFG_ACHIEVEMENT_REDIS_HOST=${FORCE_CFG_ACHIEVEMENT_REDIS_HOST:-${_T}hostname}
CFG_ACHIEVEMENT_REDIS_PORT=${FORCE_CFG_ACHIEVEMENT_REDIS_PORT:-${_T}port}
CFG_ACHIEVEMENT_REDIS_PASSWORD=${FORCE_CFG_ACHIEVEMENT_REDIS_PASSWORD:-${_T}password}
