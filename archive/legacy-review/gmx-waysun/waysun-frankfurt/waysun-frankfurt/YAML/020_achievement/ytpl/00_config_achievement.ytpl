apiVersion: v1
kind: ConfigMap
metadata:
  name: achievement
  namespace: ${CFG_K8S_NAMESPACE}
data:
  ACHIEVEMENT_ACHIEVEMENT_EVENTS_CACHE_TIMEOUT: ${CFG_ACHIEVEMENT_ACHIEVEMENT_EVENTS_CACHE_TIMEOUT}
  ACHIEVEMENT_WINDOWS_CACHE_TIMEOUT: ${CFG_ACHIEVEMENT_WINDOWS_CACHE_TIMEOUT}
  ACHIEVEMENT_HOST: 0.0.0.0
  ACHIEVEMENT_PORT: "8080"
