# File contains all values are needed by this scripts only
readonly CFG_K8S_NAMESPACE=${FORCE_CFG_K8S_NAMESPACE:-microservices}

readonly CFG_LOGGING_USE_JSON=${FORCE_CFG_LOGGING_USE_JSON:-"false"}
readonly CFG_OPEN_API_SERVER_URL=${FORCE_CFG_OPEN_API_SERVER_URL:-"https://api.dev.stella.waysungames.com/"}
readonly CFG_REQUIRE_JWT_AUTH=${FORCE_CFG_REQUIRE_JWT_AUTH:-"true"}
readonly CFG_TEST_PROJECT_ID=${FORCE_CFG_TEST_PROJECT_ID:-"b7d38c10-1870-4594-8d51-f6ae6c788e05"}
readonly CFG_TEST_USER_ID=${FORCE_CFG_TEST_USER_ID:-"524c2046-9d6a-4430-bad3-890ff7987848"}

_T='bitwarden|env_var:stella:manual-dev:::microservices:common|SECRET_BOX_HEX_KEY'
