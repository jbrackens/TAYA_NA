# File contains all values are needed by this scripts only
CFG_K8S_NAMESPACE=${FORCE_CFG_K8S_NAMESPACE:-microservices}

CFG_ISSUER_CACHE_REFRESH_FREQUENCY=${FORCE_CFG_ISSUER_CACHE_REFRESH_FREQUENCY:-"1 hour"}
CFG_JWKS_CACHE_REFRESH_FREQUENCY=${FORCE_CFG_JWKS_CACHE_REFRESH_FREQUENCY:-"10 minutes"}
CFG_JWT_SERVICE_DISCOVERY_URI=${FORCE_CFG_JWT_SERVICE_DISCOVERY_URI:-"http://localhost:8080/auth/realms"}
CFG_JWT_INTERNAL_SERVICE_DISCOVERY_URI=${FORCE_CFG_JWT_INTERNAL_SERVICE_DISCOVERY_URI:-"http://localhost:8080/auth/realms"}
CFG_KAFKA_BOOTSTRAP_SERVERS=${FORCE_CFG_KAFKA_BOOTSTRAP_SERVERS:-"kafka.streaming.svc.cluster.local:9092"}
CFG_KAFKA_SCHEMA_REGISTRY_URL=${FORCE_CFG_KAFKA_SCHEMA_REGISTRY_URL:-"http://cp-schema-registry.streaming.svc.cluster.local:8081"}
CFG_LOGGING_USE_JSON=${FORCE_CFG_LOGGING_USE_JSON:-"true"}
CFG_OPEN_API_SERVER_URL=${FORCE_CFG_OPEN_API_SERVER_URL:-"undefined"}
CFG_REQUIRE_JWT_AUTH=${FORCE_CFG_REQUIRE_JWT_AUTH:-"true"}
CFG_TEST_PROJECT_ID=${FORCE_CFG_TEST_PROJECT_ID:-""}
CFG_TEST_USER_ID=${FORCE_CFG_TEST_USER_ID:-""}

readonly CFG_TOPIC_NAME_FOR_ACHIEVEMENTS=${FORCE_CFG_TOPIC_NAME_FOR_ACHIEVEMENTS:-"stella-streaming.default-achievement-achieved"}
readonly CFG_TOPIC_NAME_FOR_ACHIEVEMENTS_DEFINITION=${FORCE_CFG_TOPIC_NAME_FOR_ACHIEVEMENTS_DEFINITION:-"stella-messaging.default-achievement-definition"}
readonly CFG_TOPIC_NAME_FOR_AGGREGATIONS=${FORCE_CFG_TOPIC_NAME_FOR_AGGREGATIONS:-"stella-streaming.default-aggregation-aggregated"}
readonly CFG_TOPIC_NAME_FOR_AGGREGATIONS_DEFINITION=${FORCE_CFG_TOPIC_NAME_FOR_AGGREGATIONS_DEFINITION:-"stella-messaging.default-aggregation-definition"}
readonly CFG_TOPIC_NAME_FOR_EVENTS_DEFINITION=${FORCE_CFG_TOPIC_NAME_FOR_EVENTS_DEFINITION:-"stella-messaging.default-event-definition"}
readonly CFG_TOPIC_NAME_FOR_EVENTS_RAW=${FORCE_CFG_TOPIC_NAME_FOR_EVENTS_RAW:-"stella-streaming.default-event-raw"}

CFG_SECRET_BOX_HEX_KEY=${FORCE_CFG_SECRET_BOX_HEX_KEY:-"undefined"}
