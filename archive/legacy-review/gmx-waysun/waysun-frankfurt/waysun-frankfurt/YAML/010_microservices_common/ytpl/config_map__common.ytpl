apiVersion: v1
kind: ConfigMap
metadata:
  name: common
  namespace: "${CFG_K8S_NAMESPACE}"
data:
  ISSUER_CACHE_REFRESH_FREQUENCY: "${CFG_ISSUER_CACHE_REFRESH_FREQUENCY}"
  JWKS_CACHE_REFRESH_FREQUENCY: "${CFG_JWKS_CACHE_REFRESH_FREQUENCY}"
  JWT_SERVICE_DISCOVERY_URI: "${CFG_JWT_SERVICE_DISCOVERY_URI}"
  JWT_INTERNAL_SERVICE_DISCOVERY_URI: "${CFG_JWT_INTERNAL_SERVICE_DISCOVERY_URI}"
  KAFKA_BOOTSTRAP_SERVERS: "${CFG_KAFKA_BOOTSTRAP_SERVERS}"
  KAFKA_SCHEMA_REGISTRY_URL: "${CFG_KAFKA_SCHEMA_REGISTRY_URL}"
  LOGGING_USE_JSON: "${CFG_LOGGING_USE_JSON}"
  OPEN_API_SERVER_URL: "${CFG_OPEN_API_SERVER_URL}"
  REQUIRE_JWT_AUTH: "${CFG_REQUIRE_JWT_AUTH}"
  TEST_PROJECT_ID: "${CFG_TEST_PROJECT_ID}"
  TEST_USER_ID: "${CFG_TEST_USER_ID}"
  TOPIC_NAME_FOR_ACHIEVEMENTS: "${CFG_TOPIC_NAME_FOR_ACHIEVEMENTS}"
  TOPIC_NAME_FOR_ACHIEVEMENTS_DEFINITION: "${CFG_TOPIC_NAME_FOR_ACHIEVEMENTS_DEFINITION}"
  TOPIC_NAME_FOR_AGGREGATIONS: "${CFG_TOPIC_NAME_FOR_AGGREGATIONS}"
  TOPIC_NAME_FOR_AGGREGATIONS_DEFINITION: "${CFG_TOPIC_NAME_FOR_AGGREGATIONS_DEFINITION}"
  TOPIC_NAME_FOR_EVENTS_DEFINITION: "${CFG_TOPIC_NAME_FOR_EVENTS_DEFINITION}"
  TOPIC_NAME_FOR_EVENTS_RAW: "${CFG_TOPIC_NAME_FOR_EVENTS_RAW}"
