apiVersion: v1
kind: Secret
type: Opaque
metadata:
  name: user-context
  namespace: ${CFG_K8S_NAMESPACE}
data:
  USER_CONTEXT_DB_ADDRESS: ${USER_CONTEXT_DB_ADDRESS}
  USER_CONTEXT_DB_PORT: ${USER_CONTEXT_DB_PORT}
  USER_CONTEXT_DB_NAME: ${USER_CONTEXT_DB_NAME}
  USER_CONTEXT_DB_USERNAME: ${USER_CONTEXT_DB_USERNAME}
  USER_CONTEXT_DB_PASSWORD: ${USER_CONTEXT_DB_PASSWORD}
  USER_CONTEXT_PLAY_SECRET_KEY: ${USER_CONTEXT_PLAY_SECRET_KEY}

