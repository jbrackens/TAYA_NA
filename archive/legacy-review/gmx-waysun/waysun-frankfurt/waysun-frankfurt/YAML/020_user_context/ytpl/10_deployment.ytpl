apiVersion: apps/v1
kind: Deployment
metadata:
  labels:
    app: user-context
    k8s-app: user-context
    qcloud-app: user-context
  name: user-context
  namespace: ${CFG_K8S_NAMESPACE}
spec:
  progressDeadlineSeconds: 600
  replicas: ${CFG_REPLICAS}
  selector:
    matchLabels:
      app: user-context
      k8s-app: user-context
      qcloud-app: user-context
  strategy:
    rollingUpdate:
      maxSurge: ${CFG_STRATEGY_MAX_SURGE}
      maxUnavailable: ${CFG_STRATEGY_MAX_UNAVAILABLE}
    type: RollingUpdate
  template:
    metadata:
      labels:
        app: user-context
        k8s-app: user-context
        qcloud-app: user-context
    spec:
      affinity:
        nodeAffinity:
          preferredDuringSchedulingIgnoredDuringExecution:
          - preference:
              matchExpressions:
              - key: nodes-type
                operator: In
                values:
                - ${CFG_DEPLOY_ON_POOL}
            weight: 1
          requiredDuringSchedulingIgnoredDuringExecution:
            nodeSelectorTerms:
            - matchExpressions:
              - key: nodes-type
                operator: In
                values:
                - ${CFG_DEPLOY_ON_POOL}
      containers:
      - env:
        - name: USER_CONTEXT_REQUIRE_JWT_AUTH
          valueFrom:
            configMapKeyRef:
              key: REQUIRE_JWT_AUTH
              name: common
              optional: false
        - name: USER_CONTEXT_TEST_USER_ID
          valueFrom:
            configMapKeyRef:
              key: TEST_USER_ID
              name: common
              optional: false
        - name: USER_CONTEXT_TEST_PROJECT_ID
          valueFrom:
            configMapKeyRef:
              key: TEST_PROJECT_ID
              name: common
              optional: false
        - name: JWT_SERVICE_DISCOVERY_URI
          valueFrom:
            configMapKeyRef:
              key: JWT_SERVICE_DISCOVERY_URI
              name: common
              optional: false
        - name: JWT_INTERNAL_SERVICE_DISCOVERY_URI
          valueFrom:
            configMapKeyRef:
              key: JWT_INTERNAL_SERVICE_DISCOVERY_URI
              name: common
              optional: false
        - name: USER_CONTEXT_ISSUER_CACHE_REFRESH_FREQUENCY
          valueFrom:
            configMapKeyRef:
              key: ISSUER_CACHE_REFRESH_FREQUENCY
              name: common
              optional: false
        - name: USER_CONTEXT_JWKS_CACHE_REFRESH_FREQUENCY
          valueFrom:
            configMapKeyRef:
              key: JWKS_CACHE_REFRESH_FREQUENCY
              name: common
              optional: false
        - name: USER_CONTEXT_SECRET_BOX_HEX_KEY
          valueFrom:
            secretKeyRef:
              key: SECRET_BOX_HEX_KEY
              name: common
              optional: false
        - name: USER_CONTEXT_OPEN_API_SERVER_URL
          valueFrom:
            configMapKeyRef:
              key: OPEN_API_SERVER_URL
              name: common
              optional: false
        - name: LOGGING_USE_JSON
          valueFrom:
            configMapKeyRef:
              key: LOGGING_USE_JSON
              name: common
              optional: false
        envFrom:
        - secretRef:
            name: user-context
        - configMapRef:
            name: user-context
        image: "${CFG_DEPLOY_IMAGE}:${CFG_DEPLOY_TAG}"
        imagePullPolicy: Always
        name: user-context
        livenessProbe:
          failureThreshold: 3
          httpGet:
            path: /alive
            port: 8558
            scheme: HTTP
          initialDelaySeconds: 60
          periodSeconds: 10
          successThreshold: 1
          timeoutSeconds: 10
        readinessProbe:
          failureThreshold: 3
          httpGet:
            path: /ready
            port: 8558
            scheme: HTTP
          initialDelaySeconds: 60
          periodSeconds: 10
          successThreshold: 1
          timeoutSeconds: 2
        resources:
          limits:
            cpu: ${CFG_RESOURCE_LIMIT_CPU}
            memory: ${CFG_RESOURCE_LIMIT_MEMORY}
          requests:
            cpu: ${CFG_RESOURCE_REQUESTS_CPU}
            memory: ${CFG_RESOURCE_REQUESTS_MEMORY}
        securityContext:
          privileged: false
        terminationMessagePath: /dev/termination-log
        terminationMessagePolicy: File
      dnsPolicy: ClusterFirst
      initContainers:
      - args:
        - -c
        - /liquibase/docker-entrypoint.sh --url=jdbc:postgresql://§{USER_CONTEXT_DB_ADDRESS}:§{USER_CONTEXT_DB_PORT}/§{USER_CONTEXT_DB_NAME}
          --username=§{USER_CONTEXT_LIQUIBASE_DB_USERNAME} --password=§{USER_CONTEXT_LIQUIBASE_DB_PASSWORD}
          --changeLogFile=changelog/changelog.xml update
        command:
        - sh
        envFrom:
        - secretRef:
            name: user-context
        - secretRef:
            name: user-context-db-migration
        image: "${CFG_DEPLOY_IMAGE}:${CFG_DEPLOY_DB_TAG}"
        imagePullPolicy: Always
        name: init
        resources:
          limits:
            cpu: 500m
            memory: 1Gi
          requests:
            cpu: 500m
            memory: 1Gi
        securityContext:
          privileged: false
        terminationMessagePath: /dev/termination-log
        terminationMessagePolicy: File
      restartPolicy: Always
      schedulerName: default-scheduler
      securityContext: {}
      terminationGracePeriodSeconds: 30
