apiVersion: v1
kind: ConfigMap
metadata:
  name: user-context
  namespace: ${CFG_K8S_NAMESPACE}
data:
  AKKA_CLUSTER_BOOTSTRAP_SERVICE_NAME: user-context
  JAVA_OPTS: -Dconfig.resource=application-k8s.conf
  USER_CONTEXT_ENTITY_ASK_TIMEOUT: ${CFG_USER_CONTEXT_ENTITY_ASK_TIMEOUT}
  USER_CONTEXT_HOST: 0.0.0.0
  USER_CONTEXT_PORT: "8080"
  USER_CONTEXT_START_AKKA_MANAGEMENT_AND_CLUSTER_BOOTSTRAP: "true"
