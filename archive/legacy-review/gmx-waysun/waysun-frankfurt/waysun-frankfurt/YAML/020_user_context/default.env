# File contains all values are needed by this scripts only
CFG_K8S_NAMESPACE=${FORCE_CFG_K8S_NAMESPACE:-microservices}

CFG_REPLICAS=undefined
CFG_ENABLE_HPA=${FORCE_CFG_ENABLE_HPA:-false}
CFG_MAX_REPLICAS=${FORCE_CFG_MAX_REPLICAS:-${CFG_REPLICAS}}
CFG_HPA_CPU_UTILIZATION=${FORCE_CFG_HPA_CPU_UTILIZATION:-80}

CFG_STRATEGY_MAX_SURGE=${FORCE_CFG_STRATEGY_MAX_SURGE:-1}
CFG_STRATEGY_MAX_UNAVAILABLE=${FORCE_CFG_STRATEGY_MAX_UNAVAILABLE:-0}

CFG_DEPLOY_ON_POOL=${FORCE_CFG_DEPLOY_ON_POOL:-microservices-nodes}


CFG_DEPLOY_IMAGE=${FORCE_CFG_DEPLOY_IMAGE:-waysun-dev.tencentcloudcr.com/stella/user-context}
CFG_DEPLOY_TAG=undefined
CFG_DEPLOY_DB_TAG=undefined

CFG_RESOURCE_LIMIT_CPU=undefined
CFG_RESOURCE_LIMIT_MEMORY=undefined
CFG_RESOURCE_REQUESTS_CPU=undefined
CFG_RESOURCE_REQUESTS_MEMORY=undefined

CFG_USER_CONTEXT_ENTITY_ASK_TIMEOUT=${FORCE_CFG_USER_CONTEXT_ENTITY_ASK_TIMEOUT:-"10 seconds"}

CFG_USER_CONTEXT_DB_ADDRESS=undefined
CFG_USER_CONTEXT_DB_NAME=undefined
CFG_USER_CONTEXT_DB_PASSWORD=undefined
CFG_USER_CONTEXT_DB_PORT=undefined
CFG_USER_CONTEXT_DB_USERNAME=undefined
CFG_USER_CONTEXT_PLAY_SECRET_KEY=undefined
