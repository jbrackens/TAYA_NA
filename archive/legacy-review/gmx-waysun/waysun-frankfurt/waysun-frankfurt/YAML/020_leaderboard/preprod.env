# File contains all values are needed by this scripts only
CFG_REPLICAS=${FORCE_CFG_REPLICAS:-1}
CFG_INGESTOR_REPLICAS=${FORCE_CFG_INGESTOR_REPLICAS:-1}

# because I want to have rapid deployment
CFG_STRATEGY_MAX_SURGE=${FORCE_CFG_STRATEGY_MAX_SURGE:-0}
CFG_STRATEGY_MAX_UNAVAILABLE=${FORCE_CFG_STRATEGY_MAX_UNAVAILABLE:-1}

CFG_DEPLOY_TAG=${FORCE_CFG_DEPLOY_TAG:-0.0.27}
CFG_DEPLOY_DB_TAG=${FORCE_CFG_DEPLOY_DB_TAG:-db-migration-${CFG_DEPLOY_TAG}}
CFG_DEPLOY_INGESTOR_TAG=${FORCE_CFG_DEPLOY_DB_TAG:-ingestor-${CFG_DEPLOY_TAG}}

CFG_RESOURCE_LIMIT_CPU=${FORCE_CFG_RESOURCE_LIMIT_CPU:-250m}
CFG_RESOURCE_LIMIT_MEMORY=${FORCE_CFG_RESOURCE_LIMIT_MEMORY:-512Mi}
CFG_RESOURCE_REQUESTS_CPU=${FORCE_CFG_RESOURCE_REQUESTS_CPU:-250m}
CFG_RESOURCE_REQUESTS_MEMORY=${FORCE_CFG_RESOURCE_REQUESTS_MEMORY:-512Mi}

CFG_RESOURCE_INGESTOR_LIMIT_CPU=${FORCE_CFG_RESOURCE_REQUESTS_CPU:-250m}
CFG_RESOURCE_INGESTOR_LIMIT_MEMORY=${FORCE_CFG_RESOURCE_REQUESTS_MEMORY:-512Mi}
CFG_RESOURCE_INGESTOR_REQUESTS_CPU=${FORCE_CFG_RESOURCE_REQUESTS_CPU:-250m}
CFG_RESOURCE_INGESTOR_REQUESTS_MEMORY=${FORCE_CFG_RESOURCE_REQUESTS_MEMORY:-512Mi}

_T="bitwarden|db:tencent:terra-dev:::terra-rds-all-schema:frankfurt-2,frankfurt|"
CFG_LEADERBOARD_DB_ADDRESS=${FORCE_CFG_LEADERBOARD_DB_ADDRESS:-${_T}hostname}
CFG_LEADERBOARD_DB_PORT=${FORCE_CFG_LEADERBOARD_DB_PORT:-${_T}port}
CFG_LEADERBOARD_DB_NAME=${FORCE_CFG_LEADERBOARD_DB_NAME:-'raw|leaderboard'}
CFG_LEADERBOARD_DB_USERNAME=${FORCE_CFG_LEADERBOARD_DB_USERNAME:-${_T}username}
CFG_LEADERBOARD_DB_PASSWORD=${FORCE_CFG_LEADERBOARD_DB_PASSWORD:-${_T}password}

CFG_LEADERBOARD_LIQUIBASE_DB_USERNAME=${FORCE_CFG_LEADERBOARD_DB_USERNAME:-${_T}username}
CFG_LEADERBOARD_LIQUIBASE_DB_PASSWORD=${FORCE_CFG_LEADERBOARD_DB_PASSWORD:-${_T}password}

CFG_LEADERBOARD_PLAY_SECRET_KEY=${FORCE_CFG_LEADERBOARD_PLAY_SECRET_KEY:-'bitwarden|env_var:stella:terra-dev:::microservices:leaderboard|PLAY_SECRET_KEY'}

_T='bitwarden|redis:tencent:terra-dev:::terra-redis:frankfurt-2,frankfurt|'
CFG_LEADERBOARD_REDIS_DATABASE_NUMBER=${FORCE_CFG_LEADERBOARD_REDIS_DATABASE_NUMBER:-'raw|2'}
CFG_LEADERBOARD_REDIS_HOST=${FORCE_CFG_LEADERBOARD_REDIS_HOST:-${_T}hostname}
CFG_LEADERBOARD_REDIS_PORT=${FORCE_CFG_LEADERBOARD_REDIS_PORT:-${_T}port}
CFG_LEADERBOARD_REDIS_PASSWORD=${FORCE_CFG_LEADERBOARD_REDIS_PASSWORD:-${_T}password}

