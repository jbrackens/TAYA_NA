KC_DB=postgres
KC_DB_URL=jdbc:postgresql://postgres:5432/keycloak
KC_DB_USERNAME=postgres
KC_DB_PASSWORD=postgres

KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=password

KC_HOSTNAME_PATH=/auth
KC_HTTP_ENABLED=true
KC_HTTP_PORT=8080
KC_HTTP_HOST=0.0.0.0
KC_HTTP_RELATIVE_PATH=/auth
KC_LOG_FORMAT='%d{HH:mm:ss,SSS} %-5p [cid=%X{correlationId}] [%c] (%t) %s%e%n'
KC_LOG_LEVEL=INFO,org.keycloak.services.scheduled.ScheduledTaskRunner:info,org.keycloak:debug,org.keycloak.transaction:info

ALLOW_ACCESS_TOKEN_AUTHORIZATION=true
IDENTITY_PROVIDER_EVENT_INGESTOR_BASE_URL=http://stella.local:8000
IDENTITY_PROVIDER_PUBLISHER_USERNAME=admin
IDENTITY_PROVIDER_PUBLISHER_REALM=master
IDENTITY_PROVIDER_PUBLISHER_CLIENT_ID=myclient-uuid
IDENTITY_PROVIDER_PUBLISHER_TOKEN_MINIMUM_REMAINING_SECONDS_TO_EXPIRE=60

