<?xml version="1.0" encoding="UTF-8"?>
<configuration scan="true" scanPeriod="3 seconds">
    <statusListener class="ch.qos.logback.core.status.OnConsoleStatusListener"/>

    <contextListener class="ch.qos.logback.classic.jul.LevelChangePropagator">
        <resetJUL>true</resetJUL>
    </contextListener>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LoggingEventCompositeJsonEncoder">
            <providers>
                <timestamp/>
                <logLevel/>
                <threadName/>
                <loggerName/>
                <mdc/>
                <message/>
                <arguments/>
                <stackTrace/>
                <stackHash/>
            </providers>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>

    <!-- Logging for Application -->
    <logger name="eeg.waysun.events.validators" level="WARN"/>
    <logger name="io.confluent.kafka.schemaregistry.client.rest" level="WARN"/>
    <logger name="io.confluent.kafka.schemaregistry" level="WARN"/>
    <logger name="org.apache.flink.runtime.checkpoint.CheckpointCoordinator" level="WARN"/>
    <logger name="org.apache.flink.streaming.connectors.kafka.FlinkKafkaProducer" level="WARN"/>
    <logger name="org.apache.flink.streaming.api.functions.sink.TwoPhaseCommitSinkFunction" level="WARN" />


</configuration>