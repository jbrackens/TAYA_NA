<configuration>
    <statusListener class="ch.qos.logback.core.status.OnConsoleStatusListener"/>

    <contextListener class="ch.qos.logback.classic.jul.LevelChangePropagator">
        <resetJUL>true</resetJUL>
    </contextListener>

    <property name="JSON_LOGGING" value="${JSON_LOGGING:-true}"/>
    <property name="STREAMING_LOG_LEVEL" value="${STREAMING_LOG_LEVEL:-INFO}"/>

    <if condition='property("JSON_LOGGING").equals("true")'>
        <then>
            <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
                <encoder class="net.logstash.logback.encoder.LoggingEventCompositeJsonEncoder">
                    <providers>
                        <timestamp/>
                        <logLevel/>
                        <threadName/>
                        <loggerName/>
                        <mdc/>
                        <message/>
                        <arguments/>
                        <stackTrace/>
                        <stackHash/>
                    </providers>
                </encoder>
            </appender>
        </then>
        <else>
            <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
                <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
                    <Pattern>%date{"yyyy-MM-dd HH:mm:ss,SSSZZZZ"} %-5level [%X{correlation_uuid}] [%-20.20thread] %logger{10} - %message%n%xException</Pattern>
                </encoder>
            </appender>
        </else>
    </if>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>

    <logger name="net.flipsports.gmx.game.argyll.racingroulette.webgateway.controller.RouletteController" level="INFO"/>
    <logger name="net.flipsports.gmx.game.argyll.racingroulette.webgateway.services.data.stream.FakeEventSource" level="INFO"/>
    <logger name="net.flipsports.gmx.game.argyll.racingroulette.webgateway.services.data.stream.KafkaEventSource" level="DEBUG"/>
    <logger name="net.flipsports.gmx.game.argyll.racingroulette.webgateway.services.event.actor.EventActor" level="INFO"/>
    <logger name="net.flipsports.gmx.game.argyll.racingroulette.webgateway.services.event.actor.state.EventStorage" level="DEBUG"/>
    <logger name="net.flipsports.gmx.game.argyll.racingroulette.webgateway.services.roulette.RouletteEngine" level="INFO"/>

    <logger name="net.flipsports.gmx.webapiclient.sbtech.betting.BettingAPIClientImpl" level="DEBUG"/>

    <logger name="net.flipsports" level="${STREAMING_LOG_LEVEL}"/>
    <logger name="akka.actor" level="${STREAMING_LOG_LEVEL}"/>
    <logger name="akka.stream" level="${STREAMING_LOG_LEVEL}"/>

    <logger name="akka.actor.TimerScheduler" level="INFO"/>

    <logger name="org.apache.kafka.clients" level="INFO"/>

</configuration>