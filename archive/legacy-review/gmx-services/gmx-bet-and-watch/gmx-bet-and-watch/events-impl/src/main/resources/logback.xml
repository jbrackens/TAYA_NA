<configuration> <!-- scan="true" scanPeriod="3 seconds">-->
    <statusListener class="ch.qos.logback.core.status.OnConsoleStatusListener"/>

    <contextListener class="ch.qos.logback.classic.jul.LevelChangePropagator">
        <resetJUL>true</resetJUL>
    </contextListener>

    <turboFilter class="net.flipsports.gmx.common.internal.java.core.exception.RejectExceptionLogFilter">
        <loggerName>event</loggerName>
        <exceptionClass>net.flipsports.gmx.common.internal.scala.core.exception.NotLoggedException</exceptionClass>
        <onMatch>DENY</onMatch>
    </turboFilter>

    <property name="JSON_LOGGING" value="${JSON_LOGGING:-true}"/>
    <if condition='property("JSON_LOGGING").equals("true")'>
        <then>
            <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
                <encoder class="net.logstash.logback.encoder.LoggingEventCompositeJsonEncoder">
                    <providers>
                        <timestamp/>
                        <logLevel/>
                        <threadName/>
                        <loggerName/>
                        <mdc/>
                        <message/>
                        <arguments/>
                        <stackTrace/>
                        <stackHash/>
                    </providers>
                </encoder>
            </appender>
        </then>
        <else>
            <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
                <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
                    <Pattern>%date{"yyyy-MM-dd HH:mm:ss,SSSZZZZ"} %-5level [%-20.20thread] %logger{10} - %message%n%xException</Pattern>
                </encoder>
            </appender>
        </else>
    </if>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>

    <logger name="net.flipsports.gmx" level="INFO" />

    <!-- User data -->
    <logger name="net.flipsports.gmx.widget.argyll.betandwatch.events.service.external.sbtech.DataAPIClientImpl" level="DEBUG" />
    <!-- ATR events -->
    <logger name="net.flipsports.gmx.widget.argyll.betandwatch.events.service.external.atr.SportMediastreamClientImpl" level="INFO" />
    <!-- RMG events -->
    <logger name="net.flipsports.gmx.widget.argyll.betandwatch.events.service.external.rmg.ContentScoreboardClientImpl" level="DEBUG" />

    <logger name="net.flipsports.gmx.widget.argyll.betandwatch.events.service.event.UnmappedEventsCheck" level="DEBUG" />

</configuration>