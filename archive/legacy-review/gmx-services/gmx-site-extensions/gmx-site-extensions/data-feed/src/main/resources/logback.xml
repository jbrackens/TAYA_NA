<configuration>
    <statusListener class="ch.qos.logback.core.status.OnConsoleStatusListener"/>

    <contextListener class="ch.qos.logback.classic.jul.LevelChangePropagator">
        <resetJUL>true</resetJUL>
    </contextListener>

    <property name="JSON_LOGGING" value="${JSON_LOGGING:-true}"/>
    <if condition='property("JSON_LOGGING").equals("true")'>
        <then>
            <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
                <encoder class="net.logstash.logback.encoder.LoggingEventCompositeJsonEncoder">
                    <providers>
                        <timestamp/>
                        <logLevel/>
                        <threadName/>
                        <loggerName/>
                        <mdc/>
                        <message/>
                        <pattern>
                          <pattern>
                            { "partner": "${GMX_PARTNER_TYPE}" }
                          </pattern>
                        </pattern>
                        <arguments/>
                        <stackTrace/>
                        <stackHash/>
                    </providers>
                </encoder>
            </appender>
        </then>
        <else>
            <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
                <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
                    <Pattern>%date{"yyyy-MM-dd HH:mm:ss,SSSZZZZ"} %-5level [%-20.20thread] %logger{10} [%X{executionId}] - %message%n%xException</Pattern>
                </encoder>
            </appender>
        </else>
    </if>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>

    <!-- Logging for Application -->
    <logger name="gmx.widget.siteextentions.datafeed.service.sportevents.flow.SportEventFlow" level="DEBUG"/>
    <logger name="gmx.widget.siteextentions.datafeed.service.persistence.StoreUpdateMessageService" level="DEBUG"/>
    <logger name="gmx.widget.siteextentions.datafeed.service.MessageRetriesJob" level="DEBUG"/>
<!--    <logger name="gmx.widget.siteextentions.datafeed.service.MessageRetriesScheduler" level="DEBUG"/>-->

<!--    <logger name="gmx.widget.siteextentions.datafeed.service.persistence" level="DEBUG"/>-->

    <!-- Ebean logging -->
    <!--<logger name="io.ebean.SQL" level="TRACE"/>-->
    <!--<logger name="io.ebean.TXN" level="TRACE"/>-->
    <!--<logger name="io.ebean.SUM" level="TRACE"/>-->

</configuration>