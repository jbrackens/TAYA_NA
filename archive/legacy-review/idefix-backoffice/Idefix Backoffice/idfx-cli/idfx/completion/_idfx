_launch_intercepts_caching_policy() {
	local mod_time
	mod_time=$(stat -f "%m" "$1")
	local curr_time
	curr_time=$(date +%s)
	local diff_time=$((curr_time - mod_time))
	if ((diff_time > 30)); then return 0; fi
	return 1
}

