_idfx() {
	local context state state_descr line
	typeset -A opt_args
	integer NORMARG

	# n
	# s "ROOT"

	local -a commands
	commands=(
		'home:Open the resource directory (~/.idfx)'
		'filter:Open the SQL filter query'
		'transformer:Open the transformer configuration'
		'config:Modify idfx configuration'
		'logs:Display logs'
		'launch:Launch everything locally'
		'env:(Re-)start gstech environment services'
		'migrate:Run gstech database migrations'
		'import:Import DB data locally'
		'i18n:Run gstech localizations importer scripts'
		'open:Open a running service in the browser'
	)
	_arguments -n \
		"1: :{_describe 'command' commands}" \
		'*: :->args' && r

	case $state in
	args)
		# s "ARGS"
		case ${words[2]} in
		logs)
			_arguments '*:Logs:->log_sources' && r
			case $state in
			log_sources)
				case ${words[3]} in
				k8s)
					curcontext="${curcontext}:k8s:"
					_arguments \
						'--tail=[Specify number of logs to show from end (default all)]:--tail' \
						'3:Environment:((prod:"Production environment" dev:"Development environment"))' \
						'*:Pods:_logs_k8s_pods' && r
					;;
				loki)
					curcontext="${curcontext}:loki:"
					_arguments \
						'(--range --since)--from=[Specify start time to load logs from (eg. yesterday)]:--from' \
						'(--range --since)--to=[Specify end time to load logs from (eg. today)]:--to' \
						'(--from --to --since)--range=[Specify "from - to" time (eg. yesterday - today)]:--range' \
						'(--from --to --range)--since=[Specify "since" time (eg. 5m)]:--since' \
						'*--match=[Filter logs to include plaintext argument]:arg' \
						'*--no-match=[Filter logs to exclude plaintext argument]:arg' \
						'*--regex=[Filter logs to include regex expression]:arg' \
						'*--no-regex=[Filter logs to exclude regex expression]:arg' \
						'3:Environment:((prod:"Production environment" dev:"Development environment"))' \
						'*:Container:_logs_loki_containers' && r
					;;
				local)
					_message 'Opens logs generated by local launches' && r
					;;
				*)
					_logs_log_sources
					;;
				esac
				;;
			esac
			;;
		env)
			# s "ENV"
			_arguments \
				'(-s -p)'-s"[restart sequentially]" \
				'(-s -p)'-p"[restart in parallel \[default\]]" \
				'(: *)'-b"[execute yarn bootstrap after restart]" \
				'(: *)'-m"[execute yarn migrate after restart]" \
				'*:services:_env_services' && r
			;;
		open)
			curcontext="${curcontext}:open:"
			_arguments '*:open_args:_open_running_hosts' && r
			;;
		launch)
			curcontext="${curcontext}:launch:"
			# s "LAUNCH"
			_arguments \
				'*+B-[B\[id\] Add brand to launch sequence]:Select Brand Id:_launch_brands' \
				'*+W-[W\[id\] Do not auto-start worker for brand]:Select Brand Id:_launch_brands' \
				'*+C-[C\[id\] Do not auto-start client for brand]:Select Brand Id:_launch_brands' \
				'*+I-[I\[PSP|GP\] Intercept provider calls to beta-server, and relay them to your local machine]:Select Provider:_launch_intercepts' \
				"--no-inject[Skip gstech debug file injection (DANGER)]" \
				'--nx-debug[Use Nx Debug Configuration for client apps]' \
				'--skip-scaffold[Skip activation and compensation on generated test accounts]' \
				'*: :->args' && r
			;;
		migrate)
			_migrate_dbs
			;;
		config)
			local -a config_commands
			config_commands=(
				'edit:Open idfx configuration file in editor'
				'reset:Wipe idfx configuration and exit (DANGER)'
			)
			_describe 'Modify idfx configuration' config_commands && r
			;;
		import)
			curcontext="${curcontext}:import:"
			# s "IMPORT"
			_arguments -s -C \
				+ tmpopt \
				'(- *)-T[Clean tmp directory and exit]' \
				+ '(cheopts)' \
				'(- *)-r[Purge the data directory completely (alias for -R0)]' \
				'(- *)-R-[R\[n\] Purge the data directory, leave n most recent cached runs]:number' \
				+ importopts \
				"(-T -r -R)*:: :_import_cmd_arguments" && r
			;;
		esac
		;;
	esac
}

_import_cmd_arguments() {
	# s "IMPORT_CMD_ARGUMENTS"
	local alternatives
	alternatives=('opts: :_import_opts')
	local found_eoc_opt
	local mode_opt="parallel"
	for word in "${words[@]}"; do
		if [[ "${word}" =~ '-([Tr]|R[0-9]+)$' ]]; then
			found_eoc_opt=1
			break
		fi
	done
	for word in "${words[@]}"; do
		if [[ "${word}" =~ '-[^[:space:]]*s' ]]; then
			mode_opt="sequential"
			break
		fi
	done
	if [[ -z "${found_eoc_opt}" ]]; then
		if [[ "${mode_opt}" == "parallel" ]]; then
			alternatives+=('dbs: :_par_importer_dbs')
		else
			if [[ "${words[*]}" =~ ' ([grc]s) ' ]]; then
				alternatives+=('tbls: :_seq_importer_tbls')
			else
				alternatives+=('dbs: :_seq_importer_dbs_specs')
			fi
		fi
	fi

	_alternative "${alternatives[@]}" && r
}

_import_opts() {
	# s "IMPORT_CMD_ARGUMENTS__IMPORT_OPTS"
	_arguments -s \
		'(tmpopt cheopts -c -C)-c[Use cached file from most recent run (alias for -C1)]' \
		'(tmpopt cheopts -c -C)-C-[C\[n\] Use cached file from n runs back]:number' \
		'(tmpopt cheopts)-P-[P\[n\] For partitioned tables, import n most recent partitions]:number' \
		'(tmpopt cheopts -b -j)-b[Import data using BIN format where possible (default)]' \
		'(tmpopt cheopts -b -j)-j[Import data using JSON format only (slower, more readable)]' \
		'(tmpopt cheopts)-m[Run yarn migrate on gstech after import]' \
		'(tmpopt cheopts)-e[Reset PG service before performing import]' \
		'(tmpopt cheopts -p -s)-p[Use multi-threaded approach (default when importing whole databases)]' \
		'(tmpopt cheopts -p -s)-s[Use sequential approach (default when importing select tables)]' \
		+ tmpopt \
		'(- *)-T[Clean tmp directory and exit]' \
		+ '(cheopts)' \
		'(- *)-r[Purge the data directory completely (alias for -R0)]' \
		'(- *)-R-[R\[n\] Purge the data directory, leave n most recent cached runs]:number' && r
}

_par_importer_dbs() {
	# s "IMPORT_CMD_ARGUMENTS__PAR_IMPORTER_DBS"
	local dbs_list=("gs:Gstech database" "rs:Rewardserver Database" "cs:Campaignserver Database")
	local dedup_dbs=()
	for db in "${dbs_list[@]}"; do
		if [[ ! "${words[*]}" =~ " ${db%%:*} " ]]; then
			dedup_dbs+=("${db}")
		fi
	done
	_describe '' dedup_dbs && r
}

_seq_importer_dbs_specs() {
	# s "IMPORT_CMD_ARGUMENTS__SEQ_IMPORTER_DBS_SPECS"
	local commands=(
		"gs:Gstech database"
		"rs:Rewardserver Database"
		"cs:Campaignserver Database"
		"gsg:Gstech Game Data"
		"gsr:Gstech Risk Data"
		"gsp:Gstech Player Data"
		"gspf:Gstech Player Frauds Data"
		"gssome:Minimal Gstech Data"
		"gsmore:More Gstech Data"
		"gsmost:Most Gstech Data"
		"gsmax:Mostest Gstech Data"
		"csc:Campaignserver Content Data"
		"rsg:Rewardserver Game Data"
	)
	for cmd in "${commands[@]}"; do
		local found=0
		if [[ "${words[*]}" =~ " ${cmd%%:*} " ]]; then
			found=1
			break
		fi
	done
	if [[ "${found}" == 0 ]]; then
		_describe '' commands && r
	fi
}

_seq_importer_tbls() {
	# s "IMPORT_CMD_ARGUMENTS__SEQ_IMPORTER_TBLS"
	local db
	case "${words[*]}" in
	*" gs "*) db="gs" ;;
	*" rs "*) db="rs" ;;
	*" cs "*) db="cs" ;;
	esac
	if ! _retrieve_cache "DB_REMOTE_TABLES_$db"; then
		local -a tables
		while IFS= read -r line; do
			tables+=("$line")
		done < <(idfx import list-remote-tables "$db")
		if [[ "${#tables[@]}" -gt 0 ]]; then
			_store_cache "DB_REMOTE_TABLES_$db" tables
		fi
	fi
	local dedup_tables=()
	for table in "${tables[@]}"; do
		local found=0
		for word in "${words[@]}"; do
			if [[ "$word" == "$table" ]]; then
				found=1
				break
			fi
		done
		if ((found == 0)); then dedup_tables+=("$table"); fi
	done
	_describe '' dedup_tables && r
}

_migrate_dbs() {
	# s "MIGRATE"
	local -a all_migrate_commands
	local -a avail_migrate_commands
	all_migrate_commands=(
		'backend:Run gstech-backend migrations'
		'reward:Run rewardserver migrations'
		'campaign:Run campaignserver migrations'
		'lotto:Run lottoserver migrations'
		'affmore:Run affmore migrations'
	)
	for cmd in "${all_migrate_commands[@]}"; do
		local found=0
		for sel in "${words[@]:2}"; do
			if [[ $sel != "${words[$CURRENT]}" && "$cmd" =~ "$sel:" ]]; then
				found=1
				break
			fi
		done
		if ((found == 0)); then
			avail_migrate_commands+=("$cmd")
		fi
	done
	_describe 'Run all or select migrations' avail_migrate_commands && r
}

_launch_intercepts() {
	local -a I
	local -a intercepts
	if ! _retrieve_cache 'INTERCEPTS'; then
		while IFS= read -r line; do
			intercepts+=("$line")
		done < <(idfx dt tl)
		if [[ "${#intercepts[@]}" -gt 0 ]]; then
			_store_cache 'INTERCEPTS' intercepts
		fi
	fi
	for word in "${words[@]:0:-1}"; do
		if [[ "$word" =~ '\+I[a-z]+' ]]; then
			I+=("${word:2}")
		fi
	done
	local dedup_intercepts=()
	for intr in "${intercepts[@]}"; do
		local found=0
		for i in "${I[@]}"; do
			if [[ "$intr" =~ "$i" ]]; then
				found=1
				break
			fi
		done
		if ((found == 0)); then
			dedup_intercepts+=("$intr")
		fi
	done
	_describe 'intercepts' dedup_intercepts && r
}

_launch_brands() {
	local desc
	local -a brand_commands brand_arg_opts W C B
	brand_arg_opts=()
	W=()
	C=()
	B=()
	brand_commands=(
		'ld:Luckydino'
		'cj:CasinoJefe'
		'jw:JustWOW'
		'os:OlaSpill'
		'hs:HipSpin'
		'fs:FreshSpins'
		'vb:VieBet'
	)

	for word in "${words[@]}"; do
		if [[ "$word" =~ '(\+[BWC])([a-z]{2})' ]]; then
			local option="${word[2]}"
			local id="${word:2}"
			local mapped_id=""
			case "$id" in
			sn | fs) mapped_id="fs" ;;
			kk | jw) mapped_id="jw" ;;
			fk | hs) mapped_id="hd" ;;
			vb) mapped_id="vb" ;;
			ld) mapped_id="ld" ;;
			cj) mapped_id="cj" ;;
			os) mapped_id="os" ;;
			esac
			case "$option" in
			W) W+=("$mapped_id") ;;
			C) C+=("$mapped_id") ;;
			B) B+=("$mapped_id") ;;
			esac
		fi
	done

	# o "W: ${W[*]}"
	# o "C: ${C[*]}"
	# o "B: ${B[*]}"
	# o "${words[-1]}"

	case ${words[-1]} in
	"+W"* | "+C"*)
		local dedup_check=()
		if [[ "${words[-1]}" =~ "\+W" ]]; then
			desc="Do not auto-start worker for brand"
			dedup_check=("${W[@]}")
		else
			desc="Do not auto-start client for brand"
			dedup_check=("${C[@]}")
		fi

		if [ ${#B[@]} -eq 0 ]; then B=("ld"); fi
		for b in "${B[@]}"; do
			for bc in "${brand_commands[@]}"; do
				if [[ "$bc" =~ "$b:" ]]; then
					if [[ ! " ${dedup_check[*]} " =~ " $b " ]]; then
						brand_arg_opts+=("$bc")
					fi
				fi
			done
		done
		;;
	"+B"*)
		desc="Add brand to launch sequence"
		if [ ${#B[@]} -eq 0 ]; then
			brand_arg_opts=("${brand_commands[@]}")
		else
			for bc in "${brand_commands[@]}"; do
				local found=0
				for b in "${B[@]}"; do
					if [[ "$bc" =~ "$b:" ]]; then
						found=1
						break
					fi
				done
				if [ $found -eq 0 ]; then
					brand_arg_opts+=("$bc")
				fi
			done
		fi
		;;
	esac

	_describe "$desc" brand_arg_opts && r
}

_env_services() {
	# s "ENV_SERVICES"
	local -a services
	if [[ ${words[*]} =~ "pg" ]]; then
		services=(
			"redis:Redis service"
			"minio:Minio service"
			"kafka:Kafka service"
		)
	elif [[ ${words[*]} =~ "pgaff" ]] || [[ ${words[*]} =~ "pgidf" ]]; then
		services=(
			"pgaff:Affmore Postgres service"
			"pgidf:Idefix (gstech) Postgres service"
			"redis:Redis service"
			"minio:Minio service"
			"kafka:Kafka service"
		)
	else
		services=(
			"pg:All Postgres services"
			"pgaff:Affmore Postgres service"
			"pgidf:Idefix (gstech) Postgres service"
			"redis:Redis service"
			"minio:Minio service"
			"kafka:Kafka service"
		)
	fi
	local dedup_services=()
	for service in "${services[@]}"; do
		local found=0
		for word in "${words[@]}"; do
			if [[ "$service" == "$word":* ]]; then
				found=1
				break
			fi
		done
		if ((found == 0)); then
			dedup_services+=("$service")
		fi
	done
	if ((${#dedup_services[@]} == 0)); then
		_message "" && r
	fi
	_describe 'services' dedup_services && r
}

_logs_log_sources() {
	local -a sources
	sources=(
		'local:Open local logs [default]'
		'loki:Query historical logs from loki (grafana)'
	)
	if [[ -n "$AWS_VAULT" ]]; then
		sources+=('k8s:Tail live logs from k8s clusters')
	fi
	_describe 'Select log source' sources && r
}

_logs_loki_containers() {
	# s "LOKI_CONTAINERS"
	local env="${words[4]}"
	if ! _retrieve_cache "LOKI_CONTAINERS_$env"; then
		local -a containers
		while IFS= read -r line; do
			containers+=("$line")
		done < <(logcli --quiet --addr="https://loki.$env.eeg.viegg.net" labels container 2>/dev/null)
		if [[ "${#containers[@]}" -gt 0 ]]; then
			_store_cache "LOKI_CONTAINERS_$env" containers
		fi
	fi
	local dedup_containers=()
	for container in "${containers[@]}"; do
		if [[ "$container" == "$env"-* ]]; then
			local found=0
			for word in "${words[@]}"; do
				if [[ "$word" == "$container" ]]; then
					found=1
					break
				fi
			done
			if ((found == 0)); then
				dedup_containers+=("$container")
			fi
		fi
	done
	_describe 'container' dedup_containers && r
}

_logs_k8s_pods() {
	# s "K8S_PODS"
	local curr_env
	local wanted_env
	curr_env="$(kubectl config view --minify --output 'jsonpath={..namespace}')"
	if [[ "${words[4]}" = "dev" || "${words[4]}" = "prod" ]]; then
		wanted_env="${words[4]}"
	else
		wanted_env="$curr_env"
	fi
	if ! _retrieve_cache "K8s_PODS_$wanted_env"; then
		local -a pods
		if [[ "$curr_env" != "$wanted_env" ]]; then
			kubectl config use-context "luckydino-$wanted_env-cluster" >/dev/null
			kubectl config set-context --current --namespace="$wanted_env" >/dev/null
		fi
		while IFS= read -r line; do
			pods+=("$line")
		done < <(kubectl get deployments.apps --no-headers=true 2>/dev/null | awk '{print $1}')
		if [[ "${#pods[@]}" -gt 0 ]]; then
			_store_cache "K8s_PODS_$wanted_env" pods
		fi
	fi
	local dedup_pods=()
	for pod in "${pods[@]}"; do
		if [[ "$pod" == "$wanted_env"-* ]]; then
			local found=0
			for word in "${words[@]}"; do
				if [[ "$pod" == "$wanted_env-$word" ]]; then
					found=1
					break
				fi
			done
			if ((found == 0)); then
				dedup_pods+=("${pod#*"$wanted_env"-}")
			fi
		fi
	done
	_describe 'Tail pods' dedup_pods && r
}

_open_running_hosts() {
	if ! _retrieve_cache OPEN_HOSTS; then
		local -a hosts=()
		declare -A APP_DESCS=(
			["ngrok"]="Tunnel service Web-UI"
			["mailpit"]="Mock email inbox Web-UI"
			["backoffice"]="Idefix backoffice UI"
			["campa"]="Campaignserver Web-UI (Campa)"
			["luckydino"]="Luckydino brand client app"
			["jefe"]="CasinoJefe brand client app"
			["justwow"]="JustWOW brand client app"
			["kalevala"]="JustWOW brand client app"
			["olaspill"]="Olaspill brand client app"
			["hipspin"]="HipSpin brand client app"
			["fiksu"]="HipSpin brand client app"
			["freshspins"]="FreshSpins brand client app"
			["sportnation"]="FreshSpins brand client app"
			["vie"]="Vie.bet brand client app"
		)
		while IFS= read -r line; do
			local serv_name="${line%%:*}"
			local serv_port="${line##*:}"
			hosts+=("$serv_name:${APP_DESCS[$serv_name]} (localhost:$serv_port)")
		done < <(idfx running | tr ' ' '\n')
		_store_cache OPEN_HOSTS hosts
	fi

	local dedup_hosts=()
	for host in "${hosts[@]}"; do
		local found=0
		for word in "${words[@]}"; do
			if [[ "$host" == "$word":* ]]; then
				found=1
				break
			fi
		done
		if ((found == 0)); then
			dedup_hosts+=("$host")
		fi
	done
	if ((${#dedup_hosts[@]} == 0)); then
		_message "No other running services found"
	fi
	_describe 'Open service in browser' dedup_hosts && r
	_message ""
}

