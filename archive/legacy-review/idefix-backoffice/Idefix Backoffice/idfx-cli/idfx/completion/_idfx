dfle="/Users/seanbugeja/Code/eeg/idefix-pg-importer/idfx/completion/_idfx.state"

s() {
	cat <<-EOM >>"$dfle"
		-> $1
		curcontext=$curcontext
		state=$state
		line=$line
		service=$service
		words=${words[*]}
		context=$context
		CURRENT=$CURRENT
		NORMARG=$NORMARG
		opt_args=${opt_args[*]}
		----------------------------------------
	EOM
}

o() {
	printf ">>> %s <<<\\n" "$*" >>"$dfle"
}

r() {
	# printf "<- %s\\n" "${*:-"$state"}" >>"$dfle"
	return 0
}

n() {
	printf "\\n\\n" >>"$dfle"
}

