{
  "name": "idefix-brand-client",
  "version": "0.0.1",
  "license": "MIT",
  "scripts": {
    "start": "nx serve $SITE_NAME --port $PORT --prod",
    "build": "nx build",
    "test": "nx test",
    "dev:brand": "API=https://beta.justwow.com/ PORT=3000 nx serve brand --port 3000",
    "build:brand": "nx build brand",
    "start:brand": "API=https://beta.justwow.com/ PORT=3000 nx serve brand --port 3000 --prod",
    "start-local:brand": "PORT=3000 API=http://localhost:3026/ nx serve brand --port 3000",
    "analyze:brand": "ANALYZE=true nx build brand --skip-nx-cache",
    "build:all:parallel": "nx run-many --all --target=build --parallel",
    "build:all": "nx run-many --all --target=build",
    "build:all:affected": "nx affected:build --target build --parallel",
    "docker:test": "docker-compose -f docker-compose.test.yml down && docker-compose -f docker-compose.test.yml up --build --exit-code-from luckydino-client.test && docker-compose -f docker-compose.test.yml down",
    "docker:start": "docker-compose down && docker-compose up --build -d",
    "prettify": "prettier --write 'packages/**/*.{ts,tsx}'"
  },
  "private": true,
