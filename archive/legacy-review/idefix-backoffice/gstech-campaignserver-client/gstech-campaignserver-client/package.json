{
  "name": "gstech-campaignserver-client",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@react-oauth/google": "^0.12.1",
    "@reduxjs/toolkit": "^1.9.1",
    "@types/js-cookie": "^3.0.6",
    "@types/jwt-decode": "^3.1.0",
    "@uiw/react-markdown-preview": "^3.1.4",
    "axios": "^0.26.1",
    "blurhash": "^1.1.5",
    "classnames": "^2.2.6",
    "date-fns": "^2.28.0",
    "date-fns-tz": "^1.3.7",
    "formik": "^2.2.9",
    "immutability-helper": "^3.1.1",
    "js-cookie": "^3.0.5",
    "jwt-decode": "^4.0.0",
    "lodash": "^4.17.20",
    "react": "^16.14.0",
    "react-cool-inview": "^2.0.9",
    "react-csv": "^2.2.2",
    "react-datepicker": "^4.8.0",
    "react-dnd": "^14.0.5",
    "react-dnd-html5-backend": "^14.1.0",
    "react-dom": "^16.14.0",
    "react-dropzone": "^12.0.4",
    "react-mde": "^11.4.0",
    "react-redux": "^8.0.5",
    "react-router-dom": "^5.3.0",
    "react-scripts": "4.0.3",
    "react-select": "^5.7.0",
    "react-table": "^7.7.0",
    "react-toastify": "^8.2.0",
    "react-visibility-sensor": "^5.1.1",
    "react-window": "^1.8.7",
    "serve": "14.1.2",
    "styled-components": "^5.3.3",
    "styled-reset": "^4.4.4",
    "typescript": "~4.9.4",
    "yup": "^0.32.11"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx,json,css,scss,md}": [
      "prettier --write",
      "git add"
    ]
  },
  "scripts": {
    "start": "react-scripts --openssl-legacy-provider start",
    "start:local": "CAMPAIGNSERVER_URL=http://localhost:3013 react-scripts --openssl-legacy-provider start",
    "build": "react-scripts --openssl-legacy-provider build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "serve": "serve -s build",
    "docker:test": "docker-compose -f docker-compose.test.yml down && docker-compose -f docker-compose.test.yml up --build --exit-code-from gstech-campaignserver-client.test",
    "docker:start": "docker-compose down && docker-compose up --build -d"
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "scarfSettings": {
    "enabled": false
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^5.16.3",
    "@testing-library/react": "^12.1.4",
    "@testing-library/user-event": "^14.3.0",
    "@types/classnames": "^2.3.1",
    "@types/jest": "^27.4.1",
    "@types/lodash": "^4.14.191",
    "@types/node": "^17.0.23",
    "@types/react": "^17.0.43",
    "@types/react-csv": "^1.1.2",
    "@types/react-datepicker": "^4.8.0",
    "@types/react-dom": "^17.0.14",
    "@types/react-redux": "^7.1.23",
    "@types/react-router-dom": "^5.3.3",
    "@types/react-table": "^7.7.10",
    "@types/react-window": "^1.8.5",
    "@types/redux-mock-store": "^1.0.3",
    "@types/styled-components": "^5.1.24",
    "@types/uuid": "^8.3.4",
    "@types/webpack-env": "^1.18.0",
    "@types/yup": "^0.29.13",
    "@typescript-eslint/eslint-plugin": "^4.33.0",
    "@typescript-eslint/parser": "^4.33.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-config-react": "^1.1.7",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "husky": "^4.2.5",
    "lint-staged": "^12.3.7",
    "prettier": "^2.8.1",
    "redux-mock-store": "^1.5.4"
  }
}
