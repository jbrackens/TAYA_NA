{
  "name": "gstech",
  "repository": "git@github.com:flipadmin/gstech.git",
  "private": true,
  "version": "2.7.1",
  "scripts": {
    "bootstrap": "yarn workspace gstech-core bootstrap && lerna run bootstrap --ignore=gstech-core",
    "pretty": "lerna run pretty",
    "start": "lerna run start",
    "serve": "lerna run serve",
    "test": "lerna run test",
    "lint": "lerna run lint",
    "flow": "lerna run flow",
    "flow:install": "flow-typed -l packages/gstech-core/flow-typed/ install",
    "flow:stub": "flow-typed -l packages/gstech-core/flow-typed/ create-stub",
    "migrate": "lerna run migrate",
    "docker:start": "lerna run docker:start",
    "docker:test": "lerna run docker:test",
    "env": "yarn run-s env:network env:kafka env:minio env:pg-affmore env:pg-idefix env:redis",
    "env:wait": "yarn env:network && run-p env:kafka env:minio 'env:pg-affmore -- --wait' 'env:pg-idefix -- --wait' env:redis",
    "env:parallel": "yarn env:network && run-p env:kafka env:minio env:pg-affmore env:pg-idefix env:redis",
    "env:network": "docker network create gstech || true",
    "env:kafka": "docker compose -p kafka -f environment/kafka.docker-compose.yml down && docker compose -p kafka -f environment/kafka.docker-compose.yml up --build -d",
    "env:minio": "docker compose -p minio -f environment/minio.docker-compose.yml down && docker compose -p minio -f environment/minio.docker-compose.yml up --build -d",
    "env:pg-affmore": "docker compose -p pg-affmore -f environment/pg-affmore.docker-compose.yml down && docker compose -p pg-affmore -f environment/pg-affmore.docker-compose.yml up --build -d",
    "env:pg-idefix": "docker compose -p pg-idefix -f environment/pg-idefix.docker-compose.yml down && docker compose -p pg-idefix -f environment/pg-idefix.docker-compose.yml up --build -d",
    "env:redis": "docker compose -p redis -f environment/redis.docker-compose.yml down && docker compose -p redis -f environment/redis.docker-compose.yml up --build -d",
    "config:keygen": "node -r 'flow-remove-types/register' packages/gstech-core/modules/config-tool.js keygen",
    "config:encrypt": "node -r 'flow-remove-types/register' packages/gstech-core/modules/config-tool.js encrypt",
    "todos": "find . -type d \\( -path ./node_modules -o \\) -prune -o -name '*.js' -exec cat {} \\; | grep 'TODO' --color=auto",
    "current-version": "node -e \"console.log('Current version is ' + require('./packages/' + (process.argv.length > 1 ? process.argv[1] : '..') + '/package.json').version);\""
  },
  "workspaces": [
    "packages/*"
  ],
