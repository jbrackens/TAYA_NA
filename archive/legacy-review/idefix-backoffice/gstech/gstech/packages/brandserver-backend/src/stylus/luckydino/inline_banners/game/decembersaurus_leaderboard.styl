#banner_game_decembersaurus_leaderboard
  bannerStyles()
  position relative
  cdn_image '/banners/sidebar/ds_leaderboard.png' 266px 200px
  width 266px
  height 200px
  font-family 'Ubuntu',Helvetica,Arial,sans-serif
  font-size 12px
  text-shadow 1px 1px rgba(0,0,0,0.75)
  color #fff
  .selected
    color #fecb2e
  &__leaderboard
    width 200px
    margin 72px 33px 0 33px
    td.last-column
      text-align right
    .divider
      height 2px
      background-linear-gradient(top, #333333, 0%, #727272, 100%)
  .button-holder
    width 100%
    margin-top 5px
    text-align center
    position absolute
    bottom 0
    .button
      font-size 15px
      height 25px
      padding-left 12px
      padding-right 12px
