.floatlabel
  height 46px
  margin 12px auto
  display block
  position relative
  background-color #ffffff

.floatlabel label
  top 12px
  left 10px
  font-size 13px !important
  position absolute
  z-index 3
  transition all .05s linear

.floatlabel input
  background none
  padding 12px 10px 0 10px
  position absolute
  top 0
  left 0
  right 0
  bottom 0
  width 100%
  height 100%
  z-index 2

.floatlabel.focused label, .floatlabel.populated label
  top 0
  font-size 12px !important
