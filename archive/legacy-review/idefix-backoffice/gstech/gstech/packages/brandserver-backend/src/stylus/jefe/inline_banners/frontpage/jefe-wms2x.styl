#banner_frontpage_jefe-wms2x
  height 345px
  position relative
  .background
    position absolute
    left 50%
    margin-left -960px
    width 1920px
    height 345px
    cdn-background-image: '/banners/loggedin_big/2xbounty/bg.jpg'
    .viewport
      height 345px
      .item1
        cdn-background-image: '/banners/loggedin_big/2xbounty/kronos.png'
        width 380px
        height 338px
        position absolute
        bottom 0
        left 15%
        @media only screen and (max-width:1099px)
          left 440px
        @media only screen and (max-width:865px)
          display none
      .item2
        cdn-background-image: '/banners/loggedin_big/2xbounty/alfredo.png'
        width 384px
        height 345px
        position absolute
        bottom 0
        right 15%
        @media only screen and (max-width:1099px)
          right 440px
        @media only screen and (max-width:865px)
          display none

  .image
    cdn-background-image: '/banners/loggedin_big/2xbounty/logo.png'
    width 374px
    height 155px
    position absolute
    top 20px
    right 50%
    margin-right -187px

  .campaign
    position absolute
    margin 0 auto
    padding 100px 8px 40px 8px
    max-width 520px
    .button-holder
      width 100%
      text-align center
      position absolute
      bottom 40px
    .button
      background-color #a2d129
    h1
      color #3f3f3f
      font-size 49px
      line-height 50px
      font-weight 700
      text-transform uppercase
      font-family 'Titillium Web', sans-serif
      @media only screen and (max-width:767px)
        font-size 29px
        line-height 30px
    h3
      margin-top 110px
      font-size 18px
      color #3f3f3f
      text-transform uppercase
