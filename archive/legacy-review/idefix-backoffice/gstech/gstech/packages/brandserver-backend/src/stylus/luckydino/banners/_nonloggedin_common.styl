/*
Stylus variables are information about icon's compiled state, stored under its original file name

.icon-home {
  width: $icon_home_width;
}

The large array-like variables contain all information about a single icon
$icon_home = x y offset_x offset_y width height total_width total_height image_path;

At the bottom of this section, we provide information about the spritesheet itself
$spritesheet = width height image $spritesheet_sprites;
*/
$nonloggedin_common_felix_name = 'nonloggedin_common_felix';
$nonloggedin_common_felix_x = 0px;
$nonloggedin_common_felix_y = 0px;
$nonloggedin_common_felix_offset_x = 0px;
$nonloggedin_common_felix_offset_y = 0px;
$nonloggedin_common_felix_width = 369px;
$nonloggedin_common_felix_height = 295px;
$nonloggedin_common_felix_total_width = 566px;
$nonloggedin_common_felix_total_height = 295px;
$nonloggedin_common_felix_image = 'nonloggedin_common_b.png';
$nonloggedin_common_felix = 0px 0px 0px 0px 369px 295px 566px 295px 'nonloggedin_common_b.png' 'nonloggedin_common_felix';
$nonloggedin_common_lights_name = 'nonloggedin_common_lights';
$nonloggedin_common_lights_x = 373px;
$nonloggedin_common_lights_y = 0px;
$nonloggedin_common_lights_offset_x = -373px;
$nonloggedin_common_lights_offset_y = 0px;
$nonloggedin_common_lights_width = 193px;
$nonloggedin_common_lights_height = 258px;
$nonloggedin_common_lights_total_width = 566px;
$nonloggedin_common_lights_total_height = 295px;
$nonloggedin_common_lights_image = 'nonloggedin_common_b.png';
$nonloggedin_common_lights = 373px 0px -373px 0px 193px 258px 566px 295px 'nonloggedin_common_b.png' 'nonloggedin_common_lights';
$spritesheet_width = 566px;
$spritesheet_height = 295px;
$spritesheet_image = 'nonloggedin_common_b.png';
$spritesheet_sprites = $nonloggedin_common_felix $nonloggedin_common_lights;
$spritesheet = 566px 295px 'nonloggedin_common_b.png' $spritesheet_sprites;

/*
The provided mixins are intended to be used with the array-like variables

.icon-home {
  spriteWidth($icon_home)
}

.icon-email {
  sprite($icon_email)
}

Example usage in HTML:

`display: block` sprite:
<div class="icon-home"></div>

To change `display` (e.g. `display: inline-block;`), we suggest using a common CSS class:

// CSS
.icon {
  display: inline-block;
}

// HTML
<i class="icon icon-home"></i>
*/
spriteWidth($sprite) {
  width: $sprite[4];
}

spriteHeight($sprite) {
  height: $sprite[5];
}

spritePosition($sprite) {
  background-position: $sprite[2] $sprite[3];
}

spriteImage($sprite) {
  background-image: url($sprite[8]);
}

sprite($sprite) {
  spriteImage($sprite)
  spritePosition($sprite)
  spriteWidth($sprite)
  spriteHeight($sprite)
}

/*
The `sprites` mixin generates identical output to the CSS template
  but can be overridden inside of Stylus

This must be run when you have at least 2 sprites.
  If run with a single sprite, then there will be reference errors.

sprites($spritesheet_sprites);
*/
sprites($sprites) {
  for $sprite in $sprites {
    $sprite_name = $sprite[9];
    .{$sprite_name} {
      sprite($sprite);
    }
  }
}
