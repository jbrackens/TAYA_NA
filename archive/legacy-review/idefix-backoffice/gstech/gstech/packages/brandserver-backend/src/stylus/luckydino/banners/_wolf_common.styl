/*
Stylus variables are information about icon's compiled state, stored under its original file name

.icon-home {
  width: $icon_home_width;
}

The large array-like variables contain all information about a single icon
$icon_home = x y offset_x offset_y width height total_width total_height image_path;

At the bottom of this section, we provide information about the spritesheet itself
$spritesheet = width height image $spritesheet_sprites;
*/
$wolf_common_logo_name = 'wolf_common_logo';
$wolf_common_logo_x = 0px;
$wolf_common_logo_y = 304px;
$wolf_common_logo_offset_x = 0px;
$wolf_common_logo_offset_y = -304px;
$wolf_common_logo_width = 430px;
$wolf_common_logo_height = 138px;
$wolf_common_logo_total_width = 478px;
$wolf_common_logo_total_height = 442px;
$wolf_common_logo_image = 'wolf_common_b.png';
$wolf_common_logo = 0px 304px 0px -304px 430px 138px 478px 442px 'wolf_common_b.png' 'wolf_common_logo';
$wolf_common_others_name = 'wolf_common_others';
$wolf_common_others_x = 242px;
$wolf_common_others_y = 0px;
$wolf_common_others_offset_x = -242px;
$wolf_common_others_offset_y = 0px;
$wolf_common_others_width = 236px;
$wolf_common_others_height = 256px;
$wolf_common_others_total_width = 478px;
$wolf_common_others_total_height = 442px;
$wolf_common_others_image = 'wolf_common_b.png';
$wolf_common_others = 242px 0px -242px 0px 236px 256px 478px 442px 'wolf_common_b.png' 'wolf_common_others';
$wolf_common_wolf_name = 'wolf_common_wolf';
$wolf_common_wolf_x = 0px;
$wolf_common_wolf_y = 0px;
$wolf_common_wolf_offset_x = 0px;
$wolf_common_wolf_offset_y = 0px;
$wolf_common_wolf_width = 238px;
$wolf_common_wolf_height = 300px;
$wolf_common_wolf_total_width = 478px;
