/*
Stylus variables are information about icon's compiled state, stored under its original file name

.icon-home {
  width: $icon_home_width;
}

The large array-like variables contain all information about a single icon
$icon_home = x y offset_x offset_y width height total_width total_height image_path;

At the bottom of this section, we provide information about the spritesheet itself
$spritesheet = width height image $spritesheet_sprites;
*/
$creaturefromtheblacklagoon_common_mobile_character_name = 'creaturefromtheblacklagoon_common_mobile_character';
$creaturefromtheblacklagoon_common_mobile_character_x = 0px;
$creaturefromtheblacklagoon_common_mobile_character_y = 0px;
$creaturefromtheblacklagoon_common_mobile_character_offset_x = 0px;
$creaturefromtheblacklagoon_common_mobile_character_offset_y = 0px;
$creaturefromtheblacklagoon_common_mobile_character_width = 287px;
$creaturefromtheblacklagoon_common_mobile_character_height = 278px;
$creaturefromtheblacklagoon_common_mobile_character_total_width = 590px;
$creaturefromtheblacklagoon_common_mobile_character_total_height = 278px;
$creaturefromtheblacklagoon_common_mobile_character_image = 'creaturefromtheblacklagoon_common_mobile_b.png';
$creaturefromtheblacklagoon_common_mobile_character = 0px 0px 0px 0px 287px 278px 590px 278px 'creaturefromtheblacklagoon_common_mobile_b.png' 'creaturefromtheblacklagoon_common_mobile_character';
$creaturefromtheblacklagoon_common_mobile_logo_name = 'creaturefromtheblacklagoon_common_mobile_logo';
$creaturefromtheblacklagoon_common_mobile_logo_x = 291px;
$creaturefromtheblacklagoon_common_mobile_logo_y = 0px;
$creaturefromtheblacklagoon_common_mobile_logo_offset_x = -291px;
$creaturefromtheblacklagoon_common_mobile_logo_offset_y = 0px;
$creaturefromtheblacklagoon_common_mobile_logo_width = 299px;
$creaturefromtheblacklagoon_common_mobile_logo_height = 127px;
$creaturefromtheblacklagoon_common_mobile_logo_total_width = 590px;
$creaturefromtheblacklagoon_common_mobile_logo_total_height = 278px;
$creaturefromtheblacklagoon_common_mobile_logo_image = 'creaturefromtheblacklagoon_common_mobile_b.png';
$creaturefromtheblacklagoon_common_mobile_logo = 291px 0px -291px 0px 299px 127px 590px 278px 'creaturefromtheblacklagoon_common_mobile_b.png' 'creaturefromtheblacklagoon_common_mobile_logo';
$spritesheet_width = 590px;
$spritesheet_height = 278px;
$spritesheet_image = 'creaturefromtheblacklagoon_common_mobile_b.png';
$spritesheet_sprites = $creaturefromtheblacklagoon_common_mobile_character $creaturefromtheblacklagoon_common_mobile_logo;
$spritesheet = 590px 278px 'creaturefromtheblacklagoon_common_mobile_b.png' $spritesheet_sprites;

/*
The provided mixins are intended to be used with the array-like variables

.icon-home {
  spriteWidth($icon_home)
}

.icon-email {
  sprite($icon_email)
}

Example usage in HTML:

`display: block` sprite:
<div class="icon-home"></div>

To change `display` (e.g. `display: inline-block;`), we suggest using a common CSS class:

// CSS
.icon {
  display: inline-block;
}

// HTML
<i class="icon icon-home"></i>
*/
spriteWidth($sprite) {
  width: $sprite[4];
}

spriteHeight($sprite) {
  height: $sprite[5];
}

spritePosition($sprite) {
  background-position: $sprite[2] $sprite[3];
}

spriteImage($sprite) {
  background-image: url($sprite[8]);
}

sprite($sprite) {
  spriteImage($sprite)
  spritePosition($sprite)
  spriteWidth($sprite)
  spriteHeight($sprite)
}

/*
The `sprites` mixin generates identical output to the CSS template
  but can be overridden inside of Stylus

This must be run when you have at least 2 sprites.
  If run with a single sprite, then there will be reference errors.

sprites($spritesheet_sprites);
*/
sprites($sprites) {
  for $sprite in $sprites {
    $sprite_name = $sprite[9];
    .{$sprite_name} {
      sprite($sprite);
    }
  }
}
