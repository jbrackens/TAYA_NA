/*
Stylus variables are information about icon's compiled state, stored under its original file name

.icon-home {
  width: $icon_home_width;
}

The large array-like variables contain all information about a single icon
$icon_home = x y offset_x offset_y width height total_width total_height image_path;

At the bottom of this section, we provide information about the spritesheet itself
$spritesheet = width height image $spritesheet_sprites;
*/
$dazzleme_common_felix_name = 'dazzleme_common_felix';
$dazzleme_common_felix_x = 0px;
$dazzleme_common_felix_y = 0px;
$dazzleme_common_felix_offset_x = 0px;
$dazzleme_common_felix_offset_y = 0px;
$dazzleme_common_felix_width = 286px;
$dazzleme_common_felix_height = 284px;
$dazzleme_common_felix_total_width = 511px;
$dazzleme_common_felix_total_height = 462px;
$dazzleme_common_felix_image = 'dazzleme_common_a.png';
$dazzleme_common_felix = 0px 0px 0px 0px 286px 284px 511px 462px 'dazzleme_common_a.png' 'dazzleme_common_felix';
$dazzleme_common_logo_name = 'dazzleme_common_logo';
$dazzleme_common_logo_x = 0px;
$dazzleme_common_logo_y = 288px;
$dazzleme_common_logo_offset_x = 0px;
$dazzleme_common_logo_offset_y = -288px;
$dazzleme_common_logo_width = 511px;
$dazzleme_common_logo_height = 174px;
$dazzleme_common_logo_total_width = 511px;
$dazzleme_common_logo_total_height = 462px;
$dazzleme_common_logo_image = 'dazzleme_common_a.png';
$dazzleme_common_logo = 0px 288px 0px -288px 511px 174px 511px 462px 'dazzleme_common_a.png' 'dazzleme_common_logo';
$spritesheet_width = 511px;
$spritesheet_height = 462px;
$spritesheet_image = 'dazzleme_common_a.png';
$spritesheet_sprites = $dazzleme_common_felix $dazzleme_common_logo;
$spritesheet = 511px 462px 'dazzleme_common_a.png' $spritesheet_sprites;

/*
The provided mixins are intended to be used with the array-like variables

.icon-home {
  spriteWidth($icon_home)
}

.icon-email {
  sprite($icon_email)
}
*/
spriteWidth($sprite) {
  width: $sprite[4];
}

spriteHeight($sprite) {
  height: $sprite[5];
}

spritePosition($sprite) {
  background-position: $sprite[2] $sprite[3];
}

spriteImage($sprite) {
  background-image: url($sprite[8]);
}

sprite($sprite) {
  spriteImage($sprite)
  spritePosition($sprite)
  spriteWidth($sprite)
  spriteHeight($sprite)
}

/*
The `sprites` mixin generates identical output to the CSS template
  but can be overridden inside of Stylus

sprites($spritesheet_sprites);
*/
sprites($sprites) {
  for $sprite in $sprites {
    $sprite_name = $sprite[9];
    .{$sprite_name} {
      sprite($sprite);
    }
  }
}
