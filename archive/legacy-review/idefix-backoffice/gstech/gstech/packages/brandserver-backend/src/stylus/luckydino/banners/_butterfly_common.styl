/*
Stylus variables are information about icon's compiled state, stored under its original file name

.icon-home {
  width: $icon_home_width;
}

The large array-like variables contain all information about a single icon
$icon_home = x y offset_x offset_y width height total_width total_height image_path;

At the bottom of this section, we provide information about the spritesheet itself
$spritesheet = width height image $spritesheet_sprites;
*/
$butterfly_common_flower_bottom_name = 'butterfly_common_flower_bottom';
$butterfly_common_flower_bottom_x = 0px;
$butterfly_common_flower_bottom_y = 210px;
$butterfly_common_flower_bottom_offset_x = 0px;
$butterfly_common_flower_bottom_offset_y = -210px;
$butterfly_common_flower_bottom_width = 294px;
$butterfly_common_flower_bottom_height = 139px;
$butterfly_common_flower_bottom_total_width = 424px;
$butterfly_common_flower_bottom_total_height = 349px;
$butterfly_common_flower_bottom_image = 'butterfly_common_b.png';
$butterfly_common_flower_bottom = 0px 210px 0px -210px 294px 139px 424px 349px 'butterfly_common_b.png' 'butterfly_common_flower_bottom';
$butterfly_common_flower_left_name = 'butterfly_common_flower_left';
$butterfly_common_flower_left_x = 298px;
$butterfly_common_flower_left_y = 210px;
$butterfly_common_flower_left_offset_x = -298px;
$butterfly_common_flower_left_offset_y = -210px;
$butterfly_common_flower_left_width = 121px;
$butterfly_common_flower_left_height = 105px;
