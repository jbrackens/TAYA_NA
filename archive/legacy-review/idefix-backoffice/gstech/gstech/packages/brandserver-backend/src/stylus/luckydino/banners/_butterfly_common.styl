$butterfly_common_flower_left = 298px 210px -298px -210px 121px 105px 424px 349px 'butterfly_common_b.png' 'butterfly_common_flower_left';
$butterfly_common_logo_name = 'butterfly_common_logo';
$butterfly_common_logo_x = 0px;
