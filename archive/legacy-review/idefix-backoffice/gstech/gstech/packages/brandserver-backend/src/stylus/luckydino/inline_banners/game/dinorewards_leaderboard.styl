#banner_game_dinorewards_leaderboard
  bannerStyles()
  &__leaderboard
    font-family 'Ubuntu',Helvetica,Arial,sans-serif
    font-size 12px
    text-shadow 1px 1px rgba(0,0,0,0.75)
    color #fff
    .selected
      color #fecb2e
    width 180px
    margin 0 33px
    position absolute
    td.last-column
      text-align right
    .divider
      height 2px
      background-linear-gradient(top, #333333, 0%, #727272, 100%)

#banner_game_dinorewards_leaderboard
  &__leaderboard
    top 65px

#banner_game_dinorewards_leaderboard
  .button-holder
    width 100%
    margin-top 5px
    text-align center
    position absolute
    bottom 0
    .button
      font-size 15px
      height 25px
      padding-left 12px
      padding-right 12px

#banner_game_dinorewards_leaderboard
  width 266px
  height 550px
  &__action
    z-index 200
    left 0
    right 0
    bottom 10px
    position absolute
    margin 0 auto
    width 180px
    text-align center
    &_badge
      right -110px

#banner_game_long_leaderboard
  position absolute
  top 0
  width 266px
  height 300px
  background-size 266px 300px
  background-repeat no-repeat
  font-family 'Ubuntu',Helvetica,Arial,sans-serif
  font-size 12px
  .selected
    color #fecb2e
  &__leaderboard
    width 180px
    margin 0 33px
    text-shadow 1px 1px rgba(0,0,0,0.75)
    color #fff
    td.last-column
      text-align right
    .divider
      height 2px
      background-linear-gradient(top, #333333, 0%, #727272, 100%)
  .button-holder
    width 100%
    margin-top 5px
    text-align center
    position absolute
    bottom 12px
    .button
      font-size 15px


#banner_game_dinorewards_campaign,#banner_game_dinorewards_leaderboard
  background-color #00c3da
  position relative
  &__content
    position relative
    &_title
      color #ffffff
      position absolute
      text-align center
      right 0
      left 0
      top 92px
      font-weight 600
      font-size 12px
      z-index 100
      text-transform uppercase
    &_subtitle
      color #000000
      text-align center
      text-transform uppercase
      position absolute
      right 0
      left 0
      top 155px
      letter-spacing: -1px
      font-weight 700
      z-index 100
    &_subtitle2
      color #ffffff
      text-align center
      text-transform uppercase
      position absolute
      top 173px
      left 0
      right 0
      max-width 140px
      margin 0 auto
      font-weight 700
      font-size 22px
      line-height 20px
      z-index 100
    &_subtitle3
      color #FBFFA5
      text-align center
      text-transform uppercase
      position absolute
      right 0
      left 0
      top 212px
      font-size 14px
      font-weight 600
      z-index 100
  &__image
    position absolute
    z-index 10
    cdn_image '/banners/sidebar/rewards_bg.png' 266px 370px
    width 266px
    height 370px
  &__progress
    position absolute
    width 266px
    height 266px
    top 80px
    background-color #00c3da
  &__container1
    position absolute
    overflow hidden
    width 133px
    height 266px
    left 133px
    &_wedge
      background #ffffff
      height 266px
      width 133px
      left 0
      transform-origin: 0 133px
  &__container2
    position absolute
    overflow hidden
    width 133px
    height 266px
    &_wedge
      background #ffffff
      height 266px
      width 133px
      transform-origin 133px 133px
