/*
Stylus variables are information about icon's compiled state, stored under its original file name

.icon-home {
  width: $icon_home_width;
}

The large array-like variables contain all information about a single icon
$icon_home = x y offset_x offset_y width height total_width total_height image_path;

At the bottom of this section, we provide information about the spritesheet itself
$spritesheet = width height image $spritesheet_sprites;
*/
$referafriend_common_ddino_name = 'referafriend_common_ddino';
$referafriend_common_ddino_x = 0px;
$referafriend_common_ddino_y = 0px;
$referafriend_common_ddino_offset_x = 0px;
$referafriend_common_ddino_offset_y = 0px;
$referafriend_common_ddino_width = 170px;
$referafriend_common_ddino_height = 259px;
$referafriend_common_ddino_total_width = 203px;
$referafriend_common_ddino_total_height = 259px;
$referafriend_common_ddino_image = 'referafriend_common_b.png';
$referafriend_common_ddino = 0px 0px 0px 0px 170px 259px 203px 259px 'referafriend_common_b.png' 'referafriend_common_ddino';
$referafriend_common_fblogo_name = 'referafriend_common_fblogo';
$referafriend_common_fblogo_x = 174px;
$referafriend_common_fblogo_y = 0px;
$referafriend_common_fblogo_offset_x = -174px;
$referafriend_common_fblogo_offset_y = 0px;
$referafriend_common_fblogo_width = 29px;
$referafriend_common_fblogo_height = 29px;
$referafriend_common_fblogo_total_width = 203px;
$referafriend_common_fblogo_total_height = 259px;
$referafriend_common_fblogo_image = 'referafriend_common_b.png';
$referafriend_common_fblogo = 174px 0px -174px 0px 29px 29px 203px 259px 'referafriend_common_b.png' 'referafriend_common_fblogo';
$spritesheet_width = 203px;
$spritesheet_height = 259px;
$spritesheet_image = 'referafriend_common_b.png';
$spritesheet_sprites = $referafriend_common_ddino $referafriend_common_fblogo;
$spritesheet = 203px 259px 'referafriend_common_b.png' $spritesheet_sprites;

/*
The provided mixins are intended to be used with the array-like variables

.icon-home {
  spriteWidth($icon_home)
}

.icon-email {
  sprite($icon_email)
}

Example usage in HTML:

`display: block` sprite:
<div class="icon-home"></div>

To change `display` (e.g. `display: inline-block;`), we suggest using a common CSS class:

// CSS
.icon {
  display: inline-block;
}

// HTML
<i class="icon icon-home"></i>
*/
spriteWidth($sprite) {
  width: $sprite[4];
}

spriteHeight($sprite) {
  height: $sprite[5];
}

spritePosition($sprite) {
  background-position: $sprite[2] $sprite[3];
}

spriteImage($sprite) {
  background-image: url($sprite[8]);
}

sprite($sprite) {
  spriteImage($sprite)
  spritePosition($sprite)
  spriteWidth($sprite)
  spriteHeight($sprite)
}

/*
The `sprites` mixin generates identical output to the CSS template
  but can be overridden inside of Stylus

This must be run when you have at least 2 sprites.
  If run with a single sprite, then there will be reference errors.

sprites($spritesheet_sprites);
*/
sprites($sprites) {
  for $sprite in $sprites {
    $sprite_name = $sprite[9];
    .{$sprite_name} {
      sprite($sprite);
    }
  }
}
