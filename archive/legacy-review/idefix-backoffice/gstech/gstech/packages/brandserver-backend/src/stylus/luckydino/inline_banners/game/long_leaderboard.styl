#banner_game_long_leaderboard
  bannerStyles()
  &__leaderboard
    font-family 'Ubuntu',Helvetica,Arial,sans-serif
    font-size 12px
    text-shadow 1px 1px rgba(0,0,0,0.75)
    color #fff
    .selected
      color #fecb2e
    width 180px
    margin 0 33px
    position absolute
    td.last-column
      text-align right
    .divider
      height 2px
      background-linear-gradient(top, #333333, 0%, #727272, 100%)

#banner_game_long_leaderboard
  &__leaderboard
    top 100px
  top 0
  width 266px
  height 350px
  background-size 266px 300px
  background-repeat no-repeat
  font-family 'Ubuntu',Helvetica,Arial,sans-serif
  font-size 12px
  .selected
    color #fecb2e
  &__leaderboard
    width 180px
    margin 0 33px
    text-shadow 1px 1px rgba(0,0,0,0.75)
    color #fff
    td.last-column
      text-align right
    .divider
      height 2px
      background-linear-gradient(top, #333333, 0%, #727272, 100%)
  .button-holder
    width 100%
    margin-top 5px
    text-align center
    position absolute
    bottom 12px
    .button
      font-size 15px

