/*
Stylus variables are information about icon's compiled state, stored under its original file name

.icon-home {
  width: $icon_home_width;
}

The large array-like variables contain all information about a single icon
$icon_home = x y offset_x offset_y width height total_width total_height image_path;

At the bottom of this section, we provide information about the spritesheet itself
$spritesheet = width height image $spritesheet_sprites;
*/
$staxx_common_l1_name = 'staxx_common_l1';
$staxx_common_l1_x = 0px;
$staxx_common_l1_y = 190px;
$staxx_common_l1_offset_x = 0px;
$staxx_common_l1_offset_y = -190px;
$staxx_common_l1_width = 235px;
$staxx_common_l1_height = 164px;
$staxx_common_l1_total_width = 488px;
$staxx_common_l1_total_height = 354px;
$staxx_common_l1_image = 'staxx_common_b.png';
$staxx_common_l1 = 0px 190px 0px -190px 235px 164px 488px 354px 'staxx_common_b.png' 'staxx_common_l1';
$staxx_common_logo_name = 'staxx_common_logo';
$staxx_common_logo_x = 233px;
