  body#leaderboard-wrapper
    style.
      #banner_game-leaderboard_leaderboard{position:relative;overflow:hidden;-webkit-box-sizing:border-box;box-sizing:border-box;background-repeat:no-repeat;text-align:center;font-family:'PT Sans',sans-serif;width:150px;height:460px;text-align:center;}
      #banner_game-leaderboard_leaderboard *,#banner_game-leaderboard_leaderboard *:after,#banner_game-leaderboard_leaderboard *:before{-webkit-box-sizing:border-box;box-sizing:border-box}#banner_game-leaderboard_leaderboard__promo_button,#banner_game-leaderboard_leaderboard__promo_button:hover,#banner_game-leaderboard_leaderboard__promo_button:focus{display:inline-block;font-family:'Passion One',sans-serif;font-weight:700;font-size:16px;line-height:40px;text-transform:uppercase;white-space:nowrap;padding:4px 24px;text-decoration:none;text-align:center;border-radius:6px;position:relative;background-color:#ffc641;color:#343434;}#banner_game-leaderboard_leaderboard h1,#banner_game-leaderboard_leaderboard h2,#banner_game-leaderboard_leaderboard h3,#banner_game-leaderboard_leaderboard h4,#banner_game-leaderboard_leaderboard h5,#banner_game-leaderboard_leaderboard h6{font-family:'Passion One',sans-serif;font-weight:700;line-height:100%;text-transform:uppercase}#banner_game-leaderboard_leaderboard .banner-cta-button{background-color:#63c5fa;position:absolute;bottom:10px;left:0;right:0;margin:0 auto;width:120px;padding:0 12px}#banner_game-leaderboard_leaderboard__promo_button_holder{width:100%;text-align:center;position:absolute;bottom:20px}@media only screen and (max-width:991px){#banner_game-leaderboard_leaderboard{margin:0 auto;width:100%}}#banner_game-leaderboard_leaderboard .banner{margin-top:40px;background-color:#9bdbfb;width:100%;height:100%}#banner_game-leaderboard_leaderboard .banner-wrapper{width:100%;height:100%;background-size:150px 460px}#banner_game-leaderboard_leaderboard h1{color:#fff;font-size:20px;line-height:15px;text-transform:uppercase}#banner_game-leaderboard_leaderboard p{font-size:11px;line-height:16px;color:#000;max-width:120px;margin:0 auto}#banner_game-leaderboard_leaderboard__title{margin:8px 0 16px 8px;padding-top:16px;text-align:left}#banner_game-leaderboard_leaderboard__banner{font-weight:400 !important;text-align:left !important;max-width:136px !important;font-size:12px !important;line-hieght:10px !important;margin-bottom:4px !important}#banner_game-leaderboard_leaderboard__leaderboard_header{color:#2d70b8 !important;padding:0;margin:0;width:100%;height:24px;font-family:'Passion One',sans-serif;font-weight:700;font-size:15px !important;text-transform:uppercase;max-width:100% !important;line-height:24px !important;border-bottom:1px solid #1f589a;background-color:#d8f1fd;text-align:center}#banner_game-leaderboard_leaderboard__leaderboard{font-size:12px;color:#000;width:100%;}#banner_game-leaderboard_leaderboard__leaderboard tr{border-bottom:1px solid #1f589a;height:15px;}#banner_game-leaderboard_leaderboard__leaderboard tr:nth-child(1),#banner_game-leaderboard_leaderboard__leaderboard tr:nth-child(2){font-weight:bold}#banner_game-leaderboard_leaderboard__leaderboard tr.divider{height:0;margin:0;border:0}#banner_game-leaderboard_leaderboard__leaderboard tr.selected.last-row .first-column{background-color:#d8f1fd}#banner_game-leaderboard_leaderboard__leaderboard tr.selected .middle-column,#banner_game-leaderboard_leaderboard__leaderboard tr.selected .last-column{background-color:#d8f1fd}#banner_game-leaderboard_leaderboard__leaderboard .first-column{background-color:#1f589a;color:#fff;width:24px;text-align:center}#banner_game-leaderboard_leaderboard__leaderboard .middle-column{text-align:left;padding-left:8px}#banner_game-leaderboard_leaderboard__leaderboard .last-column{text-align:right;padding-right:8px;color:#2d70b8}<
  body#leaderboard-wrapper
