/*
Stylus variables are information about icon's compiled state, stored under its original file name

.icon-home {
  width: $icon_home_width;
}

The large array-like variables contain all information about a single icon
$icon_home = x y offset_x offset_y width height total_width total_height image_path;

At the bottom of this section, we provide information about the spritesheet itself
$spritesheet = width height image $spritesheet_sprites;
*/
$bs2_spinosaurus_common_dame_name = 'bs2_spinosaurus_common_dame';
$bs2_spinosaurus_common_dame_x = 0px;
$bs2_spinosaurus_common_dame_y = 207px;
$bs2_spinosaurus_common_dame_offset_x = 0px;
$bs2_spinosaurus_common_dame_offset_y = -207px;
$bs2_spinosaurus_common_dame_width = 217px;
$bs2_spinosaurus_common_dame_height = 300px;
$bs2_spinosaurus_common_dame_total_width = 431px;
$bs2_spinosaurus_common_dame_total_height = 507px;
$bs2_spinosaurus_common_dame_image = 'bs2_spinosaurus_common_b.png';
$bs2_spinosaurus_common_dame = 0px 207px 0px -207px 217px 300px 431px 507px 'bs2_spinosaurus_common_b.png' 'bs2_spinosaurus_common_dame';
$bs2_spinosaurus_common_logo_name = 'bs2_spinosaurus_common_logo';
$bs2_spinosaurus_common_logo_x = 0px;
$bs2_spinosaurus_common_logo_y = 0px;
$bs2_spinosaurus_common_logo_offset_x = 0px;
$bs2_spinosaurus_common_logo_offset_y = 0px;
$bs2_spinosaurus_common_logo_width = 431px;
$bs2_spinosaurus_common_logo_height = 203px;
$bs2_spinosaurus_common_logo_total_width = 431px;
$bs2_spinosaurus_common_logo_total_height = 507px;
$bs2_spinosaurus_common_logo_image = 'bs2_spinosaurus_common_b.png';
$bs2_spinosaurus_common_logo = 0px 0px 0px 0px 431px 203px 431px 507px 'bs2_spinosaurus_common_b.png' 'bs2_spinosaurus_common_logo';
$spritesheet_width = 431px;
$spritesheet_height = 507px;
$spritesheet_image = 'bs2_spinosaurus_common_b.png';
$spritesheet_sprites = $bs2_spinosaurus_common_dame $bs2_spinosaurus_common_logo;
$spritesheet = 431px 507px 'bs2_spinosaurus_common_b.png' $spritesheet_sprites;

/*
The provided mixins are intended to be used with the array-like variables

.icon-home {
  spriteWidth($icon_home)
}

.icon-email {
  sprite($icon_email)
}

Example usage in HTML:

`display: block` sprite:
<div class="icon-home"></div>

To change `display` (e.g. `display: inline-block;`), we suggest using a common CSS class:

// CSS
.icon {
  display: inline-block;
}

// HTML
<i class="icon icon-home"></i>
*/
spriteWidth($sprite) {
  width: $sprite[4];
}

spriteHeight($sprite) {
  height: $sprite[5];
}

spritePosition($sprite) {
  background-position: $sprite[2] $sprite[3];
}

spriteImage($sprite) {
  background-image: url($sprite[8]);
}

sprite($sprite) {
  spriteImage($sprite)
  spritePosition($sprite)
  spriteWidth($sprite)
  spriteHeight($sprite)
}

/*
The `sprites` mixin generates identical output to the CSS template
  but can be overridden inside of Stylus

This must be run when you have at least 2 sprites.
  If run with a single sprite, then there will be reference errors.

sprites($spritesheet_sprites);
*/
sprites($sprites) {
  for $sprite in $sprites {
    $sprite_name = $sprite[9];
    .{$sprite_name} {
      sprite($sprite);
    }
  }
}
