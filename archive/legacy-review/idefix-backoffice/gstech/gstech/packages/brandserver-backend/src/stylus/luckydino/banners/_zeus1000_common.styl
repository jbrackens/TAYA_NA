/*
Stylus variables are information about icon's compiled state, stored under its original file name

.icon-home {
  width: $icon_home_width;
}

The large array-like variables contain all information about a single icon
$icon_home = x y offset_x offset_y width height total_width total_height image_path;

At the bottom of this section, we provide information about the spritesheet itself
$spritesheet = width height image $spritesheet_sprites;
*/
$zeus1000_common_logo_name = 'zeus1000_common_logo';
$zeus1000_common_logo_x = 0px;
$zeus1000_common_logo_y = 264px;
$zeus1000_common_logo_offset_x = 0px;
$zeus1000_common_logo_offset_y = -264px;
$zeus1000_common_logo_width = 416px;
$zeus1000_common_logo_height = 72px;
$zeus1000_common_logo_total_width = 455px;
$zeus1000_common_logo_total_height = 336px;
$zeus1000_common_logo_image = 'zeus1000_common_b.png';
$zeus1000_common_logo = 0px 264px 0px -264px 416px 72px 455px 336px 'zeus1000_common_b.png' 'zeus1000_common_logo';
$zeus1000_common_zeus1000_name = 'zeus1000_common_zeus1000';
$zeus1000_common_zeus1000_x = 0px;
$zeus1000_common_zeus1000_y = 0px;
$zeus1000_common_zeus1000_offset_x = 0px;
$zeus1000_common_zeus1000_offset_y = 0px;
$zeus1000_common_zeus1000_width = 455px;
$zeus1000_common_zeus1000_height = 260px;
$zeus1000_common_zeus1000_total_width = 455px;
$zeus1000_common_zeus1000_total_height = 336px;
$zeus1000_common_zeus1000_image = 'zeus1000_common_b.png';
$zeus1000_common_zeus1000 = 0px 0px 0px 0px 455px 260px 455px 336px 'zeus1000_common_b.png' 'zeus1000_common_zeus1000';
$spritesheet_width = 455px;
$spritesheet_height = 336px;
$spritesheet_image = 'zeus1000_common_b.png';
$spritesheet_sprites = $zeus1000_common_logo $zeus1000_common_zeus1000;
$spritesheet = 455px 336px 'zeus1000_common_b.png' $spritesheet_sprites;

/*
The provided mixins are intended to be used with the array-like variables

.icon-home {
  spriteWidth($icon_home)
}

.icon-email {
  sprite($icon_email)
}

Example usage in HTML:

`display: block` sprite:
<div class="icon-home"></div>

To change `display` (e.g. `display: inline-block;`), we suggest using a common CSS class:

// CSS
.icon {
  display: inline-block;
}

// HTML
<i class="icon icon-home"></i>
*/
spriteWidth($sprite) {
  width: $sprite[4];
}

spriteHeight($sprite) {
  height: $sprite[5];
}

spritePosition($sprite) {
  background-position: $sprite[2] $sprite[3];
}

spriteImage($sprite) {
  background-image: url($sprite[8]);
}

sprite($sprite) {
  spriteImage($sprite)
  spritePosition($sprite)
  spriteWidth($sprite)
  spriteHeight($sprite)
}

/*
The `sprites` mixin generates identical output to the CSS template
  but can be overridden inside of Stylus

This must be run when you have at least 2 sprites.
  If run with a single sprite, then there will be reference errors.

sprites($spritesheet_sprites);
*/
sprites($sprites) {
  for $sprite in $sprites {
    $sprite_name = $sprite[9];
    .{$sprite_name} {
      sprite($sprite);
    }
  }
}
