/*
Stylus variables are information about icon's compiled state, stored under its original file name

.icon-home {
  width: $icon_home_width;
}

The large array-like variables contain all information about a single icon
$icon_home = x y offset_x offset_y width height total_width total_height image_path;

At the bottom of this section, we provide information about the spritesheet itself
$spritesheet = width height image $spritesheet_sprites;
*/
$fcup_common_felix_name = 'fcup_common_felix';
$fcup_common_felix_x = 0px;
$fcup_common_felix_y = 0px;
$fcup_common_felix_offset_x = 0px;
$fcup_common_felix_offset_y = 0px;
$fcup_common_felix_width = 256px;
$fcup_common_felix_height = 294px;
$fcup_common_felix_total_width = 502px;
$fcup_common_felix_total_height = 294px;
$fcup_common_felix_image = 'fcup_common_b.png';
$fcup_common_felix = 0px 0px 0px 0px 256px 294px 502px 294px 'fcup_common_b.png' 'fcup_common_felix';
$fcup_common_logo_name = 'fcup_common_logo';
$fcup_common_logo_x = 260px;
$fcup_common_logo_y = 0px;
$fcup_common_logo_offset_x = -260px;
$fcup_common_logo_offset_y = 0px;
$fcup_common_logo_width = 242px;
$fcup_common_logo_height = 230px;
$fcup_common_logo_total_width = 502px;
$fcup_common_logo_total_height = 294px;
$fcup_common_logo_image = 'fcup_common_b.png';
$fcup_common_logo = 260px 0px -260px 0px 242px 230px 502px 294px 'fcup_common_b.png' 'fcup_common_logo';
$spritesheet_width = 502px;
$spritesheet_height = 294px;
$spritesheet_image = 'fcup_common_b.png';
$spritesheet_sprites = $fcup_common_felix $fcup_common_logo;
$spritesheet = 502px 294px 'fcup_common_b.png' $spritesheet_sprites;

/*
The provided mixins are intended to be used with the array-like variables

.icon-home {
  spriteWidth($icon_home)
}

.icon-email {
  sprite($icon_email)
}

Example usage in HTML:

`display: block` sprite:
<div class="icon-home"></div>

To change `display` (e.g. `display: inline-block;`), we suggest using a common CSS class:

// CSS
.icon {
  display: inline-block;
}

// HTML
<i class="icon icon-home"></i>
*/
spriteWidth($sprite) {
  width: $sprite[4];
}

spriteHeight($sprite) {
  height: $sprite[5];
}

spritePosition($sprite) {
  background-position: $sprite[2] $sprite[3];
}

spriteImage($sprite) {
  background-image: url($sprite[8]);
}

sprite($sprite) {
  spriteImage($sprite)
  spritePosition($sprite)
  spriteWidth($sprite)
  spriteHeight($sprite)
}

/*
The `sprites` mixin generates identical output to the CSS template
  but can be overridden inside of Stylus

This must be run when you have at least 2 sprites.
  If run with a single sprite, then there will be reference errors.

sprites($spritesheet_sprites);
*/
sprites($sprites) {
  for $sprite in $sprites {
    $sprite_name = $sprite[9];
    .{$sprite_name} {
      sprite($sprite);
    }
  }
}
