/*
Stylus variables are information about icon's compiled state, stored under its original file name

.icon-home {
  width: $icon_home_width;
}

The large array-like variables contain all information about a single icon
$icon_home = x y offset_x offset_y width height total_width total_height image_path;

At the bottom of this section, we provide information about the spritesheet itself
$spritesheet = width height image $spritesheet_sprites;
*/
$sv-hide-info_2x_name = 'sv-hide-info_2x';
$sv-hide-info_2x_x = 0px;
$sv-hide-info_2x_y = 0px;
$sv-hide-info_2x_offset_x = 0px;
$sv-hide-info_2x_offset_y = 0px;
$sv-hide-info_2x_width = 24px;
$sv-hide-info_2x_height = 79px;
$sv-hide-info_2x_total_width = 150px;
$sv-hide-info_2x_total_height = 316px;
$sv-hide-info_2x_image = 'sprite_sv@2x.png';
$sv-hide-info_2x = 0px 0px 0px 0px 24px 79px 150px 316px 'sprite_sv@2x.png' 'sv-hide-info_2x';
$sv-new-badge_2x_name = 'sv-new-badge_2x';
$sv-new-badge_2x_x = 0px;
$sv-new-badge_2x_y = 166px;
$sv-new-badge_2x_offset_x = 0px;
$sv-new-badge_2x_offset_y = -166px;
$sv-new-badge_2x_width = 150px;
$sv-new-badge_2x_height = 150px;
$sv-new-badge_2x_total_width = 150px;
$sv-new-badge_2x_total_height = 316px;
$sv-new-badge_2x_image = 'sprite_sv@2x.png';
$sv-new-badge_2x = 0px 166px 0px -166px 150px 150px 150px 316px 'sprite_sv@2x.png' 'sv-new-badge_2x';
$sv-show-info_2x_name = 'sv-show-info_2x';
$sv-show-info_2x_x = 0px;
$sv-show-info_2x_y = 83px;
$sv-show-info_2x_offset_x = 0px;
$sv-show-info_2x_offset_y = -83px;
$sv-show-info_2x_width = 24px;
$sv-show-info_2x_height = 79px;
$sv-show-info_2x_total_width = 150px;
$sv-show-info_2x_total_height = 316px;
$sv-show-info_2x_image = 'sprite_sv@2x.png';
$sv-show-info_2x = 0px 83px 0px -83px 24px 79px 150px 316px 'sprite_sv@2x.png' 'sv-show-info_2x';
$spritesheet_width = 150px;
$spritesheet_height = 316px;
$spritesheet_image = 'sprite_sv@2x.png';
$spritesheet_sprites = $sv-hide-info_2x $sv-new-badge_2x $sv-show-info_2x;
$spritesheet = 150px 316px 'sprite_sv@2x.png' $spritesheet_sprites;

/*
The provided mixins are intended to be used with the array-like variables

.icon-home {
  spriteWidth($icon_home)
}

.icon-email {
  sprite($icon_email)
}
*/
spriteWidth($sprite) {
  width: $sprite[4];
}

spriteHeight($sprite) {
  height: $sprite[5];
}

spritePosition($sprite) {
  background-position: $sprite[2] $sprite[3];
}

spriteImage($sprite) {
  background-image: url($sprite[8]);
}

sprite($sprite) {
  spriteImage($sprite)
  spritePosition($sprite)
  spriteWidth($sprite)
  spriteHeight($sprite)
}

/*
The `sprites` mixin generates identical output to the CSS template
  but can be overridden inside of Stylus

sprites($spritesheet_sprites);
*/
sprites($sprites) {
  for $sprite in $sprites {
    $sprite_name = $sprite[9];
    .{$sprite_name} {
      sprite($sprite);
    }
  }
}
