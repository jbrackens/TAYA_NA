mixin spinner_dark(enabled)
  +spinner_white(enabled)

mixin spinner_grey(enabled)
  +spinner_blue(enabled)


mixin translation(key)
  div(style='display:none', data-translation=key)=localize(key)

mixin formFeedback()
  span.form-feedback
    span.feedback-content
      p
