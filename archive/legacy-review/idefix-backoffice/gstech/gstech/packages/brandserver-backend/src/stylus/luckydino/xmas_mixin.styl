xmas_day($sprite)
  bannerStyles()
  dark_bg_banner()
  @media only screen and (max-width:768px)
    .background
      background-position: right center;

  .campaign
    width 590px
    text-align left
    padding-left 240px
    @media only screen and (max-width:768px)
      padding-left 4px
      width 320px
    h1
      font-size 28px
      line-height 32px
      font-weight 900
      position relative
      bottom auto
      margin-top 40px
      min-height 65px
    h3
      position relative
      bottom auto
      text-transform none
      font-family 'Ubuntu', Helvetica, Arial, sans-serif
      font-size 16px
      text-shadow 1px 1px 0 rgba(0, 0, 0, 0.2)
      font-weight 400
    .button-holder
      bottom 40px
      @media only screen and (min-width:768px)
        text-align left
    .button
      background: linear-gradient(to bottom, rgba(243,29,60,0.96) 0%,rgba(242,29,60,1) 2%,rgba(206,24,51,1) 98%,rgba(205,24,51,0.96) 100%);
      color: #ffffff;
      text-shadow: 1px 1px rgba(0, 0, 0, 0.35)
      border-radius: 7px
      line-height 35px
  .campaign-banner
    bottom 70px
  &_item1
    position absolute
    display block
    right 5%
    bottom 0
    banner_sprite: $sprite
    animation reveal-up-pop 1s
    animation-iteration-count 1
    @media only screen and (max-width:1099px)
      right 20px

