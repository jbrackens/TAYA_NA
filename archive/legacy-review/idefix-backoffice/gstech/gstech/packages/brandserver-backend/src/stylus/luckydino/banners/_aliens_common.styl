$aliens_common_alien = 0px 0px 0px 0px 568px 300px 568px 533px 'aliens_common_b.png' 'aliens_common_alien';
$aliens_common_copyright_name = 'aliens_common_copyright';
$aliens_common_copyright_x = 0px;
$aliens_common_copyright_y = 472px;
