/*
Stylus variables are information about icon's compiled state, stored under its original file name

.icon-home {
  width: $icon_home_width;
}

The large array-like variables contain all information about a single icon
$icon_home = x y offset_x offset_y width height total_width total_height image_path;

At the bottom of this section, we provide information about the spritesheet itself
$spritesheet = width height image $spritesheet_sprites;
*/
$nyreload_common_felixfirecracker_name = 'nyreload_common_felixfirecracker';
$nyreload_common_felixfirecracker_x = 0px;
$nyreload_common_felixfirecracker_y = 0px;
$nyreload_common_felixfirecracker_offset_x = 0px;
$nyreload_common_felixfirecracker_offset_y = 0px;
$nyreload_common_felixfirecracker_width = 255px;
$nyreload_common_felixfirecracker_height = 290px;
$nyreload_common_felixfirecracker_total_width = 579px;
$nyreload_common_felixfirecracker_total_height = 290px;
$nyreload_common_felixfirecracker_image = 'nyreload_common_a.png';
$nyreload_common_felixfirecracker = 0px 0px 0px 0px 255px 290px 579px 290px 'nyreload_common_a.png' 'nyreload_common_felixfirecracker';
$nyreload_common_text_name = 'nyreload_common_text';
$nyreload_common_text_x = 259px;
$nyreload_common_text_y = 0px;
$nyreload_common_text_offset_x = -259px;
$nyreload_common_text_offset_y = 0px;
$nyreload_common_text_width = 320px;
$nyreload_common_text_height = 169px;
$nyreload_common_text_total_width = 579px;
$nyreload_common_text_total_height = 290px;
$nyreload_common_text_image = 'nyreload_common_a.png';
$nyreload_common_text = 259px 0px -259px 0px 320px 169px 579px 290px 'nyreload_common_a.png' 'nyreload_common_text';
$spritesheet_width = 579px;
$spritesheet_height = 290px;
$spritesheet_image = 'nyreload_common_a.png';
$spritesheet_sprites = $nyreload_common_felixfirecracker $nyreload_common_text;
$spritesheet = 579px 290px 'nyreload_common_a.png' $spritesheet_sprites;

/*
The provided mixins are intended to be used with the array-like variables

.icon-home {
  spriteWidth($icon_home)
}

.icon-email {
  sprite($icon_email)
}
*/
spriteWidth($sprite) {
  width: $sprite[4];
}

spriteHeight($sprite) {
  height: $sprite[5];
}

spritePosition($sprite) {
  background-position: $sprite[2] $sprite[3];
}

spriteImage($sprite) {
  background-image: url($sprite[8]);
}

sprite($sprite) {
  spriteImage($sprite)
  spritePosition($sprite)
  spriteWidth($sprite)
  spriteHeight($sprite)
}

/*
The `sprites` mixin generates identical output to the CSS template
  but can be overridden inside of Stylus

sprites($spritesheet_sprites);
*/
sprites($sprites) {
  for $sprite in $sprites {
    $sprite_name = $sprite[9];
    .{$sprite_name} {
      sprite($sprite);
    }
  }
}
