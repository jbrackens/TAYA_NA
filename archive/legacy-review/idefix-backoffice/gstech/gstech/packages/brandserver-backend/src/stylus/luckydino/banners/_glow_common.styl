/*
Stylus variables are information about icon's compiled state, stored under its original file name

.icon-home {
  width: $icon_home_width;
}

The large array-like variables contain all information about a single icon
$icon_home = x y offset_x offset_y width height total_width total_height image_path;

At the bottom of this section, we provide information about the spritesheet itself
$spritesheet = width height image $spritesheet_sprites;
*/
$glow_common_elk_name = 'glow_common_elk';
$glow_common_elk_x = 217px;
$glow_common_elk_y = 0px;
$glow_common_elk_offset_x = -217px;
$glow_common_elk_offset_y = 0px;
$glow_common_elk_width = 181px;
$glow_common_elk_height = 172px;
$glow_common_elk_total_width = 398px;
$glow_common_elk_total_height = 272px;
$glow_common_elk_image = 'glow_common_b.png';
$glow_common_elk = 217px 0px -217px 0px 181px 172px 398px 272px 'glow_common_b.png' 'glow_common_elk';
$glow_common_fox_name = 'glow_common_fox';
$glow_common_fox_x = 0px;
$glow_common_fox_y = 0px;
$glow_common_fox_offset_x = 0px;
$glow_common_fox_offset_y = 0px;
$glow_common_fox_width = 213px;
$glow_common_fox_height = 193px;
$glow_common_fox_total_width = 398px;
$glow_common_fox_total_height = 272px;
$glow_common_fox_image = 'glow_common_b.png';
$glow_common_fox = 0px 0px 0px 0px 213px 193px 398px 272px 'glow_common_b.png' 'glow_common_fox';
$glow_common_logo_name = 'glow_common_logo';
$glow_common_logo_x = 0px;
$glow_common_logo_y = 197px;
$glow_common_logo_offset_x = 0px;
$glow_common_logo_offset_y = -197px;
$glow_common_logo_width = 364px;
$glow_common_logo_height = 75px;
$glow_common_logo_total_width = 398px;
$glow_common_logo_total_height = 272px;
$glow_common_logo_image = 'glow_common_b.png';
$glow_common_logo = 0px 197px 0px -197px 364px 75px 398px 272px 'glow_common_b.png' 'glow_common_logo';
$spritesheet_width = 398px;
$spritesheet_height = 272px;
$spritesheet_image = 'glow_common_b.png';
$spritesheet_sprites = $glow_common_elk $glow_common_fox $glow_common_logo;
$spritesheet = 398px 272px 'glow_common_b.png' $spritesheet_sprites;

/*
The provided mixins are intended to be used with the array-like variables

.icon-home {
  spriteWidth($icon_home)
}

.icon-email {
  sprite($icon_email)
}

Example usage in HTML:

`display: block` sprite:
<div class="icon-home"></div>

To change `display` (e.g. `display: inline-block;`), we suggest using a common CSS class:

// CSS
.icon {
  display: inline-block;
}

// HTML
<i class="icon icon-home"></i>
*/
spriteWidth($sprite) {
  width: $sprite[4];
}

spriteHeight($sprite) {
  height: $sprite[5];
}

spritePosition($sprite) {
  background-position: $sprite[2] $sprite[3];
}

spriteImage($sprite) {
  background-image: url($sprite[8]);
}

sprite($sprite) {
  spriteImage($sprite)
  spritePosition($sprite)
  spriteWidth($sprite)
  spriteHeight($sprite)
}

/*
The `sprites` mixin generates identical output to the CSS template
  but can be overridden inside of Stylus

This must be run when you have at least 2 sprites.
  If run with a single sprite, then there will be reference errors.

sprites($spritesheet_sprites);
*/
sprites($sprites) {
  for $sprite in $sprites {
    $sprite_name = $sprite[9];
    .{$sprite_name} {
      sprite($sprite);
    }
  }
}
