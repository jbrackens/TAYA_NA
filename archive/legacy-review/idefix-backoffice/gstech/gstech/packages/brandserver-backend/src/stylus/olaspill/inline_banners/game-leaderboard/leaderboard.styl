#banner_game-leaderboard_leaderboard
  sidebarBanner()
  height 330px
  position relative
  background-repeat no-repeat
  .banner-cta-button
    bottom 32px !important
  &__title
    margin 8px 0 16px 8px
    padding-top 16px
    text-align left
  &__banner
    font-weight 400 !important
    text-align left !important
    max-width 136px !important
    font-size 12px !important
    line-hieght 10px !important
    margin-bottom 4px !important
  &__leaderboard_header
    color $kalevala_blue !important
    padding 0
    margin 0
    width 100%
    height 24px
    headerFont()
    font-size 15px !important
    text-transform uppercase
    max-width 100% !important
    line-height 24px !important
    border-bottom 1px solid $kalevala_dark_blue
    background-color #d8f1fd
    text-align center
  &__leaderboard
    font-size 12px
    color #000
    width 100%
    tr
      border-bottom 1px solid $kalevala_dark_blue
      height 15px
      &:nth-child(1),&:nth-child(2)
        font-weight bold
      &.divider
        height 0
        margin 0
        border 0
      &.selected
        &.last-row
          .first-column
            background-color #d8f1fd
        .middle-column, .last-column
          background-color #d8f1fd
    .first-column
      background-color $kalevala_dark_blue
      color #ffffff
      width 24px
      text-align center
    .middle-column
      text-align left
      padding-left 8px
    .last-column
      text-align right
      padding-right 8px
      color $kalevala_blue
