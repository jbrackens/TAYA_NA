
#banner_frontpage_welcome
  banner-bg $new1stdeposit_bg $new1stdeposit_bg_m
  default_banner_items()
  dark_bg_banner()
  .campaign
    max-width 520px
  .campaign-banner
    bottom 80px

#banner_frontpage_welcome_image
  banner_sprite: $new1stdeposit_en_text
  position relative
  display block
  margin 0 auto
  top 50px
  @media only screen and (max-width:991px)
    banner_sprite: $new1stdeposit_en_mobile_text
  .campaign-banner
    bottom 100px

#banner_frontpage_welcome_item1
  position absolute
  banner_sprite: $new1stdeposit_common_misspiggy
  left 10%
  bottom 0
  animation reveal-up 1.5s
  animation-iteration-count 1
  @media only screen and (max-width:991px)
    left 10px
#banner_frontpage_welcome_item2
  position absolute
  banner_sprite: $new1stdeposit_common_hook
  right 20%
  top 0
  animation reveal-down-pop 1s
  animation-iteration-count 1
  @media only screen and (max-width:991px)
    right 120px

#banner_frontpage_welcome_item3
  position absolute
  banner_sprite: $new1stdeposit_common_felix
  right 5%
  bottom 0
  animation reveal-up-pop 2s
  animation-iteration-count 1
  @media only screen and (max-width:991px)
    right -50px

.lang-fi #banner_frontpage_welcome_image
  banner_sprite: $new1stdeposit_fi_text
  @media only screen and (max-width:1199px)
    banner_sprite: $new1stdeposit_fi_mobile_text

.lang-de #banner_frontpage_welcome_image
  banner_sprite: $new1stdeposit_de_text
  @media only screen and (max-width:1199px)
    banner_sprite: $new1stdeposit_de_mobile_text

.lang-sv #banner_frontpage_welcome_image
  banner_sprite: $new1stdeposit_sv_text
  @media only screen and (max-width:991px)
    top 80px
    banner_sprite: $new1stdeposit_sv_mobile_text

.lang-no #banner_frontpage_welcome_image
  banner_sprite: $new1stdeposit_no_text
  @media only screen and (max-width:991px)
    top 80px
    banner_sprite: $new1stdeposit_no_mobile_text

.lang-ja #banner_frontpage_welcome_image
  banner_sprite: $new1stdeposit_ja_text
  @media only screen and (max-width:991px)
    top 80px
    banner_sprite: $new1stdeposit_ja_mobile_text

@keyframes reveal-up-pop {
 0% {transform: translateY(600px);}
 75% {transform:translateY(600px);}
 100% {transform:translateY(0px)}
}

  @keyframes reveal-up {
      0% {transform: translateY(600px);}
      20% {transform:translateY(0px);}
      100% {transform:translateY(0px)}
  }


