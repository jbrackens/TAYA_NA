#banner_game-leaderboard_leaderboard
  bannerStyles()
  &__leaderboard
    font-family 'Ubuntu',Helvetica,Arial,sans-serif
    font-size 12px
    text-shadow 1px 1px rgba(0,0,0,0.75)
    color #fff
    .selected
      color #fecb2e
    width 180px
    margin 0 33px
    position absolute
    td.last-column
      text-align right
    .divider
      height 2px
      background-linear-gradient(top, #333333, 0%, #727272, 100%)
