/*
Stylus variables are information about icon's compiled state, stored under its original file name

.icon-home {
  width: $icon_home_width;
}

The large array-like variables contain all information about a single icon
$icon_home = x y offset_x offset_y width height total_width total_height image_path;

At the bottom of this section, we provide information about the spritesheet itself
$spritesheet = width height image $spritesheet_sprites;
*/
$midsummer2016_en_mobile_logo_name = 'midsummer2016_en_mobile_logo';
$midsummer2016_en_mobile_logo_x = 0px;
$midsummer2016_en_mobile_logo_y = 0px;
$midsummer2016_en_mobile_logo_offset_x = 0px;
$midsummer2016_en_mobile_logo_offset_y = 0px;
$midsummer2016_en_mobile_logo_width = 320px;
$midsummer2016_en_mobile_logo_height = 66px;
$midsummer2016_en_mobile_logo_total_width = 320px;
$midsummer2016_en_mobile_logo_total_height = 66px;
$midsummer2016_en_mobile_logo_image = 'midsummer2016_en_mobile_a.png';
$midsummer2016_en_mobile_logo = 0px 0px 0px 0px 320px 66px 320px 66px 'midsummer2016_en_mobile_a.png' 'midsummer2016_en_mobile_logo';
$spritesheet_width = 320px;
$spritesheet_height = 66px;
$spritesheet_image = 'midsummer2016_en_mobile_a.png';
$spritesheet_sprites = $midsummer2016_en_mobile_logo;
$spritesheet = 320px 66px 'midsummer2016_en_mobile_a.png' $spritesheet_sprites;

/*
The provided mixins are intended to be used with the array-like variables

.icon-home {
  spriteWidth($icon_home)
}

.icon-email {
  sprite($icon_email)
}
*/
spriteWidth($sprite) {
  width: $sprite[4];
}

spriteHeight($sprite) {
  height: $sprite[5];
}

spritePosition($sprite) {
  background-position: $sprite[2] $sprite[3];
}

spriteImage($sprite) {
  background-image: url($sprite[8]);
}

sprite($sprite) {
  spriteImage($sprite)
  spritePosition($sprite)
  spriteWidth($sprite)
  spriteHeight($sprite)
}

/*
The `sprites` mixin generates identical output to the CSS template
  but can be overridden inside of Stylus

sprites($spritesheet_sprites);
*/
sprites($sprites) {
  for $sprite in $sprites {
    $sprite_name = $sprite[9];
    .{$sprite_name} {
      sprite($sprite);
    }
  }
}
