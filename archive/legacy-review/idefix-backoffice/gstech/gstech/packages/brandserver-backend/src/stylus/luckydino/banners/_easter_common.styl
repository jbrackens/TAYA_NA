/*
Stylus variables are information about icon's compiled state, stored under its original file name

.icon-home {
  width: $icon_home_width;
}

The large array-like variables contain all information about a single icon
$icon_home = x y offset_x offset_y width height total_width total_height image_path;

At the bottom of this section, we provide information about the spritesheet itself
$spritesheet = width height image $spritesheet_sprites;
*/
$easter_common_logo_name = 'easter_common_logo';
$easter_common_logo_x = 0px;
$easter_common_logo_y = 300px;
$easter_common_logo_offset_x = 0px;
$easter_common_logo_offset_y = -300px;
$easter_common_logo_width = 420px;
$easter_common_logo_height = 117px;
$easter_common_logo_total_width = 420px;
$easter_common_logo_total_height = 417px;
$easter_common_logo_image = 'easter_common_a.png';
$easter_common_logo = 0px 300px 0px -300px 420px 117px 420px 417px 'easter_common_a.png' 'easter_common_logo';
$easter_common_rooster_name = 'easter_common_rooster';
$easter_common_rooster_x = 0px;
$easter_common_rooster_y = 0px;
$easter_common_rooster_offset_x = 0px;
$easter_common_rooster_offset_y = 0px;
$easter_common_rooster_width = 405px;
$easter_common_rooster_height = 296px;
$easter_common_rooster_total_width = 420px;
$easter_common_rooster_total_height = 417px;
$easter_common_rooster_image = 'easter_common_a.png';
$easter_common_rooster = 0px 0px 0px 0px 405px 296px 420px 417px 'easter_common_a.png' 'easter_common_rooster';
$spritesheet_width = 420px;
$spritesheet_height = 417px;
$spritesheet_image = 'easter_common_a.png';
$spritesheet_sprites = $easter_common_logo $easter_common_rooster;
$spritesheet = 420px 417px 'easter_common_a.png' $spritesheet_sprites;

/*
The provided mixins are intended to be used with the array-like variables

.icon-home {
  spriteWidth($icon_home)
}

.icon-email {
  sprite($icon_email)
}
*/
spriteWidth($sprite) {
  width: $sprite[4];
}

spriteHeight($sprite) {
  height: $sprite[5];
}

spritePosition($sprite) {
  background-position: $sprite[2] $sprite[3];
}

spriteImage($sprite) {
  background-image: url($sprite[8]);
}

sprite($sprite) {
  spriteImage($sprite)
  spritePosition($sprite)
  spriteWidth($sprite)
  spriteHeight($sprite)
}

/*
The `sprites` mixin generates identical output to the CSS template
  but can be overridden inside of Stylus

sprites($spritesheet_sprites);
*/
sprites($sprites) {
  for $sprite in $sprites {
    $sprite_name = $sprite[9];
    .{$sprite_name} {
      sprite($sprite);
    }
  }
}
