xmas_day()
  frontpageBanner()
  cdn-background-image '/images/banners/xmas/bg.jpg'
  background-position center top
  @media only screen and (max-width:767px)
    cdn-background-image '/images/banners/xmas/bg_mobile.jpg'
  &__promo_button_holder
    bottom 10px
  &_campaign
    width 480px
    text-align center
    margin-top 30px
    font-size 16px
    line-height 18px
    padding 160px 0 0 0
    margin 0 auto
    color #000
    @media only screen and (max-width:767px)
      width 320px
    &_content
      justify-content center
      align-items center
      display flex
      height 115px
    &_title
      display none
  &_image
    position absolute
    background-repeat no-repeat
    width 640px
    height 137px
    left 50%
    margin-left -320px
    top 18px
    @media only screen and (max-width:767px)
      width 320px
      height 69px
      margin-left -160px
      top 48px
  &_item1
    position absolute
    background-repeat no-repeat
    width 281px
    height 340px
    background-position center bottom
    background-repeat no-repeat
    right 5%
    bottom 0
    @media only screen and (max-width:1099px)
      right 0
    @media only screen and (max-width:767px)
      display none
