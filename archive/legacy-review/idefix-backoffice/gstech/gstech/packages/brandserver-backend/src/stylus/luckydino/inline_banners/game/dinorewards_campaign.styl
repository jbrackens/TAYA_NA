#banner_game_dinorewards_campaign
  bannerStyles()
  background-color #00c3da
  position relative
  width 266px
  height 370px
  margin-top 180px
  &__action
    position absolute
    top -180px
    left 0
    right 0
    width 266px
    height 180px
    background-size 266px 180px
    &_badge
      display none
  &__content
    position relative
    &_title
      color #ffffff
      position absolute
      text-align center
      right 0
      left 0
      top 92px
      font-weight 600
      font-size 12px
      z-index 100
      text-transform uppercase
    &_subtitle
      color #000000
      text-align center
      text-transform uppercase
      position absolute
      right 0
      left 0
      top 155px
      letter-spacing: -1px
      font-weight 700
      z-index 100
    &_subtitle2
      color #ffffff
      text-align center
      text-transform uppercase
      position absolute
      top 173px
      left 0
      right 0
      max-width 140px
      margin 0 auto
      font-weight 700
      font-size 22px
      line-height 20px
      z-index 100
    &_subtitle3
      color #FBFFA5
      text-align center
      text-transform uppercase
      position absolute
      right 0
      left 0
      top 212px
      font-size 14px
      font-weight 600
      z-index 100
  &__image
    position absolute
    z-index 10
    cdn_image '/banners/sidebar/rewards_bg.png' 266px 370px
    width 266px
    height 370px
  &__progress
    position absolute
    width 266px
    height 266px
    top 80px
    background-color #00c3da
  &__container1
    position absolute
    overflow hidden
    width 133px
    height 266px
    left 133px
    &_wedge
      background #ffffff
      height 266px
      width 133px
      left 0
      transform-origin: 0 133px
  &__container2
    position absolute
    overflow hidden
    width 133px
    height 266px
    &_wedge
      background #ffffff
      height 266px
      width 133px
      transform-origin 133px 133px

