/*
Stylus variables are information about icon's compiled state, stored under its original file name

.icon-home {
  width: $icon_home_width;
}

The large array-like variables contain all information about a single icon
$icon_home = x y offset_x offset_y width height total_width total_height image_path;

At the bottom of this section, we provide information about the spritesheet itself
$spritesheet = width height image $spritesheet_sprites;
*/
$rubyslippers_common_group_name = 'rubyslippers_common_group';
$rubyslippers_common_group_x = 278px;
$rubyslippers_common_group_y = 0px;
$rubyslippers_common_group_offset_x = -278px;
$rubyslippers_common_group_offset_y = 0px;
$rubyslippers_common_group_width = 255px;
$rubyslippers_common_group_height = 296px;
$rubyslippers_common_group_total_width = 533px;
$rubyslippers_common_group_total_height = 502px;
$rubyslippers_common_group_image = 'rubyslippers_common_b.png';
$rubyslippers_common_group = 278px 0px -278px 0px 255px 296px 533px 502px 'rubyslippers_common_b.png' 'rubyslippers_common_group';
$rubyslippers_common_logo_name = 'rubyslippers_common_logo';
$rubyslippers_common_logo_x = 0px;
$rubyslippers_common_logo_y = 300px;
$rubyslippers_common_logo_offset_x = 0px;
$rubyslippers_common_logo_offset_y = -300px;
$rubyslippers_common_logo_width = 250px;
$rubyslippers_common_logo_height = 202px;
$rubyslippers_common_logo_total_width = 533px;
$rubyslippers_common_logo_total_height = 502px;
$rubyslippers_common_logo_image = 'rubyslippers_common_b.png';
$rubyslippers_common_logo = 0px 300px 0px -300px 250px 202px 533px 502px 'rubyslippers_common_b.png' 'rubyslippers_common_logo';
$rubyslippers_common_wizard_name = 'rubyslippers_common_wizard';
