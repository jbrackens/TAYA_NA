/*
Stylus variables are information about icon's compiled state, stored under its original file name

.icon-home {
  width: $icon_home_width;
}

The large array-like variables contain all information about a single icon
$icon_home = x y offset_x offset_y width height total_width total_height image_path;

At the bottom of this section, we provide information about the spritesheet itself
$spritesheet = width height image $spritesheet_sprites;
*/
$evolution_common_logo_name = 'evolution_common_logo';
$evolution_common_logo_x = 0px;
$evolution_common_logo_y = 256px;
$evolution_common_logo_offset_x = 0px;
$evolution_common_logo_offset_y = -256px;
$evolution_common_logo_width = 420px;
$evolution_common_logo_height = 51px;
$evolution_common_logo_total_width = 492px;
$evolution_common_logo_total_height = 307px;
$evolution_common_logo_image = 'evolution_common_b.png';
$evolution_common_logo = 0px 256px 0px -256px 420px 51px 492px 307px 'evolution_common_b.png' 'evolution_common_logo';
$evolution_common_rat_name = 'evolution_common_rat';
$evolution_common_rat_x = 0px;
$evolution_common_rat_y = 0px;
$evolution_common_rat_offset_x = 0px;
$evolution_common_rat_offset_y = 0px;
$evolution_common_rat_width = 242px;
$evolution_common_rat_height = 252px;
$evolution_common_rat_total_width = 492px;
$evolution_common_rat_total_height = 307px;
$evolution_common_rat_image = 'evolution_common_b.png';
$evolution_common_rat = 0px 0px 0px 0px 242px 252px 492px 307px 'evolution_common_b.png' 'evolution_common_rat';
$evolution_common_weasel_name = 'evolution_common_weasel';
$evolution_common_weasel_x = 246px;
$evolution_common_weasel_y = 0px;
$evolution_common_weasel_offset_x = -246px;
$evolution_common_weasel_offset_y = 0px;
