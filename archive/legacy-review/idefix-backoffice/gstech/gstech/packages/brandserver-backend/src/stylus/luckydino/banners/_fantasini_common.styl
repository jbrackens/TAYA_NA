$fantasini_common_dagger_total_height = 404px;
$fantasini_common_dagger_image = 'fantasini_common_b.png';
$fantasini_common_dagger = 354px 0px -354px 0px 287px 263px 641px 404px 'fantasini_common_b.png' 'fantasini_common_dagger';
$fantasini_common_lady_name = 'fantasini_common_lady';
