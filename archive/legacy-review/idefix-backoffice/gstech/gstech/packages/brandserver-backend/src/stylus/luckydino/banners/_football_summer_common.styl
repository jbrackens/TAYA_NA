$football_summer_common_logo = 0px 298px 0px -298px 242px 205px 566px 503px 'football_summer_common_a.png' 'football_summer_common_logo';
$football_summer_common_rooster_name = 'football_summer_common_rooster';
$football_summer_common_rooster_x = 260px;
$football_summer_common_rooster_y = 0px;
