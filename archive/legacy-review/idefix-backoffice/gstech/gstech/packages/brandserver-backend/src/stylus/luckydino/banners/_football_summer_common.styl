$football_summer_common_felix_total_height = 503px;
$football_summer_common_felix_image = 'football_summer_common_a.png';
$football_summer_common_felix = 0px 0px 0px 0px 256px 294px 566px 503px 'football_summer_common_a.png' 'football_summer_common_felix';
$football_summer_common_logo_name = 'football_summer_common_logo';
$football_summer_common_logo_x = 0px;
$football_summer_common_logo_y = 298px;
