/*
Stylus variables are information about icon's compiled state, stored under its original file name

.icon-home {
  width: $icon_home_width;
}

The large array-like variables contain all information about a single icon
$icon_home = x y offset_x offset_y width height total_width total_height image_path;

At the bottom of this section, we provide information about the spritesheet itself
$spritesheet = width height image $spritesheet_sprites;
*/
$superweekend_eggomatic_no_logo_eggomatic_name = 'superweekend_eggomatic_no_logo_eggomatic';
$superweekend_eggomatic_no_logo_eggomatic_x = 0px;
$superweekend_eggomatic_no_logo_eggomatic_y = 0px;
$superweekend_eggomatic_no_logo_eggomatic_offset_x = 0px;
$superweekend_eggomatic_no_logo_eggomatic_offset_y = 0px;
$superweekend_eggomatic_no_logo_eggomatic_width = 465px;
$superweekend_eggomatic_no_logo_eggomatic_height = 113px;
$superweekend_eggomatic_no_logo_eggomatic_total_width = 465px;
$superweekend_eggomatic_no_logo_eggomatic_total_height = 113px;
$superweekend_eggomatic_no_logo_eggomatic_image = 'superweekend_eggomatic_no_a.png';
$superweekend_eggomatic_no_logo_eggomatic = 0px 0px 0px 0px 465px 113px 465px 113px 'superweekend_eggomatic_no_a.png' 'superweekend_eggomatic_no_logo_eggomatic';
$spritesheet_width = 465px;
$spritesheet_height = 113px;
$spritesheet_image = 'superweekend_eggomatic_no_a.png';
$spritesheet_sprites = $superweekend_eggomatic_no_logo_eggomatic;
$spritesheet = 465px 113px 'superweekend_eggomatic_no_a.png' $spritesheet_sprites;

/*
The provided mixins are intended to be used with the array-like variables

.icon-home {
  spriteWidth($icon_home)
}

.icon-email {
  sprite($icon_email)
}
*/
spriteWidth($sprite) {
  width: $sprite[4];
}

spriteHeight($sprite) {
  height: $sprite[5];
}

spritePosition($sprite) {
  background-position: $sprite[2] $sprite[3];
}

spriteImage($sprite) {
  background-image: url($sprite[8]);
}

sprite($sprite) {
  spriteImage($sprite)
  spritePosition($sprite)
  spriteWidth($sprite)
  spriteHeight($sprite)
}

/*
The `sprites` mixin generates identical output to the CSS template
  but can be overridden inside of Stylus

sprites($spritesheet_sprites);
*/
sprites($sprites) {
  for $sprite in $sprites {
    $sprite_name = $sprite[9];
    .{$sprite_name} {
      sprite($sprite);
    }
  }
}
