/*
Stylus variables are information about icon's compiled state, stored under its original file name

.icon-home {
  width: $icon_home_width;
}

The large array-like variables contain all information about a single icon
$icon_home = x y offset_x offset_y width height total_width total_height image_path;

At the bottom of this section, we provide information about the spritesheet itself
$spritesheet = width height image $spritesheet_sprites;
*/
$copycat_common_cat_l_name = 'copycat_common_cat_l';
$copycat_common_cat_l_x = 0px;
$copycat_common_cat_l_y = 162px;
$copycat_common_cat_l_offset_x = 0px;
$copycat_common_cat_l_offset_y = -162px;
$copycat_common_cat_l_width = 183px;
$copycat_common_cat_l_height = 166px;
$copycat_common_cat_l_total_width = 550px;
$copycat_common_cat_l_total_height = 328px;
$copycat_common_cat_l_image = 'copycat_common_b.png';
$copycat_common_cat_l = 0px 162px 0px -162px 183px 166px 550px 328px 'copycat_common_b.png' 'copycat_common_cat_l';
$copycat_common_cat_r_name = 'copycat_common_cat_r';
$copycat_common_cat_r_x = 187px;
$copycat_common_cat_r_y = 162px;
$copycat_common_cat_r_offset_x = -187px;
$copycat_common_cat_r_offset_y = -162px;
$copycat_common_cat_r_width = 169px;
$copycat_common_cat_r_height = 141px;
$copycat_common_cat_r_total_width = 550px;
$copycat_common_cat_r_total_height = 328px;
$copycat_common_cat_r_image = 'copycat_common_b.png';
$copycat_common_cat_r = 187px 162px -187px -162px 169px 141px 550px 328px 'copycat_common_b.png' 'copycat_common_cat_r';
$copycat_common_logo_name = 'copycat_common_logo';
$copycat_common_logo_x = 0px;
$copycat_common_logo_y = 0px;
$copycat_common_logo_offset_x = 0px;
$copycat_common_logo_offset_y = 0px;
$copycat_common_logo_width = 550px;
