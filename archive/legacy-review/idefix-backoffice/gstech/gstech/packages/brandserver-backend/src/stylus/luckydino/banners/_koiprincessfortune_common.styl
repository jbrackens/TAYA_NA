/*
Stylus variables are information about icon's compiled state, stored under its original file name

.icon-home {
  width: $icon_home_width;
}

The large array-like variables contain all information about a single icon
$icon_home = x y offset_x offset_y width height total_width total_height image_path;

At the bottom of this section, we provide information about the spritesheet itself
$spritesheet = width height image $spritesheet_sprites;
*/
$koiprincessfortune_common_logo_name = 'koiprincessfortune_common_logo';
$koiprincessfortune_common_logo_x = 0px;
$koiprincessfortune_common_logo_y = 301px;
$koiprincessfortune_common_logo_offset_x = 0px;
$koiprincessfortune_common_logo_offset_y = -301px;
$koiprincessfortune_common_logo_width = 320px;
$koiprincessfortune_common_logo_height = 116px;
$koiprincessfortune_common_logo_total_width = 320px;
$koiprincessfortune_common_logo_total_height = 417px;
$koiprincessfortune_common_logo_image = 'koiprincessfortune_common_a.png';
$koiprincessfortune_common_logo = 0px 301px 0px -301px 320px 116px 320px 417px 'koiprincessfortune_common_a.png' 'koiprincessfortune_common_logo';
$koiprincessfortune_common_princess_name = 'koiprincessfortune_common_princess';
$koiprincessfortune_common_princess_x = 0px;
$koiprincessfortune_common_princess_y = 0px;
$koiprincessfortune_common_princess_offset_x = 0px;
$koiprincessfortune_common_princess_offset_y = 0px;
$koiprincessfortune_common_princess_width = 304px;
$koiprincessfortune_common_princess_height = 297px;
$koiprincessfortune_common_princess_total_width = 320px;
$koiprincessfortune_common_princess_total_height = 417px;
$koiprincessfortune_common_princess_image = 'koiprincessfortune_common_a.png';
$koiprincessfortune_common_princess = 0px 0px 0px 0px 304px 297px 320px 417px 'koiprincessfortune_common_a.png' 'koiprincessfortune_common_princess';
$spritesheet_width = 320px;
$spritesheet_height = 417px;
$spritesheet_image = 'koiprincessfortune_common_a.png';
$spritesheet_sprites = $koiprincessfortune_common_logo $koiprincessfortune_common_princess;
$spritesheet = 320px 417px 'koiprincessfortune_common_a.png' $spritesheet_sprites;

/*
The provided mixins are intended to be used with the array-like variables

.icon-home {
  spriteWidth($icon_home)
}

.icon-email {
  sprite($icon_email)
}
*/
spriteWidth($sprite) {
  width: $sprite[4];
}

spriteHeight($sprite) {
  height: $sprite[5];
}

spritePosition($sprite) {
  background-position: $sprite[2] $sprite[3];
}

spriteImage($sprite) {
  background-image: url($sprite[8]);
}

sprite($sprite) {
  spriteImage($sprite)
  spritePosition($sprite)
  spriteWidth($sprite)
  spriteHeight($sprite)
}

/*
The `sprites` mixin generates identical output to the CSS template
  but can be overridden inside of Stylus

sprites($spritesheet_sprites);
*/
sprites($sprites) {
  for $sprite in $sprites {
    $sprite_name = $sprite[9];
    .{$sprite_name} {
      sprite($sprite);
    }
  }
}
