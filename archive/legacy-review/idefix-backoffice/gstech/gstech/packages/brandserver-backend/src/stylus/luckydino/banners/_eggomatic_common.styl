/*
Stylus variables are information about icon's compiled state, stored under its original file name

.icon-home {
  width: $icon_home_width;
}

The large array-like variables contain all information about a single icon
$icon_home = x y offset_x offset_y width height total_width total_height image_path;

At the bottom of this section, we provide information about the spritesheet itself
$spritesheet = width height image $spritesheet_sprites;
*/
$eggomatic_common_eggomatic_name = 'eggomatic_common_eggomatic';
$eggomatic_common_eggomatic_x = 0px;
$eggomatic_common_eggomatic_y = 344px;
$eggomatic_common_eggomatic_offset_x = 0px;
$eggomatic_common_eggomatic_offset_y = -344px;
$eggomatic_common_eggomatic_width = 190px;
$eggomatic_common_eggomatic_height = 296px;
$eggomatic_common_eggomatic_total_width = 750px;
$eggomatic_common_eggomatic_total_height = 640px;
$eggomatic_common_eggomatic_image = 'eggomatic_common_b.png';
$eggomatic_common_eggomatic = 0px 344px 0px -344px 190px 296px 750px 640px 'eggomatic_common_b.png' 'eggomatic_common_eggomatic';
$eggomatic_common_logo_name = 'eggomatic_common_logo';
$eggomatic_common_logo_x = 330px;
$eggomatic_common_logo_y = 0px;
$eggomatic_common_logo_offset_x = -330px;
$eggomatic_common_logo_offset_y = 0px;
$eggomatic_common_logo_width = 420px;
$eggomatic_common_logo_height = 154px;
$eggomatic_common_logo_total_width = 750px;
$eggomatic_common_logo_total_height = 640px;
$eggomatic_common_logo_image = 'eggomatic_common_b.png';
$eggomatic_common_logo = 330px 0px -330px 0px 420px 154px 750px 640px 'eggomatic_common_b.png' 'eggomatic_common_logo';
$eggomatic_common_rooster_name = 'eggomatic_common_rooster';
$eggomatic_common_rooster_x = 0px;
$eggomatic_common_rooster_y = 0px;
$eggomatic_common_rooster_offset_x = 0px;
$eggomatic_common_rooster_offset_y = 0px;
