/*
Stylus variables are information about icon's compiled state, stored under its original file name

.icon-home {
  width: $icon_home_width;
}

The large array-like variables contain all information about a single icon
$icon_home = x y offset_x offset_y width height total_width total_height image_path;

At the bottom of this section, we provide information about the spritesheet itself
$spritesheet = width height image $spritesheet_sprites;
*/
$shangrila_common_medium_logo_name = 'shangrila_common_medium_logo';
$shangrila_common_medium_logo_x = 277px;
$shangrila_common_medium_logo_y = 0px;
$shangrila_common_medium_logo_offset_x = -277px;
$shangrila_common_medium_logo_offset_y = 0px;
$shangrila_common_medium_logo_width = 420px;
$shangrila_common_medium_logo_height = 154px;
$shangrila_common_medium_logo_total_width = 697px;
$shangrila_common_medium_logo_total_height = 300px;
$shangrila_common_medium_logo_image = 'shangrila_common_medium_b.png';
$shangrila_common_medium_logo = 277px 0px -277px 0px 420px 154px 697px 300px 'shangrila_common_medium_b.png' 'shangrila_common_medium_logo';
$shangrila_common_medium_monk_name = 'shangrila_common_medium_monk';
$shangrila_common_medium_monk_x = 0px;
$shangrila_common_medium_monk_y = 0px;
$shangrila_common_medium_monk_offset_x = 0px;
$shangrila_common_medium_monk_offset_y = 0px;
$shangrila_common_medium_monk_width = 273px;
$shangrila_common_medium_monk_height = 300px;
$shangrila_common_medium_monk_total_width = 697px;
$shangrila_common_medium_monk_total_height = 300px;
$shangrila_common_medium_monk_image = 'shangrila_common_medium_b.png';
$shangrila_common_medium_monk = 0px 0px 0px 0px 273px 300px 697px 300px 'shangrila_common_medium_b.png' 'shangrila_common_medium_monk';
$spritesheet_width = 697px;
$spritesheet_height = 300px;
$spritesheet_image = 'shangrila_common_medium_b.png';
$spritesheet_sprites = $shangrila_common_medium_logo $shangrila_common_medium_monk;
$spritesheet = 697px 300px 'shangrila_common_medium_b.png' $spritesheet_sprites;

/*
The provided mixins are intended to be used with the array-like variables

.icon-home {
  spriteWidth($icon_home)
}

.icon-email {
  sprite($icon_email)
}

Example usage in HTML:

`display: block` sprite:
<div class="icon-home"></div>

To change `display` (e.g. `display: inline-block;`), we suggest using a common CSS class:

// CSS
.icon {
  display: inline-block;
}

// HTML
<i class="icon icon-home"></i>
*/
spriteWidth($sprite) {
  width: $sprite[4];
}

spriteHeight($sprite) {
  height: $sprite[5];
}

spritePosition($sprite) {
  background-position: $sprite[2] $sprite[3];
}

spriteImage($sprite) {
  background-image: url($sprite[8]);
}

sprite($sprite) {
  spriteImage($sprite)
  spritePosition($sprite)
  spriteWidth($sprite)
  spriteHeight($sprite)
}

/*
The `sprites` mixin generates identical output to the CSS template
  but can be overridden inside of Stylus

This must be run when you have at least 2 sprites.
  If run with a single sprite, then there will be reference errors.

sprites($spritesheet_sprites);
*/
sprites($sprites) {
  for $sprite in $sprites {
    $sprite_name = $sprite[9];
    .{$sprite_name} {
      sprite($sprite);
    }
  }
}
