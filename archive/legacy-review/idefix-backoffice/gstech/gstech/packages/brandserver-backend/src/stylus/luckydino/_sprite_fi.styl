/*
Stylus variables are information about icon's compiled state, stored under its original file name

.icon-home {
  width: $icon_home_width;
}

The large array-like variables contain all information about a single icon
$icon_home = x y offset_x offset_y width height total_width total_height image_path;

At the bottom of this section, we provide information about the spritesheet itself
$spritesheet = width height image $spritesheet_sprites;
*/
$fi-hide-info_name = 'fi-hide-info';
$fi-hide-info_x = 0px;
$fi-hide-info_y = 0px;
$fi-hide-info_offset_x = 0px;
$fi-hide-info_offset_y = 0px;
$fi-hide-info_width = 12px;
$fi-hide-info_height = 40px;
$fi-hide-info_total_width = 75px;
$fi-hide-info_total_height = 163px;
$fi-hide-info_image = 'sprite_fi.png';
$fi-hide-info = 0px 0px 0px 0px 12px 40px 75px 163px 'sprite_fi.png' 'fi-hide-info';
$fi-new-badge_name = 'fi-new-badge';
$fi-new-badge_x = 0px;
$fi-new-badge_y = 88px;
$fi-new-badge_offset_x = 0px;
$fi-new-badge_offset_y = -88px;
$fi-new-badge_width = 75px;
$fi-new-badge_height = 75px;
$fi-new-badge_total_width = 75px;
$fi-new-badge_total_height = 163px;
$fi-new-badge_image = 'sprite_fi.png';
$fi-new-badge = 0px 88px 0px -88px 75px 75px 75px 163px 'sprite_fi.png' 'fi-new-badge';
$fi-show-info_name = 'fi-show-info';
$fi-show-info_x = 0px;
$fi-show-info_y = 44px;
$fi-show-info_offset_x = 0px;
$fi-show-info_offset_y = -44px;
$fi-show-info_width = 12px;
$fi-show-info_height = 40px;
$fi-show-info_total_width = 75px;
$fi-show-info_total_height = 163px;
$fi-show-info_image = 'sprite_fi.png';
$fi-show-info = 0px 44px 0px -44px 12px 40px 75px 163px 'sprite_fi.png' 'fi-show-info';
$spritesheet_width = 75px;
$spritesheet_height = 163px;
$spritesheet_image = 'sprite_fi.png';
$spritesheet_sprites = $fi-hide-info $fi-new-badge $fi-show-info;
$spritesheet = 75px 163px 'sprite_fi.png' $spritesheet_sprites;

/*
The provided mixins are intended to be used with the array-like variables

.icon-home {
  spriteWidth($icon_home)
}

.icon-email {
  sprite($icon_email)
}
*/
spriteWidth($sprite) {
  width: $sprite[4];
}

spriteHeight($sprite) {
  height: $sprite[5];
}

spritePosition($sprite) {
  background-position: $sprite[2] $sprite[3];
}

spriteImage($sprite) {
  background-image: url($sprite[8]);
}

sprite($sprite) {
  spriteImage($sprite)
  spritePosition($sprite)
  spriteWidth($sprite)
  spriteHeight($sprite)
}

/*
The `sprites` mixin generates identical output to the CSS template
  but can be overridden inside of Stylus

sprites($spritesheet_sprites);
*/
sprites($sprites) {
  for $sprite in $sprites {
    $sprite_name = $sprite[9];
    .{$sprite_name} {
      sprite($sprite);
    }
  }
}
