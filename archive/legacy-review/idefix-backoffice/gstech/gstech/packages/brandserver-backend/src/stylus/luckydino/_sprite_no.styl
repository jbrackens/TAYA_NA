/*
Stylus variables are information about icon's compiled state, stored under its original file name

.icon-home {
  width: $icon_home_width;
}

The large array-like variables contain all information about a single icon
$icon_home = x y offset_x offset_y width height total_width total_height image_path;

At the bottom of this section, we provide information about the spritesheet itself
$spritesheet = width height image $spritesheet_sprites;
*/
$no-hide-info_name = 'no-hide-info';
$no-hide-info_x = 0px;
$no-hide-info_y = 0px;
$no-hide-info_offset_x = 0px;
$no-hide-info_offset_y = 0px;
$no-hide-info_width = 9px;
$no-hide-info_height = 62px;
$no-hide-info_total_width = 75px;
$no-hide-info_total_height = 207px;
$no-hide-info_image = 'sprite_no.png';
$no-hide-info = 0px 0px 0px 0px 9px 62px 75px 207px 'sprite_no.png' 'no-hide-info';
$no-new-badge_name = 'no-new-badge';
$no-new-badge_x = 0px;
$no-new-badge_y = 132px;
$no-new-badge_offset_x = 0px;
$no-new-badge_offset_y = -132px;
$no-new-badge_width = 75px;
$no-new-badge_height = 75px;
$no-new-badge_total_width = 75px;
$no-new-badge_total_height = 207px;
$no-new-badge_image = 'sprite_no.png';
$no-new-badge = 0px 132px 0px -132px 75px 75px 75px 207px 'sprite_no.png' 'no-new-badge';
$no-show-info_name = 'no-show-info';
$no-show-info_x = 0px;
$no-show-info_y = 66px;
$no-show-info_offset_x = 0px;
$no-show-info_offset_y = -66px;
$no-show-info_width = 9px;
$no-show-info_height = 62px;
$no-show-info_total_width = 75px;
$no-show-info_total_height = 207px;
$no-show-info_image = 'sprite_no.png';
$no-show-info = 0px 66px 0px -66px 9px 62px 75px 207px 'sprite_no.png' 'no-show-info';
$spritesheet_width = 75px;
$spritesheet_height = 207px;
$spritesheet_image = 'sprite_no.png';
$spritesheet_sprites = $no-hide-info $no-new-badge $no-show-info;
$spritesheet = 75px 207px 'sprite_no.png' $spritesheet_sprites;

/*
The provided mixins are intended to be used with the array-like variables

.icon-home {
  spriteWidth($icon_home)
}

.icon-email {
  sprite($icon_email)
}
*/
spriteWidth($sprite) {
  width: $sprite[4];
}

spriteHeight($sprite) {
  height: $sprite[5];
}

spritePosition($sprite) {
  background-position: $sprite[2] $sprite[3];
}

spriteImage($sprite) {
  background-image: url($sprite[8]);
}

sprite($sprite) {
  spriteImage($sprite)
  spritePosition($sprite)
  spriteWidth($sprite)
  spriteHeight($sprite)
}

/*
The `sprites` mixin generates identical output to the CSS template
  but can be overridden inside of Stylus

sprites($spritesheet_sprites);
*/
sprites($sprites) {
  for $sprite in $sprites {
    $sprite_name = $sprite[9];
    .{$sprite_name} {
      sprite($sprite);
    }
  }
}
