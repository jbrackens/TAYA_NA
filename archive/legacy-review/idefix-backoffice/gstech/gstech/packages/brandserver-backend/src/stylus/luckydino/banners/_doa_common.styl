/*
Stylus variables are information about icon's compiled state, stored under its original file name

.icon-home {
  width: $icon_home_width;
}

The large array-like variables contain all information about a single icon
$icon_home = x y offset_x offset_y width height total_width total_height image_path;

At the bottom of this section, we provide information about the spritesheet itself
$spritesheet = width height image $spritesheet_sprites;
*/
$doa_common_jesse_name = 'doa_common_jesse';
$doa_common_jesse_x = 0px;
$doa_common_jesse_y = 0px;
$doa_common_jesse_offset_x = 0px;
$doa_common_jesse_offset_y = 0px;
$doa_common_jesse_width = 236px;
$doa_common_jesse_height = 297px;
$doa_common_jesse_total_width = 505px;
$doa_common_jesse_total_height = 297px;
$doa_common_jesse_image = 'doa_common_b.png';
$doa_common_jesse = 0px 0px 0px 0px 236px 297px 505px 297px 'doa_common_b.png' 'doa_common_jesse';
$doa_common_logo_name = 'doa_common_logo';
$doa_common_logo_x = 240px;
$doa_common_logo_y = 0px;
$doa_common_logo_offset_x = -240px;
$doa_common_logo_offset_y = 0px;
$doa_common_logo_width = 265px;
$doa_common_logo_height = 140px;
$doa_common_logo_total_width = 505px;
$doa_common_logo_total_height = 297px;
$doa_common_logo_image = 'doa_common_b.png';
$doa_common_logo = 240px 0px -240px 0px 265px 140px 505px 297px 'doa_common_b.png' 'doa_common_logo';
$spritesheet_width = 505px;
$spritesheet_height = 297px;
$spritesheet_image = 'doa_common_b.png';
$spritesheet_sprites = $doa_common_jesse $doa_common_logo;
$spritesheet = 505px 297px 'doa_common_b.png' $spritesheet_sprites;

/*
The provided mixins are intended to be used with the array-like variables

.icon-home {
  spriteWidth($icon_home)
}

.icon-email {
  sprite($icon_email)
}

Example usage in HTML:

`display: block` sprite:
<div class="icon-home"></div>

To change `display` (e.g. `display: inline-block;`), we suggest using a common CSS class:

// CSS
.icon {
  display: inline-block;
}

// HTML
<i class="icon icon-home"></i>
*/
spriteWidth($sprite) {
  width: $sprite[4];
}

spriteHeight($sprite) {
  height: $sprite[5];
}

spritePosition($sprite) {
  background-position: $sprite[2] $sprite[3];
}

spriteImage($sprite) {
  background-image: url($sprite[8]);
}

sprite($sprite) {
  spriteImage($sprite)
  spritePosition($sprite)
  spriteWidth($sprite)
  spriteHeight($sprite)
}

/*
The `sprites` mixin generates identical output to the CSS template
  but can be overridden inside of Stylus

This must be run when you have at least 2 sprites.
  If run with a single sprite, then there will be reference errors.

sprites($spritesheet_sprites);
*/
sprites($sprites) {
  for $sprite in $sprites {
    $sprite_name = $sprite[9];
    .{$sprite_name} {
      sprite($sprite);
    }
  }
}
