/*
Stylus variables are information about icon's compiled state, stored under its original file name

.icon-home {
  width: $icon_home_width;
}

The large array-like variables contain all information about a single icon
$icon_home = x y offset_x offset_y width height total_width total_height image_path;

At the bottom of this section, we provide information about the spritesheet itself
$spritesheet = width height image $spritesheet_sprites;
*/
$playboy_common_mobile_bunny_name = 'playboy_common_mobile_bunny';
$playboy_common_mobile_bunny_x = 0px;
$playboy_common_mobile_bunny_y = 0px;
$playboy_common_mobile_bunny_offset_x = 0px;
$playboy_common_mobile_bunny_offset_y = 0px;
$playboy_common_mobile_bunny_width = 180px;
$playboy_common_mobile_bunny_height = 211px;
$playboy_common_mobile_bunny_total_width = 504px;
$playboy_common_mobile_bunny_total_height = 211px;
$playboy_common_mobile_bunny_image = 'playboy_common_mobile_b.png';
$playboy_common_mobile_bunny = 0px 0px 0px 0px 180px 211px 504px 211px 'playboy_common_mobile_b.png' 'playboy_common_mobile_bunny';
$playboy_common_mobile_logo_name = 'playboy_common_mobile_logo';
$playboy_common_mobile_logo_x = 184px;
$playboy_common_mobile_logo_y = 0px;
$playboy_common_mobile_logo_offset_x = -184px;
$playboy_common_mobile_logo_offset_y = 0px;
$playboy_common_mobile_logo_width = 320px;
$playboy_common_mobile_logo_height = 78px;
$playboy_common_mobile_logo_total_width = 504px;
$playboy_common_mobile_logo_total_height = 211px;
$playboy_common_mobile_logo_image = 'playboy_common_mobile_b.png';
$playboy_common_mobile_logo = 184px 0px -184px 0px 320px 78px 504px 211px 'playboy_common_mobile_b.png' 'playboy_common_mobile_logo';
$spritesheet_width = 504px;
$spritesheet_height = 211px;
$spritesheet_image = 'playboy_common_mobile_b.png';
$spritesheet_sprites = $playboy_common_mobile_bunny $playboy_common_mobile_logo;
$spritesheet = 504px 211px 'playboy_common_mobile_b.png' $spritesheet_sprites;

/*
The provided mixins are intended to be used with the array-like variables

.icon-home {
  spriteWidth($icon_home)
}

.icon-email {
  sprite($icon_email)
}

Example usage in HTML:

`display: block` sprite:
<div class="icon-home"></div>

To change `display` (e.g. `display: inline-block;`), we suggest using a common CSS class:

// CSS
.icon {
  display: inline-block;
}

// HTML
<i class="icon icon-home"></i>
*/
spriteWidth($sprite) {
  width: $sprite[4];
}

spriteHeight($sprite) {
  height: $sprite[5];
}

spritePosition($sprite) {
  background-position: $sprite[2] $sprite[3];
}

spriteImage($sprite) {
  background-image: url($sprite[8]);
}

sprite($sprite) {
  spriteImage($sprite)
  spritePosition($sprite)
  spriteWidth($sprite)
  spriteHeight($sprite)
}

/*
The `sprites` mixin generates identical output to the CSS template
  but can be overridden inside of Stylus

This must be run when you have at least 2 sprites.
  If run with a single sprite, then there will be reference errors.

sprites($spritesheet_sprites);
*/
sprites($sprites) {
  for $sprite in $sprites {
    $sprite_name = $sprite[9];
    .{$sprite_name} {
      sprite($sprite);
    }
  }
}
