/*
Stylus variables are information about icon's compiled state, stored under its original file name

.icon-home {
  width: $icon_home_width;
}

The large array-like variables contain all information about a single icon
$icon_home = x y offset_x offset_y width height total_width total_height image_path;

At the bottom of this section, we provide information about the spritesheet itself
$spritesheet = width height image $spritesheet_sprites;
*/
$lights_common_lanterns_left_name = 'lights_common_lanterns_left';
$lights_common_lanterns_left_x = 284px;
$lights_common_lanterns_left_y = 0px;
$lights_common_lanterns_left_offset_x = -284px;
$lights_common_lanterns_left_offset_y = 0px;
$lights_common_lanterns_left_width = 193px;
$lights_common_lanterns_left_height = 265px;
$lights_common_lanterns_left_total_width = 477px;
$lights_common_lanterns_left_total_height = 340px;
$lights_common_lanterns_left_image = 'lights_common_b.png';
$lights_common_lanterns_left = 284px 0px -284px 0px 193px 265px 477px 340px 'lights_common_b.png' 'lights_common_lanterns_left';
$lights_common_lanterns_right_name = 'lights_common_lanterns_right';
$lights_common_lanterns_right_x = 0px;
$lights_common_lanterns_right_y = 0px;
$lights_common_lanterns_right_offset_x = 0px;
$lights_common_lanterns_right_offset_y = 0px;
$lights_common_lanterns_right_width = 280px;
$lights_common_lanterns_right_height = 271px;
$lights_common_lanterns_right_total_width = 477px;
$lights_common_lanterns_right_total_height = 340px;
$lights_common_lanterns_right_image = 'lights_common_b.png';
$lights_common_lanterns_right = 0px 0px 0px 0px 280px 271px 477px 340px 'lights_common_b.png' 'lights_common_lanterns_right';
$lights_common_logo_name = 'lights_common_logo';
$lights_common_logo_x = 0px;
$lights_common_logo_y = 275px;
$lights_common_logo_offset_x = 0px;
$lights_common_logo_offset_y = -275px;
$lights_common_logo_width = 320px;
$lights_common_logo_height = 65px;
$lights_common_logo_total_width = 477px;
$lights_common_logo_total_height = 340px;
$lights_common_logo_image = 'lights_common_b.png';
$lights_common_logo = 0px 275px 0px -275px 320px 65px 477px 340px 'lights_common_b.png' 'lights_common_logo';
$spritesheet_width = 477px;
$spritesheet_height = 340px;
$spritesheet_image = 'lights_common_b.png';
$spritesheet_sprites = $lights_common_lanterns_left $lights_common_lanterns_right $lights_common_logo;
$spritesheet = 477px 340px 'lights_common_b.png' $spritesheet_sprites;

/*
The provided mixins are intended to be used with the array-like variables

.icon-home {
  spriteWidth($icon_home)
}

.icon-email {
  sprite($icon_email)
}

Example usage in HTML:

`display: block` sprite:
<div class="icon-home"></div>

To change `display` (e.g. `display: inline-block;`), we suggest using a common CSS class:

// CSS
.icon {
  display: inline-block;
}

// HTML
<i class="icon icon-home"></i>
*/
spriteWidth($sprite) {
  width: $sprite[4];
}

spriteHeight($sprite) {
  height: $sprite[5];
}

spritePosition($sprite) {
  background-position: $sprite[2] $sprite[3];
}

spriteImage($sprite) {
  background-image: url($sprite[8]);
}

sprite($sprite) {
  spriteImage($sprite)
  spritePosition($sprite)
  spriteWidth($sprite)
  spriteHeight($sprite)
}

/*
The `sprites` mixin generates identical output to the CSS template
  but can be overridden inside of Stylus

This must be run when you have at least 2 sprites.
  If run with a single sprite, then there will be reference errors.

sprites($spritesheet_sprites);
*/
sprites($sprites) {
  for $sprite in $sprites {
    $sprite_name = $sprite[9];
    .{$sprite_name} {
      sprite($sprite);
    }
  }
}
