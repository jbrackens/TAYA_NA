#banner_nonloggedin_welcomeoffer
  &.lang-fi, &.lang-de, &.lang-no
    .campaign h3
      font-size 70px
      line-height 70px
      margin-top 40px
      @media only screen and (max-width:550px)
        margin-top 60px
        font-size 52px
        line-height 52px
      @media only screen and (max-width:420px)
        font-size 22px
        line-height 22px

  frontpageBanner()
  height 345px
  .background
    position absolute
    left 50%
    margin-left -960px
    width 1920px
    height 345px
    background-color #9ee1ff
    cdn-background-image: '/banners/notloggedin/bg.jpg'
    .viewport
      height 345px
      .item1
        cdn-background-image: '/banners/notloggedin/alfredo.png'
        width 450px
        height 345px
        position absolute
        bottom 0
        right 10%
        @media only screen and (max-width:1099px)
          right 240px
        @media only screen and (max-width:865px)
          display none
  .campaign
    position absolute
    margin 0 auto
    max-width 520px
    .button-holder
      width 100%
      text-align center
      position absolute
      bottom 20px
    .button
      background-color #e94c00
      padding 12px 24px
    h3
      color #3f3f3f
      font-size 95px
      line-height 100px
      font-weight 700
      text-transform uppercase
      font-family 'Titillium Web', sans-serif
      @media only screen and (max-width:767px)
        font-size 80px
        line-height 80px
    h1
      font-size 26px
      line-height 38px
      color #0089b3
      text-transform uppercase
      @media only screen and (max-width:767px)
        font-size 18px
        line-height 18px

#banner_game_nonloggedin
  .buttons
    right 0
    left auto !important

#banner_game_nonloggedin
  #banner_nonloggedin_welcomeoffer
    height 640px
    position relative
    .background
      position absolute
      width 240px
      height 640px
      background-color #9ee1ff
      cdn-background-image: '/banners/notloggedin/bg_sidebar.jpg'
      .viewport
        height 640px
        .item1
          cdn-background-image: '/banners/notloggedin/alfredo_sidebar.png'
          width 245px
          height 487px
          position absolute
          bottom 0
          left 0
          right 0
    &.lang-fi, &.lang-de, &.lang-no
      .campaign h3
        font-size 28px
        line-height 28px

    .campaign
      text-align center
      position absolute
      margin 0 auto
      max-width 520px
      top 200px
      .button-holder
        width 100%
        text-align center
        position absolute
        bottom auto
        margin-top 5px
      .button
        background-color #e94c00
        padding 12px 24px
      h3
        color #3f3f3f
        font-size 45px
        line-height 45px
        font-weight 700
        text-transform uppercase
        font-family 'Titillium Web', sans-serif
        @media only screen and (max-width:767px)
          font-size 35px
          line-height 35px
      h1
        font-size 14px
        line-height 16px
        color #0089b3
        text-transform uppercase
        max-width 180px
        margin 0 auto
