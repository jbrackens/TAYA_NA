$booonanza_common_logo_total_width = 759px;
$booonanza_common_logo_total_height = 584px;
$booonanza_common_logo_image = 'booonanza_common_a.png';
$booonanza_common_logo = 379px 0px -379px 0px 380px 223px 759px 584px 'booonanza_common_a.png' 'booonanza_common_logo';
$booonanza_common_vampirella_name = 'booonanza_common_vampirella';
$booonanza_common_vampirella_x = 0px;
$booonanza_common_vampirella_y = 0px;
