/*
Stylus variables are information about icon's compiled state, stored under its original file name

.icon-home {
  width: $icon_home_width;
}

The large array-like variables contain all information about a single icon
$icon_home = x y offset_x offset_y width height total_width total_height image_path;

At the bottom of this section, we provide information about the spritesheet itself
$spritesheet = width height image $spritesheet_sprites;
*/
$booonanza_common_draculino_name = 'booonanza_common_draculino';
$booonanza_common_draculino_x = 0px;
$booonanza_common_draculino_y = 304px;
$booonanza_common_draculino_offset_x = 0px;
$booonanza_common_draculino_offset_y = -304px;
$booonanza_common_draculino_width = 362px;
$booonanza_common_draculino_height = 280px;
$booonanza_common_draculino_total_width = 759px;
$booonanza_common_draculino_total_height = 584px;
$booonanza_common_draculino_image = 'booonanza_common_a.png';
$booonanza_common_draculino = 0px 304px 0px -304px 362px 280px 759px 584px 'booonanza_common_a.png' 'booonanza_common_draculino';
$booonanza_common_logo_name = 'booonanza_common_logo';
