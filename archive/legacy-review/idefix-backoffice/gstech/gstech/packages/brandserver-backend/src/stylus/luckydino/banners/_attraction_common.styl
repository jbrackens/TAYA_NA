/*
Stylus variables are information about icon's compiled state, stored under its original file name

.icon-home {
  width: $icon_home_width;
}

The large array-like variables contain all information about a single icon
$icon_home = x y offset_x offset_y width height total_width total_height image_path;

At the bottom of this section, we provide information about the spritesheet itself
$spritesheet = width height image $spritesheet_sprites;
*/
$attraction_common_icon_name = 'attraction_common_icon';
$attraction_common_icon_x = 219px;
$attraction_common_icon_y = 87px;
$attraction_common_icon_offset_x = -219px;
$attraction_common_icon_offset_y = -87px;
$attraction_common_icon_width = 224px;
$attraction_common_icon_height = 207px;
$attraction_common_icon_total_width = 600px;
$attraction_common_icon_total_height = 315px;
$attraction_common_icon_image = 'attraction_common_b.png';
$attraction_common_icon = 219px 87px -219px -87px 224px 207px 600px 315px 'attraction_common_b.png' 'attraction_common_icon';
$attraction_common_icon2_name = 'attraction_common_icon2';
$attraction_common_icon2_x = 0px;
$attraction_common_icon2_y = 87px;
$attraction_common_icon2_offset_x = 0px;
$attraction_common_icon2_offset_y = -87px;
$attraction_common_icon2_width = 215px;
$attraction_common_icon2_height = 228px;
$attraction_common_icon2_total_width = 600px;
$attraction_common_icon2_total_height = 315px;
$attraction_common_icon2_image = 'attraction_common_b.png';
$attraction_common_icon2 = 0px 87px 0px -87px 215px 228px 600px 315px 'attraction_common_b.png' 'attraction_common_icon2';
$attraction_common_logo_name = 'attraction_common_logo';
$attraction_common_logo_x = 0px;
$attraction_common_logo_y = 0px;
$attraction_common_logo_offset_x = 0px;
$attraction_common_logo_offset_y = 0px;
