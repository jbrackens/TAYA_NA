{
  "name": "gstech-backend",
  "version": "2.7.1",
  "private": true,
  "scripts": {
    "bootstrap": "yarn link gstech-core",
    "pretty": "prettier -c '**/*.js'",
    "start": "KAFKA_ENABLED=true nodemon -r 'flow-remove-types/register' .",
    "serve": "yarn migrate && node -r 'flow-remove-types/register' .",
    "crontab": "node -r 'flow-remove-types/register' crontab.js",
    "worker": "node -r 'flow-remove-types/register' worker.js",
    "test": "yarn run mocha --timeout 10000 --grep @slow --invert './server/**/*.spec.js'",
    "mocha": "NODE_ENV=test mocha --timeout 10000 --exit --require './scripts/setup-test'",
    "test:slow": "NODE_ENV=test mocha --timeout 10000 --exit --require './scripts/setup-test' 'server/**/*.spec.js'",
    "test:grep": "yarn run mocha --timeout 10000 './server/**/*.spec.js' -g ",
    "test:igrep": "LOGGER_LEVEL=debug yarn run test:grep",
    "lint": "eslint '**/*.js'",
    "flow": "flow",
    "docker:test": "docker compose -f docker-compose.test.yml down && docker compose -f docker-compose.test.yml up --build --exit-code-from gstech-backend.test",
    "docker:start": "docker compose up --build -d",
    "migrate": "node ../gstech-core/modules/migrator.js migrate",
    "add:migration": "node ../gstech-core/modules/migrator.js create",
    "opti:migrate": "node ./server/modules/core/optimove/migrator.js migrate",
    "opti:add:migration": "node ./server/modules/core/optimove/migrator.js create",
    "dev:crontab": "nodemon -r 'flow-remove-types/register' crontab.js",
    "dev:worker": "KAFKA_ENABLED=true notifications_LD=http://localhost:3020 notifications_CJ=http://localhost:3021 notifications_KK=http://localhost:3022 notifications_OS=http://localhost:3023 notifications_FK=http://localhost:3024 notifications_SN=http://localhost:3025 notifications_VB=http://localhost:3026 nodemon -r 'flow-remove-types/register' worker.js",
    "setup:db": "NODE_ENV=test PORT=3002 node scripts/setup-db.js",
    "fakedata": "NODE_ENV=test node scripts/create-fake-data.js",
    "update:geo": "node -r 'flow-remove-types/register' scripts/update-geo-data.js",
    "script:runner": "node scripts/runner.js -- ",
    "tags:update-campaign-abusers": "node scripts/tag-campaign-abusers.js",
    "tags:vip": "node scripts/tag-vip.js",
    "reports:421-daily-activity": "node scripts/421-daily-activity-update-job.js",
    "reports:421-game-turnover": "node scripts/421-game-turnover-update-job.js",
    "reports:421-hourly-activity": "node scripts/421-hourly-activity-update-job.js",
    "reports:421-player-game-summary": "node scripts/421-player-game-summary-update-job.js",
    "fix:962-close-zero-balance-accounts-prohibited-countries": "node -r 'flow-remove-types/register' scripts/962-close-zero-balance-accounts-prohibited-countries.js",
    "fix:IDXD-1197-create-a-view-for-the-dsr": "node -r 'flow-remove-types/register' scripts/IDXD-1197-create-a-view-for-the-dsr.js",
    "evolution:migration": "flow-node ./scripts/27-import-evo-oss-games.js"
  }
}
